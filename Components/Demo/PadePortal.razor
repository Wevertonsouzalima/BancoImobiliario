    private string DonutSimples(string numero, string label, double frac, string corFg, string corBg, int tamanho = 108)
    {
        double raio = 52, circ = 2 * Math.PI * raio, traco = circ * Math.Clamp(frac, 0, 1);
        string dash = $"{traco.ToString(_inv)} {(circ - traco).ToString(_inv)}";
        string txtNum = string.IsNullOrEmpty(numero) ? "" : $"<text x='60' y='58' text-anchor='middle' style='fill:{corFg};font-size:20px;font-weight:700'>{numero}</text>";
        string txtLbl = string.IsNullOrEmpty(label) ? "" : $"<text x='60' y='76' text-anchor='middle' style='fill:{corFg};opacity:.7;font-size:8px;letter-spacing:1px'>{label}</text>";
        return $"<svg viewBox='0 0 120 120' style='width:{tamanho}px;height:{tamanho}px'>" +
               $"<circle cx='60' cy='60' r='52' style='fill:none;stroke:{corBg};stroke-width:11'/>" +
               $"<circle cx='60' cy='60' r='52' style='fill:none;stroke:{corFg};stroke-width:11;stroke-linecap:round' stroke-dasharray='{dash}' transform='rotate(-90 60 60)'/>" +
               txtNum + txtLbl + "</svg>";
    }

    private string GraficoLinha(double[] valores, string[] rotulos)
    {
        double w = 760, h = 220, padL = 40, padB = 30, padT = 20, padR = 20;
        double maxV = 130, minV = 50;
        double plotW = w - padL - padR, plotH = h - padT - padB;
        int n = 4;
        var pts = new List<string>();
        var circ = new System.Text.StringBuilder();
        var labs = new System.Text.StringBuilder();
        for (int i = 0; i < n; i++)
        {
            double x = padL + plotW * i / (n - 1);
            labs.Append($"<text x='{x.ToString(_inv)}' y='{(h - 6).ToString(_inv)}' text-anchor='middle' style='fill:#6b7280;font-size:11px'>{rotulos[i]}</text>");
            if (i < valores.Length)
            {
                double y = padT + plotH * (1 - (valores[i] - minV) / (maxV - minV));
                pts.Add($"{x.ToString(_inv)},{y.ToString(_inv)}");
                circ.Append($"<circle cx='{x.ToString(_inv)}' cy='{y.ToString(_inv)}' r='5' style='fill:#fff;stroke:#8b1a3f;stroke-width:2'/>");
                circ.Append($"<text x='{x.ToString(_inv)}' y='{(y - 12).ToString(_inv)}' text-anchor='middle' style='fill:#8b1a3f;font-size:11px;font-weight:700'>{valores[i].ToString("N1", _pt)}%</text>");
            }
        }
        var grid = new System.Text.StringBuilder();
        foreach (var gv in new[] { 130, 100, 50 })
        {
            double y = padT + plotH * (1 - (gv - minV) / (maxV - minV));
            grid.Append($"<line x1='{padL}' y1='{y.ToString(_inv)}' x2='{(w - padR).ToString(_inv)}' y2='{y.ToString(_inv)}' style='stroke:#eee;stroke-dasharray:3 3'/>");
            grid.Append($"<text x='{(w - padR + 4).ToString(_inv)}' y='{(y + 3).ToString(_inv)}' style='fill:#9ca3af;font-size:10px'>{gv}%</text>");
        }
        return $"<svg viewBox='0 0 {w.ToString(_inv)} {h.ToString(_inv)}' style='width:100%;height:auto'>{grid}<polyline points='{string.Join(" ", pts)}' style='fill:none;stroke:#8b1a3f;stroke-width:2'/>{circ}{labs}</svg>";
    }

