        private static Indicador Ind(string desc, params (int peso, int nota)[] tri)
        {
            var i = new Indicador { Descricao = desc };
            for (int t = 0; t < 4 && t < tri.Length; t++) { i.Tri[t] = new TriValor { Peso = tri[t].peso, Nota = tri[t].nota }; }
            return i;
        }

        private static AreaResultado Area(string nome, string sigla, string cor, decimal dist, params int[] tris)
        {
            var a = new AreaResultado { Nome = nome, Sigla = sigla, Cor = cor, Distribuicao = dist };
            for (int t = 0; t < tris.Length && t < 4; t++) { a.Tri[t] = tris[t]; }
            return a;
        }
