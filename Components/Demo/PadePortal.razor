    // ===================== Cálculos =====================
    private decimal NotaBlocoTri(Bloco b, int t)
    {
        decimal s = 0m;
        foreach (var i in b.Indicadores) { s += i.Tri[t].Peso * i.Tri[t].Nota; }
        return Math.Round(s / 100m, 2);
    }

    private decimal NotaContratoTri(Funcionario f, int t)
    {
        if (f.Blocos is null) { return f.NotaContratoStored ?? 0m; }
        decimal pond = 0m, pesos = 0m;
        foreach (var b in f.Blocos) { pond += NotaBlocoTri(b, t) * b.PesoBloco; pesos += b.PesoBloco; }
        return pesos == 0m ? 0m : Math.Round(pond / pesos, 2);
    }

    private decimal NotaContrato(Funcionario f)
    {
        if (f.Blocos is null) { return f.NotaContratoStored ?? 0m; }
        decimal s = 0m;
        for (int t = 0; t < 4; t++) { s += NotaContratoTri(f, t); }
        return Math.Round(s / 4m, 2);
    }

    private decimal? ResultFinalAreaNullable(AreaResultado a)
    {
        decimal? ultimo = null;
        for (int t = 0; t < 4; t++) { if (a.Tri[t].HasValue) { ultimo = a.Tri[t]; } }
        return ultimo;
    }
    private decimal ResultFinalArea(AreaResultado a) => ResultFinalAreaNullable(a) ?? 0m;

    private decimal? MediaAreasTri(Funcionario f, int t)
    {
        if (f.Areas is null) { return null; }
        var vals = f.Areas.Where(a => a.Tri[t].HasValue).Select(a => a.Tri[t]!.Value).ToList();
        if (vals.Count == 0) { return null; }
        return Math.Round(vals.Average(), 1);
    }

    private decimal NotaAreas(Funcionario f)
    {
        if (f.Areas is null) { return f.NotaAreasStored ?? 0m; }
        var finais = f.Areas.Select(ResultFinalArea).Where(v => v > 0m).ToList();
        return finais.Count == 0 ? 0m : Math.Round(finais.Average(), 2);
    }

    private decimal NotaPade(Funcionario f) => Math.Round(NotaContrato(f) * 0.70m + NotaAreas(f) * 0.30m, 2);

    private decimal? Ranking(Funcionario f) => f.Inelegivel ? null : Math.Round(NotaPade(f) - f.DesagioPts, 2);

