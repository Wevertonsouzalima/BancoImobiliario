@page "/pade"
@rendermode InteractiveServer
@using System.Globalization

@*
    ============================================================================
    PADE IPC - Portal completo (single-file, Blazor Server / .NET 9)
    ----------------------------------------------------------------------------
    Shell (sidebar + topbar) + 7 telas, alternadas pelo papel:
      GESTOR      -> Início, Equipe, Contrato de Metas, Áreas Atendidas, Histórico
      FUNCIONÁRIO -> Minha performance
      ADMIN       -> Apuração do PADE
    Dados mock centralizados em PadeMock (@code). Bootstrap Icons via CDN.
    Cálculos: NotaPADE = Contrato×70% + Resultado(Áreas)×30%.
    ============================================================================
*@

<HeadContent>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
</HeadContent>

<div class="pade-app">

    @* =============================== SIDEBAR =============================== *@
    <aside class="pade-side">
        <div class="pade-side-top">
            <a class="pade-sair" href="javascript:void(0)">Sair</a>
            <div class="pade-side-avatar">@UsuarioAvatar()</div>
            <div class="pade-side-nome">@UsuarioNome()</div>
            <span class="pade-side-papel">@UsuarioPapelLabel()</span>
        </div>

        <nav class="pade-nav">
            @foreach (var item in NavDoPapel())
            {
                var it = item;
                <button type="button"
                        class="pade-nav-item @(_rota == it.Rota ? "ativo" : "")"
                        @onclick="() => _rota = it.Rota">
                    <i class="bi @it.Icone"></i>
                    <span>@it.Titulo</span>
                </button>
            }
        </nav>

        @if (_papel == Papel.Funcionario)
        {
            <div class="pade-vercomo">
                <label>VER COMO</label>
                <select class="pade-input" @bind="_funcSelecionadoId">
                    @foreach (var f in PadeMock.Funcionarios)
                    {
                        <option value="@f.Id">@f.Nome</option>
                    }
                </select>
            </div>
        }
    </aside>

    @* ================================ MAIN ================================ *@
    <main class="pade-main">

        <header class="pade-topbar">
            <div class="pade-topbar-tit">
                <span class="pade-pade">PADE IPC</span>
                <h1>@TituloPagina()</h1>
                <span class="pade-sub">@SubtituloPagina()</span>
            </div>

            <div class="pade-topbar-dir">
                <div class="pade-papel-toggle">
                    @foreach (var p in (Papel[])Enum.GetValues(typeof(Papel)))
                    {
                        var pp = p;
                        <button type="button"
                                class="pade-papel-btn @(_papel == pp ? "ativo" : "")"
                                @onclick="() => TrocarPapel(pp)">
                            <i class="bi @IconePapel(pp)"></i>
                            <span>@NomePapel(pp)</span>
                        </button>
                    }
                </div>
                <div class="pade-periodo">
                    <i class="bi bi-calendar-event"></i>
                    <select class="pade-periodo-sel" value="@_trimApuracao" @onchange="OnTrocarPeriodo">
                        @for (int t = 0; t < 4; t++)
                        {
                            var tl = t;
                            <option value="@tl">@(tl + 1)º TRIMESTRE · 2026</option>
                        }
                    </select>
                </div>
                <button type="button" class="pade-ic-btn"><i class="bi bi-bell"></i><span class="pade-dot"></span></button>
                <button type="button" class="pade-ic-btn"><i class="bi bi-file-earmark-text"></i></button>
                <div class="pade-user">
                    <span class="pade-user-av">@UsuarioAvatar()</span>
                    <div class="pade-user-info">
                        <strong>@UsuarioNome()</strong>
                        <span>@UsuarioDescricao()</span>
                    </div>
                </div>
            </div>
        </header>

        <div class="pade-conteudo">

            @* ----------------------------- GESTOR :: INÍCIO ----------------------------- *@
            @if (_rota == "g-inicio")
            {
                <div class="pade-banner">
                    <div>
                        <span class="pade-banner-eyebrow">BEM-VINDA</span>
                        <h2 class="pade-banner-h">Olá, GESTOR(A).</h2>
                        <p class="pade-banner-p">
                            Período de apuração: <b>@(_trimApuracao + 1)º Trimestre · 2026</b>.
                            Você tem <b>36 dias</b> para finalizar as avaliações da sua equipe.
                        </p>
                    </div>
                    <div class="pade-banner-donut">
                        @((MarkupString)DonutSimples("36", "DIAS", 0.62, "#ffffff", "rgba(255,255,255,.25)"))
                    </div>
                </div>

                <div class="pade-stats-4">
                    <div class="pade-stat pade-stat-red">
                        <div class="pade-stat-top"><span>EQUIPE TOTAL</span><i class="bi bi-people"></i></div>
                        <strong>8</strong>
                    </div>
                    <div class="pade-stat">
                        <div class="pade-stat-top"><span>AVALIAÇÕES PENDENTES</span><i class="bi bi-info-circle"></i></div>
                        <strong>2</strong>
                        <small>0 pendente · 2 não iniciada</small>
                    </div>
                    <div class="pade-stat">
                        <div class="pade-stat-top"><span>CONCLUÍDAS</span><i class="bi bi-check-circle"></i></div>
                        <strong>6</strong>
                        <small>de 8 colaboradores</small>
                    </div>
                    <div class="pade-stat">
                        <div class="pade-stat-top"><span>EM LICENÇA</span><i class="bi bi-info-circle"></i></div>
                        <strong>1</strong>
                        <small>preenchimento como n/a</small>
                    </div>
                </div>

                <div class="pade-2col">
                    <div class="pade-card">
                        <div class="pade-card-head">
                            <span class="pade-card-tit"><i class="bi bi-bell"></i> Notificações <span class="pade-chip-novas">4 NOVAS</span></span>
                            <a href="javascript:void(0)" class="pade-link">Ver todas</a>
                        </div>
                        @foreach (var n in PadeMock.Notificacoes)
                        {
                            <div class="pade-notif">
                                <span class="pade-notif-ic"><i class="bi @n.Icone"></i></span>
                                <div class="pade-notif-txt">
                                    <strong>@n.Titulo</strong>
                                    <span>@n.Descricao</span>
                                </div>
                                <div class="pade-notif-meta">
                                    <a href="javascript:void(0)" class="pade-link">@n.Acao</a>
                                    <small>@n.Quando</small>
                                </div>
                            </div>
                        }
                    </div>

                    <div class="pade-card">
                        <div class="pade-card-head">
                            <span class="pade-card-tit">Composição PADE</span>
                            <span class="pade-mini">1ºTRI</span>
                        </div>
                        <p class="pade-muted-sm">média da sua equipe</p>
                        <div class="pade-comp">
                            <div class="pade-comp-donut">
                                @((MarkupString)DonutSimples("93,18", "MÉDIA", 0.72, "#8b1a3f", "#efe3e7"))
                            </div>
                            <div class="pade-comp-leg">
                                <div class="pade-leg-row"><span class="pade-dotc" style="background:#8b1a3f"></span> Contrato de Metas <small>70% da nota PADE</small><b>85,4%</b></div>
                                <div class="pade-leg-row"><span class="pade-dotc" style="background:#d23a5c"></span> Áreas Atendidas <small>30% da nota PADE</small><b>111,4%</b></div>
                                <div class="pade-leg-row pade-leg-total">Nota PADE média <b>93,18%</b></div>
                            </div>
                        </div>
                    </div>
                </div>

                <div class="pade-stats-3">
                    <div class="pade-mini-card"><i class="bi bi-file-earmark-text"></i><div><strong>Manual do Programa</strong><span>Regras, pesos e critérios da apuração PADE.</span></div></div>
                    <div class="pade-mini-card"><i class="bi bi-people"></i><div><strong>Hierarquia da equipe</strong><span>Identificou alguém que não deveria estar sob sua gestão? Movimente.</span></div><i class="bi bi-chevron-right pade-chev"></i></div>
                    <div class="pade-mini-card"><i class="bi bi-info-circle"></i><div><strong>Dúvidas e sugestões</strong><span>Fale com o time Campanhas &amp; Incentivos.</span></div><i class="bi bi-chevron-right pade-chev"></i></div>
                </div>
            }

            @* ----------------------------- GESTOR :: EQUIPE ----------------------------- *@
            @if (_rota == "g-equipe")
            {
                <div class="pade-tabs">
                    @foreach (var tab in EquipeTabs())
                    {
                        var tb = tab;
                        <button type="button" class="pade-tab @(_equipeFiltro == tb.Key ? "ativo" : "")"
                                @onclick="() => _equipeFiltro = tb.Key">
                            @tb.Label <span class="pade-tab-n">@tb.Count</span>
                        </button>
                    }
                    <div class="pade-tabs-dir">
                        <div class="pade-busca"><i class="bi bi-search"></i><input placeholder="Buscar profissional..." @bind="_equipeBusca" @bind:event="oninput" /></div>
                        <button class="pade-btn pade-btn-outline"><i class="bi bi-download"></i> Exportar</button>
                    </div>
                </div>

                <div class="pade-grid-func">
                    @foreach (var f in EquipeFiltrada())
                    {
                        var fn = f;
                        <div class="pade-func-card">
                            <div class="pade-func-card-head">
                                <span class="pade-av" style="background:@fn.CorAvatar">@fn.Id</span>
                                <div class="pade-func-card-nome">
                                    <strong>@fn.Nome</strong>
                                    <span>@fn.Cargo · @fn.Grupo</span>
                                </div>
                                @{
                                    var bdg = BadgeEquipe(fn);
                                }
                                @if (bdg is not null)
                                {
                                    <span class="pade-badge @bdg.Value.Classe">@bdg.Value.Texto</span>
                                }
                            </div>
                            <div class="pade-func-card-body">
                                <div class="pade-mini-donut">
                                    @((MarkupString)DonutSimples(FmtNum(NotaPade(fn)), "", Math.Min((double)NotaPade(fn) / 130d, 1d), "#8b1a3f", "#efe3e7", 88))
                                </div>
                                <div class="pade-barras">
                                    <div class="pade-barra-row"><span>Contrato (70%)</span><b>@FmtNum(NotaContrato(fn))</b></div>
                                    <div class="pade-barra"><div class="pade-barra-fill" style="width:@(Math.Min((double)NotaContrato(fn), 130) / 130 * 100)%"></div></div>
                                    <div class="pade-barra-row"><span>Áreas (30%)</span><b>@FmtNum(NotaAreas(fn))%</b></div>
                                    <div class="pade-barra"><div class="pade-barra-fill" style="width:@(Math.Min((double)NotaAreas(fn), 130) / 130 * 100)%"></div></div>
                                </div>
                            </div>
                            <div class="pade-status-row"><span>Contrato de Metas</span> @((MarkupString)StatusPill(fn.StatusContrato))</div>
                            <div class="pade-status-row"><span>Áreas Atendidas<br /><small>atualizado automaticamente</small></span> @((MarkupString)StatusPill("CONCLUIDO"))</div>
                            <button class="pade-btn pade-btn-primario pade-btn-full" @onclick="() => IrParaContrato(fn)"><i class="bi bi-pencil"></i> Avaliar contrato</button>
                        </div>
                    }
                </div>
            }

            @* ------------------------- GESTOR :: CONTRATO DE METAS ------------------------- *@
            @if (_rota == "g-contrato")
            {
                var fc = PadeMock.F1;
                <section class="pade-func-bar">
                    <span class="pade-av pade-av-lg" style="background:@fc.CorAvatar">@fc.Id</span>
                    <div class="pade-func-bar-dados">
                        <h2>@fc.Nome</h2>
                        <div class="pade-func-bar-grid">
                            <span><b>Cargo:</b> @fc.Cargo</span>
                            <span><b>Admissão:</b> @fc.Admissao</span>
                            <span class="pade-muted">Área Gerencial: <span class="pade-ink">@fc.AreaGerencial</span></span>
                            <span><b>Grupo de Competição:</b> <span class="pade-wine">@fc.Grupo</span></span>
                        </div>
                        <button class="pade-btn-licenca"><i class="bi bi-info-circle"></i> Informar licença</button>
                    </div>
                    <div class="pade-func-bar-donut">
                        @((MarkupString)DonutSimples(Fmt2(NotaContrato(fc)), "NOTA FINAL", Math.Min((double)NotaContrato(fc) / 130d, 1d), "#8b1a3f", "#efe3e7"))
                    </div>
                    <div class="pade-func-bar-acoes">
                        <button class="pade-btn pade-btn-primario"><i class="bi bi-check-lg"></i> Salvar e enviar</button>
                        <button class="pade-btn pade-btn-outline"><i class="bi bi-pencil"></i> Salvar rascunho</button>
                        <button class="pade-btn pade-btn-texto"><i class="bi bi-x-lg"></i> Fechar sem salvar</button>
                    </div>
                </section>

                <section class="pade-tri-cards">
                    @for (int t = 0; t < 4; t++)
                    {
                        var tl = t;
                        var ap = tl == _trimApuracao;
                        <div class="pade-tri-card @(ap ? "ativo" : "")">
                            <div class="pade-tri-top"><span>@(tl + 1)º TRIMESTRE</span>@if (ap){
                                <span class="pade-tri-badge">EM APURAÇÃO</span>
                            }
                        </div>
                        <strong>@Fmt2(NotaContratoTri(fc, tl))%</strong>
                    </div>
                }
                <div class="pade-tri-card final">
                    <div class="pade-tri-top"><span>NOTA FINAL</span></div>
                    <strong>@Fmt2(NotaContrato(fc))%</strong>
                </div>
            </section>

               
            decimal somaBlocos = SomaPesosBlocos(fc);
            bool blocosOk = somaBlocos == 100m;

            <section class="pade-pesos">
                <div class="pade-pesos-info">
                    <span class="pade-pesos-tit">Soma dos pesos dos blocos (deve totalizar 100%)</span>
                    <div class="pade-pesos-track"><div class="pade-pesos-fill @(blocosOk ? "ok" : "warn")" style="width:@(Math.Min((double)somaBlocos, 100d))%"></div></div>
                    <span class="pade-pesos-val @(blocosOk ? "ok" : "warn")">@FmtNum(somaBlocos)<small>/100%</small></span>
                </div>
                <div class="pade-pesos-status @(blocosOk ? "status-ok" : "status-warn")">
                    <i class="bi @(blocosOk ? "bi-check-circle-fill" : "bi-info-circle-fill")"></i>
                    <span>@(blocosOk ? "Pronto para salvar" : "Ajuste os pesos")</span>
                </div>
            </section>

            @foreach (var bloco in fc.Blocos!)
            {
                var b = bloco;
                <div class="pade-bloco">
                    <div class="pade-bloco-head">
                        <button class="pade-chevron" @onclick="() => b.Expandido = !b.Expandido"><i class="bi @(b.Expandido ? "bi-chevron-down" : "bi-chevron-right")"></i></button>
                        <div class="pade-bloco-barra"></div>
                        <div class="pade-bloco-tit"><strong>@b.Nome</strong><span>@b.Indicadores.Count indicadores · @(TodosPesosTriOk(b) ? "pesos por trimestre OK" : "ajustar pesos")</span></div>
                        <div class="pade-bloco-peso"><label>PESO DO BLOCO</label><input type="number" min="0" max="100" class="pade-input pade-input-peso" @bind="b.PesoBloco" @bind:event="oninput" /><span>%</span></div>
                        <div class="pade-bloco-nota"><span>@(_trimApuracao + 1)ºTRI</span><strong>@Fmt2(NotaBlocoTri(b, _trimApuracao))%</strong></div>
                        <button class="pade-lix" @onclick="() => fc.Blocos!.Remove(b)"><i class="bi bi-trash3"></i></button>
                    </div>

                    @if (b.Expandido)
                    {
                        <div class="pade-tab-wrap">
                            <table class="pade-tabela">
                                <thead>
                                    <tr><th class="pade-col-ind" rowspan="2">INDICADOR</th>@for (int t = 0; t < 4; t++){
                                        <th colspan="2" class="pade-th-grp">@(t + 1)º TRIMESTRE</th>
                                    }
                                    <th rowspan="2"></th></tr>
                                    <tr class="pade-th-sub">@for (int t = 0; t < 4; t++){
                                        <th>PESO</th><th>NOTA</th>
                                    }
                                </tr>
                            </thead>
                            <tbody>
                                @{
                                    int li = 0;
                                }
                                @foreach (var indic in b.Indicadores)
                                {
                                    var ind = indic; li++;
                                    <tr>
                                        <td class="pade-col-ind"><span class="pade-num-li">@li</span><input class="pade-input pade-input-txt" @bind="ind.Descricao" @bind:event="oninput" /></td>
                                        @for (int t = 0; t < 4; t++)
                                        {
                                            var tl = t;
                                            <td class="pade-cel-num"><div class="pade-suf"><input type="number" class="pade-input" @bind="ind.Tri[tl].Peso" @bind:event="oninput" /><span>%</span></div></td>
                                            <td class="pade-cel-num"><div class="pade-suf"><input type="number" class="pade-input" @bind="ind.Tri[tl].Nota" @bind:event="oninput" /><span>%</span></div></td>
                                        }
                                        <td><button class="pade-rem-ind" @onclick="() => b.Indicadores.Remove(ind)"><i class="bi bi-x-lg"></i></button></td>
                                    </tr>
                                }
                                <tr class="pade-soma">
                                    <td class="pade-col-ind">SOMA DOS PESOS</td>
                                    @for (int t = 0; t < 4; t++)
                                    {
                                        var tl = t; var sp = SomaPesosInd(b, tl); bool ok = sp == 100m;
                                        <td colspan="2" class="pade-cel-soma"><span class="pade-pill-soma @(ok ? "ok" : "warn")">@FmtNum(sp)% <i class="bi @(ok ? "bi-check-lg" : "bi-exclamation-triangle")"></i></span></td>
                                    }
                                    <td></td>
                                </tr>
                            </tbody>
                        </table>
                    </div>
                    <button class="pade-add-link" @onclick="() => b.Indicadores.Add(new Indicador())"><i class="bi bi-plus-lg"></i> Adicionar indicador</button>
                }
            </div>
        }
        <button class="pade-add-bloco" @onclick="() => AdicionarBlocoNovo(fc)"><i class="bi bi-plus-lg"></i> Adicionar novo bloco</button>
    }

    @* ------------------------- GESTOR :: ÁREAS ATENDIDAS ------------------------- *@
    @if (_rota == "g-areas")
    {
        var fa = PadeMock.F1;
        <div class="pade-info-banner">
            <span class="pade-info-ic"><i class="bi bi-graph-up-arrow"></i></span>
            <div>
                <strong>Resultado Operacional / Lucro Líquido — 30% da nota PADE</strong>
                <p>Apuramos o resultado de <b>cada área atendida</b> e tiramos a <b>média simples</b> — independente do % de atendimento. Acompanhamos trimestralmente, mas para o PADE vale o <b>resultado final (anual)</b>.</p>
            </div>
            <span class="pade-fonte">FONTE: SAS · RESULTADO OP.</span>
        </div>

        <section class="pade-areas-head">
            <span class="pade-av pade-av-lg" style="background:@fa.CorAvatar">@fa.Id</span>
            <div class="pade-areas-head-nome"><h2>@fa.Nome</h2><span>@fa.Cargo · @fa.Grupo</span></div>
            <div class="pade-areas-head-donut">@((MarkupString)DonutSimples("121,00", "RESULTADO", 0.93, "#8b1a3f", "#efe3e7"))</div>
            <div class="pade-areas-head-stats">
                <div><span>Áreas atendidas</span><b>3</b></div>
                <div><span>Último trimestre apurado</span><b>3º TRI</b></div>
                <div><span>Resultado final (0–130%)</span><b>121,00%</b></div>
                <div><span>Contribuição PADE (×30%)</span><b>36,30%</b></div>
            </div>
        </section>

        <div class="pade-chips">
            <span class="pade-chips-lbl">VER OUTRO FUNCIONÁRIO:</span>
            @foreach (var f in PadeMock.Funcionarios)
            {
                var fl = f;
                <button class="pade-chip @(_areaFuncId == fl.Id ? "ativo" : "")" @onclick="() => _areaFuncId = fl.Id">FUNCIONÁRIO</button>
            }
        </div>

        <div class="pade-card">
            <div class="pade-card-head"><span class="pade-card-tit">Resultado Operacional por área e por trimestre</span><span class="pade-mini">Read-only · atualizado pela base</span></div>
            <p class="pade-muted-sm">Média simples na última linha · resultado anual destacado à direita</p>
            <table class="pade-tabela pade-tabela-areas">
                <thead><tr><th class="pade-col-ind">ÁREA</th><th>1º TRI</th><th>2º TRI</th><th>3º TRI ●</th><th>4º TRI</th><th>RESULT. FINAL</th></tr></thead>
                <tbody>
                    @foreach (var ar in fa.Areas!)
                    {
                        <tr>
                            <td class="pade-col-ind"><span class="pade-dotc" style="background:@ar.Cor"></span> @ar.Nome</td>
                            @for (int t = 0; t < 4; t++)
                            {
                                <td>@(ar.Tri[t].HasValue ? Fmt1(ar.Tri[t]!.Value) + "%" : "—")</td>
                            }
                            <td><span class="pade-pill-final">@Fmt1(ResultFinalArea(ar))%</span></td>
                        </tr>
                    }
                    <tr class="pade-media-tri">
                        <td class="pade-col-ind">MÉDIA DO TRIMESTRE</td>
                        @for (int t = 0; t < 4; t++)
                        {
                            var m = MediaAreasTri(fa, t);
                            <td>@(m.HasValue ? Fmt1(m.Value) + "%" : "—")</td>
                        }
                        <td></td>
                    </tr>
                    <tr class="pade-result-final">
                        <td class="pade-col-ind pade-wine">RESULTADO FINAL → PADE</td>
                        <td colspan="3" class="pade-muted">Média simples dos resultados finais das áreas atendidas</td>
                        <td class="pade-muted-sm">121,00% × 30%</td>
                        <td class="pade-wine"><b>+36,30</b></td>
                    </tr>
                </tbody>
            </table>
        </div>

        <div class="pade-card">
            <div class="pade-card-head"><span class="pade-card-tit">Evolução do resultado (média trimestral)</span></div>
            @((MarkupString)GraficoLinha(new double[] { 115.7, 118.0, 121.0 }, new[] { "1º TRI", "2º TRI", "3º TRI", "4º TRI" }))
        </div>
    }

    @* ----------------------------- GESTOR :: HISTÓRICO ----------------------------- *@
    @if (_rota == "g-historico")
    {
        <div class="pade-hist-banner">
            <span class="pade-hist-ic"><i class="bi bi-trophy"></i></span>
            <div>
                <span class="pade-banner-eyebrow">HISTÓRICO · APENAS GESTOR</span>
                <h2>Premiações dos seus funcionários</h2>
                <p>Acompanhe quantas vezes cada profissional ganhou o programa, em qual posição e a nota PADE de cada ano. Esta tela é exclusiva da gestão.</p>
            </div>
        </div>

        <div class="pade-stats-4">
            <div class="pade-stat"><div class="pade-stat-top"><span>ANOS DE HISTÓRICO</span><i class="bi bi-calendar3"></i></div><strong>4</strong></div>
            <div class="pade-stat"><div class="pade-stat-top"><span>PROFISSIONAIS</span><i class="bi bi-people"></i></div><strong>8</strong></div>
            <div class="pade-stat pade-stat-red"><div class="pade-stat-top"><span>VITÓRIAS DA EQUIPE</span><i class="bi bi-trophy"></i></div><strong>3</strong></div>
            <div class="pade-stat"><div class="pade-stat-top"><span>TOP 3 NO ÚLTIMO ANO</span></div><strong>0</strong></div>
        </div>

        <div class="pade-card">
            <div class="pade-card-head"><div><span class="pade-card-tit">Histórico ano a ano</span><p class="pade-muted-sm">Posição no ranking · nota final · medalha quando ficou no Top 3</p></div><a class="pade-link" href="javascript:void(0)"><i class="bi bi-download"></i> Exportar</a></div>
            <table class="pade-tabela pade-tabela-hist">
                <thead><tr><th class="pade-col-ind">FUNCIONÁRIO</th><th>VITÓRIAS</th><th>2022</th><th>2023</th><th>2024</th><th>2025</th></tr></thead>
                <tbody>
                    @foreach (var f in PadeMock.Funcionarios)
                    {
                        <tr>
                            <td class="pade-col-ind"><span class="pade-av pade-av-sm" style="background:@f.CorAvatar">@f.Id</span><div class="pade-hist-nome"><strong>@f.Nome</strong><span>@f.Cargo</span></div></td>
                            <td><span class="pade-vit">@f.Vitorias×</span></td>
                            @foreach (var h in f.Historico)
                            {
                                <td>
                                    @if (h.Posicao.HasValue)
                                    {
                                        <span class="pade-pos @(h.Posicao.Value <= 3 ? (h.Posicao.Value == 1 ? "ouro" : "bronze") : "")">@(h.Posicao.Value <= 3 ? "🏅 " : "")@(h.Posicao.Value)º</span>
                                        <div class="pade-pos-nota">@Fmt0(h.Nota)%</div>
                                    }
                                    else
                                    {

                                        <span class="pade-muted">—</span>
                                    }
                                </td>
                            }
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <p class="pade-secao-lbl">PROFISSIONAIS COM MAIS CONQUISTAS</p>
        <div class="pade-stats-4">
            @foreach (var f in PadeMock.Funcionarios.Where(x => x.Vitorias > 0).OrderByDescending(x => x.Vitorias).Take(2)
                      .Concat(PadeMock.Funcionarios.Where(x => x.Id is "F2" or "F3")))
            {
                <div class="pade-conq-card">
                    <span class="pade-av" style="background:@f.CorAvatar">@f.Id</span>
                    <div><strong>@f.Nome</strong><span>@f.Cargo</span><small>Último: 2025 · 5º lugar</small></div>
                    @if (f.Vitorias > 0)
                    {
                        <span class="pade-badge pade-badge-wine">@f.Vitorias× VENCEDOR</span>
                    }
                </div>
            }
        </div>
    }

    @* ------------------------- FUNCIONÁRIO :: MINHA PERFORMANCE ------------------------- *@
    @if (_rota == "f-performance")
    {
        var fp = PadeMock.PorId(_funcSelecionadoId);
        <div class="pade-banner pade-banner-func">
            <div class="pade-banner-donut pade-banner-donut-lg">@((MarkupString)DonutSimples("", "NOTA PADE", 0.0, "rgba(255,255,255,.9)", "rgba(255,255,255,.25)"))</div>
            <div>
                <span class="pade-banner-eyebrow">SUA PERFORMANCE</span>
                <h2 class="pade-banner-h">Olá, @fp.Nome.</h2>
                <p class="pade-banner-p">Sua nota atual no programa PADE é <b>@Fmt2(NotaPade(fp))%</b>. Acompanhe abaixo o detalhe da composição da sua nota — você não tem acesso ao ranking ou às notas dos colegas.</p>
            </div>
            <div class="pade-trofeu"><i class="bi bi-trophy"></i><strong>@fp.Vitorias×</strong><span>VEZES QUE GANHOU O PROGRAMA</span></div>
        </div>

        <div class="pade-card pade-grupo">
            <span class="pade-info-ic"><i class="bi bi-people"></i></span>
            <div class="pade-grupo-txt">
                <span class="pade-banner-eyebrow">SEU GRUPO DE COMPETIÇÃO</span>
                <h3>@fp.Grupo</h3>
                <p>Você compete com profissionais do mesmo grupo, definido pela combinação cargo + superintendência. O ranking interno não é compartilhado — você vê apenas a sua nota e a do primeiro colocado.</p>
            </div>
            <div class="pade-grupo-notas">
                <div class="pade-nota-box wine"><span>SUA NOTA</span><b>@Fmt1(NotaPade(fp))%</b></div>
                <div class="pade-nota-box"><span>TOP 1 DO GRUPO</span><b>@Fmt1(NotaPade(fp))%</b></div>
            </div>
        </div>

        <div class="pade-2col">
            <div class="pade-card">
                <div class="pade-card-head"><span class="pade-card-tit"><i class="bi bi-bar-chart"></i> Contrato de Metas</span><span class="pade-badge pade-badge-wine">70% do PADE</span></div>
                <p class="pade-muted-sm">Definido pelo seu gestor a cada trimestre</p>
                <div class="pade-ind-val">Nota deste indicador <b>@Fmt2(NotaContrato(fp))%</b></div>
                <div class="pade-ind-bar"></div>
                <div class="pade-ind-calc"><span>@Fmt0(NotaContrato(fp))% × 70%</span><span>= vale na sua nota PADE <b>@Fmt2(NotaContrato(fp) * 0.70m)</b></span></div>
            </div>
            <div class="pade-card">
                <div class="pade-card-head"><span class="pade-card-tit"><i class="bi bi-graph-up-arrow"></i> Resultado Operacional</span><span class="pade-badge pade-badge-wine">30% do PADE</span></div>
                <p class="pade-muted-sm">Média dos resultados das áreas atendidas</p>
                <div class="pade-ind-val">Nota deste indicador <b>@Fmt2(NotaAreas(fp))%</b></div>
                <div class="pade-ind-bar"></div>
                <div class="pade-ind-calc"><span>@Fmt0(NotaAreas(fp))% × 30%</span><span>= vale na sua nota PADE <b>@Fmt2(NotaAreas(fp) * 0.30m)</b></span></div>
            </div>
        </div>

        <div class="pade-card">
            <div class="pade-card-head"><div><span class="pade-card-tit">Sua evolução trimestral</span><p class="pade-muted-sm">Nota do Contrato de Metas em cada trimestre</p></div></div>
            <div class="pade-evo">
                @for (int t = 0; t < 4; t++)
                {
                    var tl = t; var ap = tl == _trimApuracao;
                    <div class="pade-evo-card">
                        <div class="pade-evo-top"><span>@(tl + 1)º TRIMESTRE</span>@if (ap){
                            <span class="pade-tri-badge wine">EM APURAÇÃO</span>
                        }else
                        {

                            <span class="pade-aguard">AGUARDANDO</span>
                        }
                    </div>
                    <strong>@Fmt2(NotaContratoTri(fp, tl))%</strong>
                </div>
            }
        </div>
    </div>

    <div class="pade-card">
        <div class="pade-card-head"><div><span class="pade-card-tit">Indicadores do Contrato de Metas</span><p class="pade-muted-sm">Visualização dos indicadores definidos pelo seu gestor — sem possibilidade de edição</p></div></div>
        @foreach (var b in (fp.Blocos ?? PadeMock.F1.Blocos!))
        {
            <div class="pade-ro-bloco">
                <div class="pade-ro-bloco-head"><div class="pade-bloco-barra"></div><strong>@b.Nome</strong><span class="pade-ro-peso">Peso do bloco: @FmtNum(b.PesoBloco)%</span></div>
                <table class="pade-tabela pade-tabela-ro">
                    <thead><tr><th class="pade-col-ind">INDICADOR</th>@for (int t = 0; t < 4; t++){
                        <th>@(t + 1)º·PESO</th><th>NOTA</th>
                    }
                </tr></thead>
                <tbody>
                    @foreach (var ind in b.Indicadores)
                    {
                        <tr><td class="pade-col-ind">@ind.Descricao</td>@for (int t = 0; t < 4; t++){
                            <td><span class="pade-ro-peso-cel">@FmtNum(ind.Tri[t].Peso)%</span></td><td><span class="pade-ro-nota-cel">@FmtNum(ind.Tri[t].Nota)%</span></td>
                        }
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
</div>

<div class="pade-card">
    <div class="pade-card-head"><span class="pade-card-tit">Suas áreas atendidas — Resultado Operacional</span></div>
    <table class="pade-tabela">
        <thead><tr><th class="pade-col-ind">ÁREA</th><th>DISTRIBUIÇÃO</th><th>RESULT. FINAL</th></tr></thead>
        <tbody>
            @foreach (var ar in (fp.Areas ?? PadeMock.F1.Areas!))
            {
                <tr><td class="pade-col-ind"><span class="pade-av pade-av-sm" style="background:@ar.Cor">@ar.Sigla</span><div class="pade-hist-nome"><strong>@ar.Nome</strong><span>Apuração trimestral via SAS</span></div></td><td>@FmtNum(ar.Distribuicao)%</td><td><span class="pade-pill-final">@Fmt1(ResultFinalArea(ar))%</span></td></tr>
            }
        </tbody>
    </table>
    <p class="pade-rodape-nota"><i class="bi bi-info-circle"></i> Esta tela mostra apenas a sua performance. Posições no ranking e notas de outros profissionais são restritas à administração do programa.</p>
</div>
            }

@* ----------------------------- ADMIN :: APURAÇÃO ----------------------------- *@
            @if (_rota == "a-apuracao")
{
    <div class="pade-filtros">
        <span class="pade-filtros-lbl">FILTROS:</span>
        <select class="pade-input"><option>Selecione</option></select>
        <select class="pade-input"><option>Selecione</option></select>
        <select class="pade-input"><option>Selecione</option></select>
        <select class="pade-input"><option>Acumulado (todos os tri)</option></select>
        <div class="pade-filtros-dir">
            <button class="pade-btn pade-btn-outline"><i class="bi bi-arrow-clockwise"></i> Recalcular</button>
            <button class="pade-btn pade-btn-outline"><i class="bi bi-download"></i> Exportar Excel</button>
            <button class="pade-btn pade-btn-primario"><i class="bi bi-check-lg"></i> Enviar aos funcionários</button>
        </div>
    </div>

    <div class="pade-stats-5">
        <div class="pade-stat"><div class="pade-stat-top"><span>PROFISSIONAIS</span><i class="bi bi-people"></i></div><strong>8</strong></div>
        <div class="pade-stat"><div class="pade-stat-top"><span>AGUARDANDO APURAÇÃO</span><i class="bi bi-info-circle"></i></div><strong>0</strong></div>
        <div class="pade-stat"><div class="pade-stat-top"><span>AVALIAÇÕES SUSPEITAS</span><i class="bi bi-info-circle"></i></div><strong>0</strong></div>
        <div class="pade-stat"><div class="pade-stat-top"><span>INELEGÍVEIS / DESÁGIO</span><i class="bi bi-info-circle"></i></div><strong>1 / 2</strong></div>
        <div class="pade-stat pade-stat-red"><div class="pade-stat-top"><span>GRUPOS DE COMPETIÇÃO</span><i class="bi bi-bar-chart"></i></div><strong>3</strong></div>
    </div>

    <div class="pade-tabs pade-tabs-admin">
        @{
            var adminTabs = new[] { ("rank", "Ranking por grupo", "8"), ("aprov", "Aprovar / Devolver", "0"), ("susp", "Avaliações suspeitas", "0"), ("eleg", "Elegibilidade & Deságio", "3"), ("comp", "Comparativo entre grupos", "") };
        }
        @foreach (var t in adminTabs)
        {
            var tt = t;
            <button class="pade-tab @(_adminTab == tt.Item1 ? "ativo" : "")" @onclick="() => _adminTab = tt.Item1">@tt.Item2 @if (tt.Item3 != ""){
                <span class="pade-tab-n">@tt.Item3</span>
            }
        </button>
    }
</div>

@foreach (var grupo in PadeMock.Grupos)
{
    var membros = PadeMock.Funcionarios.Where(f => f.Grupo == grupo).ToList();
    var ranqueados = membros.Where(f => !f.Inelegivel).OrderByDescending(f => Ranking(f) ?? 0).ToList();
    var inelegiveis = membros.Where(f => f.Inelegivel).ToList();
    var inelegCount = inelegiveis.Count;
    <div class="pade-grupo-rank">
        <div class="pade-grupo-rank-head"><div class="pade-bloco-barra"></div><strong>Grupo de Competição: @grupo</strong><span class="pade-chip-cinza">@membros.Count profissionais@(inelegCount > 0 ? $" · {inelegCount} inelegível" : "")</span><span class="pade-mini pade-grupo-acum">Acumulado</span></div>
        <table class="pade-tabela pade-tabela-rank">
            <thead><tr><th>POS.</th><th class="pade-col-ind">PROFISSIONAL</th><th>CONTRATO (70%)</th><th>RESULT. (30%)</th><th>NOTA</th><th>DESÁGIO</th><th>RANKING</th><th></th></tr></thead>
            <tbody>
                @{
                    int pos = 0;
                }
                @foreach (var f in ranqueados)
                {
                    pos++;
                    <tr>
                        <td><span class="pade-pos-num @(pos == 1 ? "ouro" : "")">@pos</span></td>
                        <td class="pade-col-ind"><span class="pade-av pade-av-sm" style="background:@f.CorAvatar">@f.Id</span><div class="pade-hist-nome"><strong>@f.Nome</strong><span>@f.Cargo · @f.AreaGerencial</span></div></td>
                        <td>@Fmt2(NotaContrato(f))%</td>
                        <td>@Fmt2(NotaAreas(f))%</td>
                        <td>@Fmt2(NotaPade(f))%</td>
                        <td>@(f.DesagioPts > 0 ? $"-{f.DesagioPts:0} pts" : "—")</td>
                        <td><span class="pade-rank-badge">@Fmt2(Ranking(f) ?? 0)%</span></td>
                        <td><a class="pade-link" href="javascript:void(0)">Ver detalhe ›</a></td>
                    </tr>
                }
                @foreach (var f in inelegiveis)
                {
                    <tr class="pade-ineleg">
                        <td><span class="pade-pos-num ne">N/E</span></td>
                        <td class="pade-col-ind"><span class="pade-av pade-av-sm" style="background:@f.CorAvatar">@f.Id</span><div class="pade-hist-nome"><strong>@f.Nome <span class="pade-badge pade-badge-ineleg">INELEGÍVEL</span></strong><span>@f.Cargo · @f.AreaGerencial</span></div></td>
                        <td>0,00%</td>
                        <td>@Fmt2(NotaAreas(f))%</td>
                        <td>@Fmt2(NotaPade(f))%</td>
                        <td>—</td>
                        <td class="pade-muted">fora do ranking</td>
                        <td><a class="pade-link" href="javascript:void(0)">Ver detalhe ›</a></td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
}
            }

</div>
</main>
</div>

@* ================================ ESTILOS ================================ *@
<style>
