@code {
    // ===================== Cultura / formatação =====================
    private static readonly CultureInfo _ptBr = new CultureInfo("pt-BR");
    private static readonly CultureInfo _inv = CultureInfo.InvariantCulture;

    private string Fmt2(decimal v) => v.ToString("N2", _ptBr);

    private string FmtNum(decimal v)
    {
        // Inteiro -> sem casas; com fração -> 2 casas.
        if (v == Math.Truncate(v))
        {
            return v.ToString("N0", _ptBr);
        }
        return v.ToString("N2", _ptBr);
    }

    // ===================== Enums / modelos =====================
    private enum Perfil
    {
        Gestor,
        Funcionario,
        Admin
    }

    private string NomePerfil(Perfil p)
    {
        string nome;
        switch (p)
        {
            case Perfil.Gestor:
                nome = "Gestor";
                break;
            case Perfil.Funcionario:
                nome = "Funcionário";
                break;
            case Perfil.Admin:
                nome = "Admin";
                break;
            default:
                nome = p.ToString();
                break;
        }
        return nome;
    }

    private string IconePerfil(Perfil p)
    {
        string icone;
        switch (p)
        {
            case Perfil.Gestor:
                icone = "bi-people";
                break;
            case Perfil.Funcionario:
                icone = "bi-person";
                break;
            case Perfil.Admin:
                icone = "bi-gear";
                break;
            default:
                icone = "bi-person";
                break;
        }
        return icone;
    }

    private class Funcionario
    {
        public string Nome { get; set; } = "";
        public string Cargo { get; set; } = "";
        public string Admissao { get; set; } = "";
        public string AreaGerencial { get; set; } = "";
        public string GrupoCompeticao { get; set; } = "";
    }

    private class TrimestreValor
    {
        public decimal Peso { get; set; }
        public decimal Nota { get; set; }
    }

    private class Indicador
    {
        public string Descricao { get; set; } = "";
        public TrimestreValor[] Trimestres { get; set; } =
        {
            new TrimestreValor(), new TrimestreValor(), new TrimestreValor(), new TrimestreValor()
        };
    }

    private class Bloco
    {
        public string Nome { get; set; } = "";
        public decimal PesoBloco { get; set; }
        public bool Expandido { get; set; } = true;
        public List<Indicador> Indicadores { get; set; } = new();
    }

    // ===================== Estado =====================
    private Perfil _perfil = Perfil.Gestor;
    private int _trimApuracao = 0;
    private bool SomenteLeitura => _perfil == Perfil.Funcionario;

    private bool _modalBlocoAberto = false;
    private string _novoBlocoNome = "";
    private decimal? _novoBlocoPeso;

    private readonly string[] _catalogoBlocos =
    {
        "BAU — Atividades Rotina",
        "Projetos Estratégicos",
        "Competências & Comportamental",
        "Resultados / KPIs",
        "Gestão de Pessoas"
    };

    private Funcionario _func = new Funcionario
    {
        Nome = "FUNCIONÁRIO 1",
        Cargo = "Analista Financeiro Pl.",
        Admissao = "20/04/2025",
        AreaGerencial = "Campanhas & Incentivos",
        GrupoCompeticao = "Pleno-1"
    };

    private List<Bloco> _blocos = new();

    protected override void OnInitialized()
    {
        _blocos.Add(new Bloco
        {
            Nome = "BAU — Atividades Rotina",
            PesoBloco = 35m,
            Expandido = true,
            Indicadores = new List<Indicador>
            {
                new Indicador
                {
                    Descricao = "Atendimento de chamados de incentivos",
                    Trimestres = new[]
                    {
                        new TrimestreValor { Peso = 50m, Nota = 115m },
                        new TrimestreValor { Peso = 50m, Nota = 120m },
                        new TrimestreValor { Peso = 50m, Nota = 122m },
                        new TrimestreValor { Peso = 50m, Nota = 130m }
                    }
                },
                new Indicador
                {
                    Descricao = "Conciliação mensal de premiações",
                    Trimestres = new[]
                    {
                        new TrimestreValor { Peso = 50m, Nota = 110m },
                        new TrimestreValor { Peso = 50m, Nota = 118m },
                        new TrimestreValor { Peso = 50m, Nota = 120m },
                        new TrimestreValor { Peso = 50m, Nota = 130m }
                    }
                }
            }
        });
    }

    // ===================== Cálculos =====================
    // Nota do bloco no trimestre = Σ(peso_ind × nota_ind) / 100
    private decimal NotaBlocoTrimestre(Bloco b, int t)
    {
        decimal soma = 0m;
        foreach (var ind in b.Indicadores)
        {
            soma += ind.Trimestres[t].Peso * ind.Trimestres[t].Nota;
        }
        return Math.Round(soma / 100m, 2);
    }

    // Nota do trimestre = Σ(nota_bloco × peso_bloco) / Σ(pesos_blocos)
    private decimal NotaTrimestre(int t)
    {
        decimal somaPonderada = 0m;
        decimal somaPesos = 0m;
        foreach (var b in _blocos)
        {
            somaPonderada += NotaBlocoTrimestre(b, t) * b.PesoBloco;
            somaPesos += b.PesoBloco;
        }
        if (somaPesos == 0m)
        {
            return 0m;
        }
        return Math.Round(somaPonderada / somaPesos, 2);
    }

    // Nota final = média dos 4 trimestres
    private decimal NotaFinal
    {
        get
        {
            decimal soma = 0m;
            for (int t = 0; t < 4; t++)
            {
                soma += NotaTrimestre(t);
            }
            return Math.Round(soma / 4m, 2);
        }
    }

    private decimal SomaPesosBlocos()
    {
        decimal soma = 0m;
        foreach (var b in _blocos)
        {
            soma += b.PesoBloco;
        }
        return soma;
    }

    private decimal SomaPesosIndicadores(Bloco b, int t)
    {
        decimal soma = 0m;
        foreach (var ind in b.Indicadores)
        {
            soma += ind.Trimestres[t].Peso;
        }
        return soma;
    }

    private bool TodosPesosTrimestreOk(Bloco b)
    {
        for (int t = 0; t < 4; t++)
        {
            if (SomaPesosIndicadores(b, t) != 100m)
            {
                return false;
            }
        }
        return true;
    }

    private (string Texto, string Classe, string Icone) ObterStatusPesos(bool blocosOk)
    {
        string texto;
        string classe;
        string icone;
        switch (blocosOk)
        {
            case true:
                texto = "Pronto para salvar";
                classe = "status-ok";
                icone = "bi-check-circle-fill";
                break;
            case false:
                texto = "Ajuste os pesos";
                classe = "status-warn";
                icone = "bi-info-circle-fill";
                break;
            default:
                texto = "";
                classe = "";
                icone = "";
                break;
        }
        return (texto, classe, icone);
    }

    // ===================== Ações =====================
    private void SelecionarPerfil(Perfil p)
    {
        _perfil = p;
    }

    private void OnTrocarPeriodo(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int idx))
        {
            _trimApuracao = idx;
        }
    }

    private void AdicionarIndicador(Bloco b)
    {
        b.Indicadores.Add(new Indicador { Descricao = "" });
    }

    private void RemoverIndicador(Bloco b, Indicador ind)
    {
        b.Indicadores.Remove(ind);
    }

    private void RemoverBloco(Bloco b)
    {
        _blocos.Remove(b);
    }

    private List<string> BlocosDisponiveis()
    {
        var usados = _blocos.Select(x => x.Nome).ToHashSet();
        return _catalogoBlocos.Where(n => !usados.Contains(n)).ToList();
    }

    private void AbrirModalBloco()
    {
        _novoBlocoNome = "";
        _novoBlocoPeso = null;
        _modalBlocoAberto = true;
    }

    private void FecharModalBloco()
    {
        _modalBlocoAberto = false;
    }

    private void SalvarNovoBloco()
    {
        if (string.IsNullOrWhiteSpace(_novoBlocoNome) || !_novoBlocoPeso.HasValue)
        {
            return;
        }

        _blocos.Add(new Bloco
        {
            Nome = _novoBlocoNome,
            PesoBloco = _novoBlocoPeso.Value,
            Expandido = true,
            Indicadores = new List<Indicador>
            {
                new Indicador { Descricao = "" }
            }
        });

        _modalBlocoAberto = false;
    }
}
