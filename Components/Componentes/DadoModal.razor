@using Microsoft.AspNetCore.Components
@inject IJSRuntime JS

@* ============================================================
   DadoModal - modal de rolagem de dado com cubo 3D (CSS).

   Fluxo:
   1. AbrirAsync() abre o modal; o cubo fica em "repouso" balançando leve.
   2. O jogador clica "Parar".
   3. Busca o resultado no servidor (ObterResultadoServidor) e toca o som.
   4. O cubo ROLA em 3D (várias voltas desacelerando) e PARA com a face
      da frente mostrando o número sorteado (resultado do range inteiro).
   5. O jogador clica "Confirmar" e AoConfirmar é disparado.

   Observação: o cubo é um D6 (forma visual). Durante o giro as faces
   passam rápido (borrão de rotação); ao parar, a face frontal mostra
   exatamente o número sorteado, como a cara final de um dado.
   ============================================================ *@

<div class="dado-overlay" style="@(_aberto ? "" : "display:none;")">
    <div class="dado-modal">

        <header class="dado-modal-header">
            <h3>@TituloModal</h3>
        </header>

        <div class="dado-cena">
            <div class="@ClasseCubo()" style="@EstiloCubo()">
                <div class="face face-front">@_faceFront</div>
                <div class="face face-back">@_faceBack</div>
                <div class="face face-right">@_faceRight</div>
                <div class="face face-left">@_faceLeft</div>
                <div class="face face-top">@_faceTop</div>
                <div class="face face-bottom">@_faceBottom</div>
            </div>
            <div class="dado-sombra @( _estado == EstadoDado.Rolando ? "rolando" : "")"></div>
        </div>

        <div class="dado-status">
            @switch (_estado)
            {
                case EstadoDado.Rolando:
                    <span class="status-texto">Role o dado!</span>
                    break;

                case EstadoDado.Parando:
                    <span class="status-texto">Parando...</span>
                    break;

                case EstadoDado.Revelado:
                    <span class="status-label">Você tirou</span>
                    <span class="status-resultado">@_resultadoServidor</span>
                    break;

                case EstadoDado.Erro:
                    <span class="status-erro">
                        <i class="bi bi-exclamation-triangle"></i>
                        @_mensagemErro
                    </span>
                    break;
            }
        </div>

        <footer class="dado-modal-footer">
            @switch (_estado)
            {
                case EstadoDado.Rolando:
                    <button type="button" class="dado-botao parar" @onclick="PararAsync">
                        <i class="bi bi-hand-index-thumb"></i>
                        Parar
                    </button>
                    break;

                case EstadoDado.Parando:
                    <button type="button" class="dado-botao parar" disabled>
                        <i class="bi bi-hourglass-split"></i>
                        Parando...
                    </button>
                    break;

                case EstadoDado.Revelado:
                    <button type="button" class="dado-botao confirmar" @onclick="ConfirmarAsync">
                        <i class="bi bi-check-lg"></i>
                        Confirmar
                    </button>
                    break;

                case EstadoDado.Erro:
                    <button type="button" class="dado-botao fechar" @onclick="FecharPorErro">
                        <i class="bi bi-x-lg"></i>
                        Fechar
                    </button>
                    break;
            }
        </footer>

    </div>
</div>

<style>
    .dado-overlay {
        position: fixed;
        inset: 0;
        background: rgba(2, 6, 23, .82);
        backdrop-filter: blur(3px);
        display: flex;
        align-items: center;
        justify-content: center;
        z-index: 1100;
        padding: 1rem;
    }

    .dado-modal {
        width: min(92vw, 380px);
        border: 1px solid rgba(96, 165, 250, .22);
        border-radius: 24px;
        background: linear-gradient(160deg, rgba(15,23,42,.98), rgba(2,6,23,.98));
        box-shadow: 0 30px 70px rgba(0,0,0,.55);
        padding: 1.5rem;
        text-align: center;
    }

    .dado-modal-header h3 {
        margin: 0 0 1.25rem;
        color: #e5e7eb;
        font-size: 1.15rem;
    }

    /* ===== Cena 3D ===== */
    .dado-cena {
        --tam: 110px;
        height: calc(var(--tam) + 50px);
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        perspective: 700px;
        margin-bottom: 1rem;
    }

    .cubo {
        position: relative;
        width: var(--tam);
        height: var(--tam);
        transform-style: preserve-3d;
        transition: transform .1s linear;
    }

        /* repouso: balança de leve continuamente */
        .cubo.repouso {
            animation: cuboRepouso 3s ease-in-out infinite;
        }

        /* rolando: giro rápido nos 3 eixos (a parada fina é via transform inline) */
        .cubo.rolando {
            animation: cuboRola .6s linear infinite;
        }

    .face {
        position: absolute;
        width: var(--tam);
        height: var(--tam);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2.6rem;
        font-weight: 900;
        color: #0f172a;
        background: linear-gradient(145deg, #f8fafc, #cbd5e1);
        border: 2px solid rgba(255,255,255,.7);
        border-radius: 18px;
        box-shadow: inset 0 2px 8px rgba(255,255,255,.7), inset 0 -6px 14px rgba(15,23,42,.18);
        font-variant-numeric: tabular-nums;
        backface-visibility: hidden;
    }

    /* posiciona as 6 faces do cubo */
    .face-front {
        transform: rotateY(0deg) translateZ(calc(var(--tam) / 2));
    }

    .face-back {
        transform: rotateY(180deg) translateZ(calc(var(--tam) / 2));
    }

    .face-right {
        transform: rotateY(90deg) translateZ(calc(var(--tam) / 2));
    }

    .face-left {
        transform: rotateY(-90deg) translateZ(calc(var(--tam) / 2));
    }

    .face-top {
        transform: rotateX(90deg) translateZ(calc(var(--tam) / 2));
    }

    .face-bottom {
        transform: rotateX(-90deg) translateZ(calc(var(--tam) / 2));
    }

    .dado-sombra {
        width: 90px;
        height: 16px;
        margin-top: 14px;
        border-radius: 50%;
        background: radial-gradient(ellipse, rgba(0,0,0,.5), transparent 70%);
        filter: blur(2px);
        transition: transform .2s ease;
    }

        .dado-sombra.rolando {
            animation: sombraPulsa .6s ease-in-out infinite;
        }

    @@keyframes cuboRepouso {
        0%, 100% {
            transform: rotateX(-18deg) rotateY(-22deg);
        }

        50% {
            transform: rotateX(-12deg) rotateY(-30deg);
        }
    }

    @@keyframes cuboRola {
        0% {
            transform: rotateX(0deg) rotateY(0deg) rotateZ(0deg);
        }

        100% {
            transform: rotateX(360deg) rotateY(360deg) rotateZ(180deg);
        }
    }

    @@keyframes sombraPulsa {
        0%, 100% {
            transform: scaleX(1);
            opacity: .5;
        }

        50% {
            transform: scaleX(.7);
            opacity: .3;
        }
    }

    .dado-revelado .face {
        background: linear-gradient(145deg, #dcfce7, #86efac);
        box-shadow: inset 0 2px 8px rgba(255,255,255,.7), 0 0 26px rgba(34,197,94,.4);
        color: #0f172a;
    }

    /* ===== Status / botões ===== */
    .dado-status {
        min-height: 56px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        gap: .15rem;
        margin-bottom: 1.1rem;
    }

    .status-texto {
        color: #94a3b8;
        font-weight: 700;
    }

    .status-label {
        color: #94a3b8;
        font-size: .82rem;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .status-resultado {
        color: #86efac;
        font-size: 2rem;
        font-weight: 900;
    }

    .status-erro {
        color: #fca5a5;
        font-weight: 700;
        display: flex;
        align-items: center;
        gap: .4rem;
        font-size: .9rem;
    }

    .dado-modal-footer {
        display: flex;
    }

    .dado-botao {
        flex: 1;
        min-height: 48px;
        border: 0;
        border-radius: 14px;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        gap: .5rem;
        font-weight: 900;
        font-size: 1rem;
        cursor: pointer;
        transition: 150ms ease;
    }

        .dado-botao.parar {
            background: linear-gradient(135deg, #2563eb, #3b82f6);
            color: white;
        }

        .dado-botao.confirmar {
            background: linear-gradient(135deg, #16a34a, #22c55e);
            color: white;
        }

        .dado-botao.fechar {
            background: rgba(148, 163, 184, .2);
            color: #e5e7eb;
        }

        .dado-botao:disabled {
            opacity: .6;
            cursor: not-allowed;
        }
</style>

@code {
    // ---- Parâmetros (mesma API de antes) ----

    [Parameter] public string TituloModal { get; set; } = "Resultado";
    [Parameter] public int MinValor { get; set; } = 1;
    [Parameter] public int MaxValor { get; set; } = 6;
    [Parameter] public List<int> NumerosRestritos { get; set; } = new();
    [Parameter] public Func<Task<int>>? ObterResultadoServidor { get; set; }
    [Parameter] public EventCallback<int> AoConfirmar { get; set; }

    // Modo automático (bot): o dado para sozinho no valor informado,
    // sem botão "Parar" nem "Confirmar". Útil para animar o turno do bot.
    [Parameter] public bool Automatico { get; set; }

    // ---- Estado ----

    private enum EstadoDado { Rolando, Parando, Revelado, Erro }

    private bool _aberto;
    private EstadoDado _estado = EstadoDado.Rolando;

    private int _resultadoServidor;
    private string? _mensagemErro;

    // valores exibidos nas 6 faces
    private string _faceFront = "?";
    private string _faceBack = "?";
    private string _faceRight = "?";
    private string _faceLeft = "?";
    private string _faceTop = "?";
    private string _faceBottom = "?";

    // transform final do cubo (para parar mostrando a frente)
    private string _transformFinal = "";

    // ---- API pública (inalterada) ----

    public async Task AbrirAsync()
    {
        _aberto = true;
        _estado = EstadoDado.Rolando;       // já abre rolando
        _resultadoServidor = 0;
        _mensagemErro = null;
        _transformFinal = "";
        SortearFacesVisuais();
        StateHasChanged();

        // som de rolagem contínua (em loop) enquanto o dado gira
        await TocarSomLoopAsync("dado");
    }

    public void Fechar()
    {
        _aberto = false;
        StateHasChanged();
    }

    // Modo automático (bot): abre, rola, para sozinho no valor e auto-confirma.
    // Não usa ObterResultadoServidor — o valor já vem resolvido pelo roteiro do bot.
    public async Task AbrirAutomaticoAsync(int valor)
    {
        _aberto = true;
        _estado = EstadoDado.Rolando;
        _resultadoServidor = valor;
        _mensagemErro = null;
        _transformFinal = "";
        SortearFacesVisuais();
        StateHasChanged();

        await TocarSomLoopAsync("dado");

        // gira um tempo (como se estivesse rolando)
        await Task.Delay(2000);

        // "solta" o dado
        await PararSomLoopAsync();
        await TocarSomAsync("jogandodado");

        _estado = EstadoDado.Parando;
        StateHasChanged();
        await Task.Delay(700);

        // para no valor
        _faceFront = valor.ToString();
        _transformFinal = "transform: rotateX(-15deg) rotateY(-20deg);";
        _estado = EstadoDado.Revelado;
        StateHasChanged();

        // deixa visível um instante e fecha sozinho
        await Task.Delay(900);
        _aberto = false;
        StateHasChanged();

        if (AoConfirmar.HasDelegate)
            await AoConfirmar.InvokeAsync(valor);
    }

    // ---- Rolagem ----

    private async Task PararAsync()
    {
        if (_estado != EstadoDado.Rolando)
            return;

        // 1. Busca o resultado no servidor.
        int resultado;
        try
        {
            resultado = ObterResultadoServidor is null
                ? SortearVisual()
                : await ObterResultadoServidor.Invoke();
        }
        catch (Exception ex)
        {
            await PararSomLoopAsync();
            _mensagemErro = ex.InnerException?.Message ?? ex.Message;
            _estado = EstadoDado.Erro;
            StateHasChanged();
            return;
        }

        _resultadoServidor = resultado;

        // 2. Para o som de rolagem e toca o som de "soltar o dado".
        await PararSomLoopAsync();
        await TocarSomAsync("jogandodado");

        // 3. Marca como parando (mantém o giro mais um instante e desacelera).
        _estado = EstadoDado.Parando;
        StateHasChanged();

        await Task.Delay(700);

        // 4. Para mostrando o resultado na face da frente.
        _faceFront = resultado.ToString();
        _transformFinal = "transform: rotateX(-15deg) rotateY(-20deg);";
        _estado = EstadoDado.Revelado;
        StateHasChanged();
    }

    private async Task ConfirmarAsync()
    {
        if (_estado != EstadoDado.Revelado)
            return;

        await PararSomLoopAsync();

        var resultado = _resultadoServidor;
        _aberto = false;
        StateHasChanged();

        if (AoConfirmar.HasDelegate)
            await AoConfirmar.InvokeAsync(resultado);
    }

    private async void FecharPorErro()
    {
        await PararSomLoopAsync();
        _aberto = false;
        _mensagemErro = null;
        StateHasChanged();
    }

    // ---- Visual ----

    private string ClasseCubo()
    {
        switch (_estado)
        {
            case EstadoDado.Rolando: return "cubo rolando";
            case EstadoDado.Parando: return "cubo rolando";
            case EstadoDado.Revelado: return "cubo dado-revelado";
            default: return "cubo";
        }
    }

    private string EstiloCubo()
    {
        // No estado revelado, aplica o transform final fixo (sem animação).
        return _estado == EstadoDado.Revelado ? _transformFinal : "";
    }

    // Sorteia 6 números do range para as faces (decorativo).
    private void SortearFacesVisuais()
    {
        _faceFront = SortearVisual().ToString();
        _faceBack = SortearVisual().ToString();
        _faceRight = SortearVisual().ToString();
        _faceLeft = SortearVisual().ToString();
        _faceTop = SortearVisual().ToString();
        _faceBottom = SortearVisual().ToString();
    }

    private int SortearVisual()
    {
        var min = MinValor;
        var max = MaxValor;
        if (max < min) max = min;

        var validos = new List<int>();
        for (var v = min; v <= max; v++)
            if (!NumerosRestritos.Contains(v))
                validos.Add(v);

        if (validos.Count == 0)
            for (var v = min; v <= max; v++)
                validos.Add(v);

        return validos[Random.Shared.Next(validos.Count)];
    }

    private async Task TocarSomAsync(string nome)
    {
        try
        {
            await JS.InvokeVoidAsync("jogoAudio.tocar", nome);
        }
        catch
        {
            /* som é opcional; ignora se o helper não estiver carregado */
        }
    }

    private async Task TocarSomLoopAsync(string nome)
    {
        try
        {
            await JS.InvokeVoidAsync("jogoAudio.tocarLoop", nome);
        }
        catch
        {
            /* som opcional */
        }
    }

    private async Task PararSomLoopAsync()
    {
        try
        {
            await JS.InvokeVoidAsync("jogoAudio.pararLoop");
        }
        catch
        {
            /* som opcional */
        }
    }
}
