    [Inject]
    private IJSRuntime JS { get; set; } = default!;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (!firstRender || _inicializado)
            return;

        _inicializado = true;

        try
        {
            _identificadorJogador = await BrowserIdentificacaoService.ObterOuCriarIdentificadorAsync();

            var nomeSalvo = await BrowserIdentificacaoService.ObterNomeAsync();
            _nomeJogador = nomeSalvo ?? string.Empty;

            await CarregarAsync();
        }
        catch (Exception ex)
        {
            _erro = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _carregando = false;
            StateHasChanged();
        }
    }

    private async Task CarregarAsync()
    {
        _erroAcao = null;

        _lobby = await PartidaService.ObterLobbyAsync(
            IdPartida,
            _identificadorJogador);

        if (_lobby == null)
        {
            _erro = "Partida nao encontrada.";
            return;
        }

        _perfisBot = await PartidaService.ListarPerfisBotAsync();

        if (_idPerfilBotSelecionado <= 0 && _perfisBot.Count > 0)
            _idPerfilBotSelecionado = _perfisBot[0].IdPerfilBot;

        if (string.IsNullOrWhiteSpace(_nomeJogador) && !string.IsNullOrWhiteSpace(_lobby.UsuarioAtualNome))
            _nomeJogador = _lobby.UsuarioAtualNome;

        var jogadorAtual = _lobby.Jogadores
            .FirstOrDefault(x => x.IdPartidaJogador == _lobby.UsuarioAtualIdPartidaJogador);

        if (jogadorAtual != null)
        {
            _corAtual = jogadorAtual.CorHex;
            _avatarAtual = jogadorAtual.UrlAvatar;
        }
    }

    private async Task SalvarNomeAsync()
    {
        if (_lobby == null || string.IsNullOrWhiteSpace(_identificadorJogador))
            return;

        await ExecutarAcaoAsync(async () =>
        {
            await BrowserIdentificacaoService.SalvarNomeAsync(_nomeJogador);

            await PartidaService.AtualizarNomeJogadorAsync(
                _lobby.IdPartida,
                _identificadorJogador,
                _nomeJogador);

            // Recarrega o lobby passando o identificador do usuário atual.
            // O retorno de AtualizarNomeJogadorAsync vem "anônimo" (sem
            // UsuarioAtual...), então não o usamos diretamente.
            await CarregarAsync();

            _mensagem = "Nome salvo com sucesso.";
        });
    }

    private async Task AdicionarBotAsync()
    {
        if (_lobby == null)
            return;

        await ExecutarAcaoAsync(async () =>
        {
            await PartidaService.AdicionarBotAsync(new AdicionarBotDTO
            {
                IdPartida = _lobby.IdPartida,
                IdPerfilBot = _idPerfilBotSelecionado,
                NomeBot = _nomeBot
            });

            _nomeBot = null;
            _mensagem = "Bot adicionado.";
            await CarregarAsync();
        });
    }

