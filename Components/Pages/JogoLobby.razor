    // ---- Fila sequencial (Local Multiplayer) ----

    private bool ExistemHumanosPendentes()
        => QtdHumanosPendentes > 0;

    private int QtdHumanosPendentes =>
        _lobby?.Jogadores.Count(j =>
            !j.EhBot &&
            j.ParticipaDesempateOrdem &&
            !j.OrdemTurno.HasValue) ?? 0;

    private async Task IniciarFilaRolagemAsync()
    {
        if (_lobby == null)
            return;

        // Monta a fila com todos os humanos que ainda precisam rolar (ordem de jogador).
        var pendentes = _lobby.Jogadores
            .Where(j => !j.EhBot && j.ParticipaDesempateOrdem && !j.OrdemTurno.HasValue)
            .OrderBy(j => j.OrdemJogador)
            .Select(j => j.IdPartidaJogador)
            .ToList();

        if (pendentes.Count == 0)
            return;

        _filaRolagem.Clear();
        foreach (var id in pendentes)
            _filaRolagem.Enqueue(id);

        _conduzindoFila = true;

        await AbrirProximoDaFilaAsync();
    }

    private async Task AbrirProximoDaFilaAsync()
    {
        if (_filaRolagem.Count == 0)
        {
            _conduzindoFila = false;
            return;
        }

        _idJogadorRolando = _filaRolagem.Dequeue();
        _tituloDado = MontarTituloDado(_idJogadorRolando);

        if (_dadoModal is not null)
            await _dadoModal.AbrirAsync();
    }

    private string MontarTituloDado(int idPartidaJogador)
