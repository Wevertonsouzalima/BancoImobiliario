    {
        // Atualiza o lobby (o servidor ja rolou bots e tentou resolver a ordem).
        await CarregarAsync();

        if (_conduzindoFila)
        {
            // Se a fila atual esvaziou mas ainda ha humanos pendentes
            // (ex.: empate gerou nova rodada), monta a proxima fila.
            if (_filaRolagem.Count == 0 && QtdHumanosPendentes > 0)
            {
                var proximos = _lobby!.Jogadores
                    .Where(j => !j.EhBot && j.ParticipaDesempateOrdem && !j.OrdemTurno.HasValue)
                    .OrderBy(j => j.OrdemJogador)
                    .Select(j => j.IdPartidaJogador)
                    .ToList();

                foreach (var id in proximos)
                    _filaRolagem.Enqueue(id);
            }

            if (_filaRolagem.Count > 0)
            {
                await AbrirProximoDaFilaAsync();
                return;
            }

            // Fila encerrada e ninguem mais pendente: ordem definida.
            _conduzindoFila = false;
            _mensagem = "Ordem definida.";
        }
        else
        {
            _mensagem = $"Voce tirou {valor}.";
        }

        StateHasChanged();
    }

    #endregion

    #region Aparencia

    private string? _corAtual;
    private string? _avatarAtual;

    private bool _modalAparenciaAberto;
    private bool _salvandoAparencia;
    private string? _erroModal;

    private string? _corModal;
    private string? _avatarPreviewModal;
    private string _nomeImagem = string.Empty;
    private IBrowserFile? _arquivoSelecionado;

    private const long TamanhoMaximoUploadBytes = 5 * 1024 * 1024;

    private readonly List<string> _coresDisponiveis = new()
    {
        "#ef4444", "#f97316", "#f59e0b", "#eab308",
        "#84cc16", "#22c55e", "#10b981", "#14b8a6",
        "#06b6d4", "#0ea5e9", "#3b82f6", "#6366f1",
        "#8b5cf6", "#a855f7", "#d946ef", "#ec4899"
    };

    private void AbrirModalAparencia()
    {
        _corModal = _corAtual;
        _avatarPreviewModal = _avatarAtual;
        _arquivoSelecionado = null;
        _nomeImagem = string.Empty;
        _erroModal = null;
        _modalAparenciaAberto = true;
    }

    private void FecharModalAparencia()
    {
        if (_salvandoAparencia)
            return;

        _modalAparenciaAberto = false;
        _arquivoSelecionado = null;
        _erroModal = null;
    }

    private void OnArquivoSelecionado(InputFileChangeEventArgs e)
    {
        _erroModal = null;

        var arquivo = e.File;

        if (arquivo is null)
            return;

        if (arquivo.Size > TamanhoMaximoUploadBytes)
        {
            _erroModal = "A imagem excede o tamanho maximo de 5 MB.";
            _arquivoSelecionado = null;
            return;
        }

        _arquivoSelecionado = arquivo;

        if (string.IsNullOrWhiteSpace(_nomeImagem))
            _nomeImagem = Path.GetFileNameWithoutExtension(arquivo.Name);
    }

    private async Task SalvarAparenciaAsync()
    {
        if (_lobby == null || string.IsNullOrWhiteSpace(_identificadorJogador))
            return;

        _salvandoAparencia = true;
        _erroModal = null;

        try
        {
            var urlAvatar = _avatarPreviewModal;

            if (_arquivoSelecionado is not null)
            {
                urlAvatar = await AvatarService.SalvarUploadAsync(
                    _arquivoSelecionado,
                    _nomeImagem);
            }

            await PartidaService.AtualizarAparenciaJogadorAsync(
                _lobby.IdPartida,
                _identificadorJogador,
                _corModal,
                urlAvatar);

            _corAtual = _corModal;
            _avatarAtual = urlAvatar;

            _modalAparenciaAberto = false;
            _arquivoSelecionado = null;

            // Recarrega o lobby com o identificador do usuário atual,
            // já que o retorno do método vem sem os dados de UsuarioAtual.
            await CarregarAsync();

            _mensagem = "Aparencia atualizada.";
        }
        catch (Exception ex)
        {
            _erroModal = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _salvandoAparencia = false;
        }
    }

    private string EstiloAvatarPreview()
    {
        return string.IsNullOrWhiteSpace(_corAtual)
            ? string.Empty
            : $"border-color:{_corAtual};";
    }

    private string EstiloAvatarModal()
    {
        return string.IsNullOrWhiteSpace(_corModal)
            ? string.Empty
            : $"border-color:{_corModal};";
    }

    #endregion
}
