        {
            if (_modoEdicaoJogador)
            {
                await PartidaService.AtualizarJogadorLocalAsync(
                    _lobby.IdPartida,
                    _idJogadorEditando,
                    _nomeJogadorModal,
                    _corJogadorModal);

                _mensagem = "Jogador atualizado.";
