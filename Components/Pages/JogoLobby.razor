            else
            {
                await PartidaService.AdicionarJogadorLocalAsync(new AdicionarJogadorLocalDTO
                {
                    IdPartida = _lobby.IdPartida,
                    Nome = _nomeJogadorModal,
                    CorHex = _corJogadorModal
                });

                _mensagem = "Jogador adicionado.";
            }

            _modalJogadorAberto = false;
            await CarregarAsync();
        }
        catch (Exception ex)
        {
            _erroJogadorModal = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _salvandoJogador = false;
