    // ---- Fluxo individual (usado fora do Local Multiplayer ou clique avulso) ----

    private async Task AbrirDadoAsync(int idPartidaJogador)
    {
        _conduzindoFila = false;
        _idJogadorRolando = idPartidaJogador;
