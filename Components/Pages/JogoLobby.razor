@page "/jogo/lobby/{IdPartida:int}"

@using BancoImobiliario.Components.Componentes
@using BancoImobiliario.Models.DTOs.Jogo
@using BancoImobiliario.Models.Enums
@using BancoImobiliario.Services
@using BancoImobiliario.Services.Jogador

@using Microsoft.AspNetCore.Components.Forms

@inject PartidaService PartidaService
@inject BrowserIdentificacaoService BrowserIdentificacaoService
@inject AvatarService AvatarService
@inject NavigationManager NavigationManager

<PageTitle>Lobby da Partida</PageTitle>

<div class="lobby-page">

    @if (_carregando)
    {
        <div class="lobby-loading">
            <i class="bi bi-hourglass-split"></i>
            <span>Carregando lobby...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_erro))
    {
        <div class="lobby-alert error">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@_erro</span>
        </div>
    }
    else if (_lobby == null)
    {
        <div class="lobby-alert error">
            <i class="bi bi-exclamation-triangle"></i>
            <span>Lobby nao encontrado.</span>
        </div>
    }
    else
    {
        <section class="lobby-hero">
            <div>
                <span class="lobby-eyebrow">Aguardando jogadores</span>
                <h1>Lobby da Partida</h1>
                <p>Defina jogadores, bots e a ordem de turno antes de iniciar a partida.</p>
            </div>

            <div class="lobby-code-card">
                <span>Codigo da sala</span>
                <strong>@_lobby.CodigoSala</strong>
                <button type="button" @onclick="CopiarCodigoAsync">
                    <i class="bi bi-copy"></i>
                    Copiar
                </button>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_mensagem))
        {
            <div class="lobby-alert success">
                <i class="bi bi-check-circle"></i>
                <span>@_mensagem</span>
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_erroAcao))
        {
            <div class="lobby-alert error">
                <i class="bi bi-exclamation-triangle"></i>
                <span>@_erroAcao</span>
            </div>
        }

        <section class="lobby-shell">

            <div class="lobby-status-bar">
                <div class="status-item">
                    <span>Status</span>
                    <strong>@_lobby.StatusPartidaDescricao</strong>
                </div>

                <div class="status-item">
                    <span>Tipo</span>
                    <strong>@_lobby.TipoJogoDescricao</strong>
                </div>

                <div class="status-item">
                    <span>Jogadores</span>
                    <strong>@_lobby.QtdJogadoresAtivos / @_lobby.QtdMaxJogadores</strong>
                </div>

                <div class="status-item">
                    <span>Host</span>
                    <strong>@(_lobby.HostNome ?? "-")</strong>
                </div>
            </div>

            <div class="lobby-grid">

                <section class="lobby-card players-card">
                    <div class="card-header">
                        <div>
                            <h2>Jogadores</h2>
                            <p>Participantes humanos e bots da sala.</p>
                        </div>

                        @if (_lobby.UsuarioAtualEhHost)
                        {
                            <span class="host-pill">Voce e o host</span>
                        }
                    </div>

                    @if (!_lobby.UsuarioAtualEstaNaSala)
                    {
                        <div class="lobby-alert warning compact">
                            <i class="bi bi-person-exclamation"></i>
                            <span>Este navegador ainda nao esta identificado como jogador desta sala.</span>
                        </div>
                    }

                    <div class="player-list">
                        @foreach (var jogador in _lobby.Jogadores)
                        {
                            <article class="@ClasseJogador(jogador)">
                                <div class="player-avatar" style="@EstiloAvatar(jogador)">
                                    @if (!string.IsNullOrWhiteSpace(jogador.UrlAvatar))
                                    {
                                        <img src="@jogador.UrlAvatar" alt="@jogador.NomeJogador" />
                                    }
                                    else
                                    {
                                        @ObterIniciais(jogador.NomeJogador)
                                    }
                                </div>

                                <div class="player-main">
                                    <div class="player-title">
                                        <strong>@jogador.NomeJogador</strong>

                                        @if (jogador.EhHost)
                                        {
                                            <span class="mini-pill host">Host</span>
                                        }

                                        @if (jogador.EhBot)
                                        {
                                            <span class="mini-pill bot">Bot</span>
                                        }
                                        else
                                        {
                                            <span class="mini-pill human">Humano</span>
                                        }
                                    </div>

                                    <div class="player-meta">
                                        <span>@jogador.StatusJogadorDescricao</span>

                                        @if (!string.IsNullOrWhiteSpace(jogador.NomePerfilBot))
                                        {
                                            <span>- @jogador.NomePerfilBot</span>
                                        }

                                        @if (!string.IsNullOrWhiteSpace(jogador.DificuldadeBotDescricao))
                                        {
                                            <span>- @jogador.DificuldadeBotDescricao</span>
                                        }
                                    </div>
                                </div>

                                <div class="player-order">
                                    @if (jogador.OrdemTurno.HasValue)
                                    {
                                        <span class="order-number">#@jogador.OrdemTurno</span>
                                    }
                                    else if (jogador.ParticipaDesempateOrdem)
                                    {
                                        <span class="order-pending">Rolar</span>
                                    }
                                    else
                                    {
                                        <span class="order-muted">-</span>
                                    }

                                    @if (jogador.UltimoResultadoOrdem.HasValue)
                                    {
                                        <small>Dado: @jogador.UltimoResultadoOrdem</small>
                                    }
                                </div>

                                <div class="player-actions">
                                    @if (jogador.PodeRolarDadoOrdem
                                        && _lobby.UsuarioAtualIdPartidaJogador == jogador.IdPartidaJogador
                                        && _lobby.TipoJogo != (int)TipoJogoConfiguracao.LocalMultiplayer)
                                    {
                                        <button type="button"
                                                class="small-action primary"
                                                @onclick="() => AbrirDadoAsync(jogador.IdPartidaJogador)"
                                                disabled="@(_processando)">
                                            <i class="bi bi-dice-5"></i>
                                            Rolar dado
                                        </button>
                                    }

                                    @if (_lobby.UsuarioAtualEhHost && !jogador.EhHost && !jogador.EhBot
                                         && _lobby.TipoJogo == (int)TipoJogoConfiguracao.LocalMultiplayer
                                         && _lobby.IdStatusPartida == (int)StatusPartida.Lobby)
                                    {
                                        <button type="button"
                                                class="small-action neutro"
                                                @onclick="() => AbrirModalEditarJogador(jogador)"
                                                disabled="@(_processando)">
                                            <i class="bi bi-pencil"></i>
                                        </button>
                                    }

                                    @if (_lobby.UsuarioAtualEhHost && !jogador.EhHost && _lobby.IdStatusPartida == (int)StatusPartida.Lobby)
                                    {
                                        <button type="button"
                                                class="small-action danger"
                                                @onclick="() => RemoverJogadorAsync(jogador.IdPartidaJogador)"
                                                disabled="@(_processando)">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    }
                                </div>
                            </article>
                        }
                    </div>
                </section>

                <aside class="lobby-side">

                    <section class="lobby-card">
                        <div class="card-header">
                            <div>
                                <h2>Seu jogador</h2>
                                <p>Nome usado para identificar voce na partida.</p>
                            </div>
                        </div>

                        <div class="field">
                            <label>Nome</label>
                            <input class="lobby-input"
                                   @bind="_nomeJogador"
                                   @bind:event="oninput"
                                   maxlength="120"
                                   placeholder="Informe seu nome" />
                        </div>

                        <button type="button"
                                class="lobby-button secondary full"
                                @onclick="SalvarNomeAsync"
                                disabled="@(_processando || !_lobby.UsuarioAtualEstaNaSala)">
                            <i class="bi bi-save"></i>
                            Salvar nome
                        </button>
                    </section>

                    <section class="lobby-card">
                        <div class="card-header">
                            <div>
                                <h2>Aparencia</h2>
                                <p>Escolha uma cor e uma foto para se destacar no tabuleiro.</p>
                            </div>
                        </div>

                        <div class="aparencia-preview">
                            <div class="aparencia-avatar" style="@EstiloAvatarPreview()">
                                @if (!string.IsNullOrWhiteSpace(_avatarAtual))
                                {
                                    <img src="@_avatarAtual" alt="Avatar" />
                                }
                                else
                                {
                                    @ObterIniciais(_nomeJogador)
                                }
                            </div>
                            <div class="aparencia-info">
                                <strong>@(_nomeJogador is { Length: > 0 } ? _nomeJogador : "Seu avatar")</strong>
                                <small>@(string.IsNullOrWhiteSpace(_corAtual) ? "Sem cor definida" : _corAtual)</small>
                            </div>
                        </div>

                        <button type="button"
                                class="lobby-button secondary full"
                                @onclick="AbrirModalAparencia"
                                disabled="@(_processando || !_lobby.UsuarioAtualEstaNaSala)">
                            <i class="bi bi-palette"></i>
                            Personalizar aparencia
                        </button>
                    </section>

                    @if (_lobby.UsuarioAtualEhHost && _lobby.TipoJogo == (int)TipoJogoConfiguracao.LocalMultiplayer)
                    {
                        <section class="lobby-card">
                            <div class="card-header">
                                <div>
                                    <h2>Jogadores locais</h2>
                                    <p>Inclua outros jogadores humanos neste dispositivo.</p>
                                </div>
                            </div>

                            <button type="button"
                                    class="lobby-button secondary full"
                                    @onclick="AbrirModalAdicionarJogador"
                                    disabled="@(_processando || !_lobby.PodeAdicionarJogadorOuBot)">
                                <i class="bi bi-person-plus"></i>
                                Adicionar jogador
                            </button>
                        </section>
                    }

                    @if (_lobby.UsuarioAtualEhHost)
                    {
                        <section class="lobby-card">
                            <div class="card-header">
                                <div>
                                    <h2>Adicionar bot</h2>
                                    <p>Complete a sala com jogadores automaticos.</p>
                                </div>
                            </div>

                            <div class="field">
                                <label>Perfil do bot</label>
                                <select class="lobby-input" @bind="_idPerfilBotSelecionado">
                                    @foreach (var perfil in _perfisBot)
                                    {
                                        <option value="@perfil.IdPerfilBot">@perfil.Nome - @perfil.DificuldadePadraoDescricao</option>
                                    }
                                </select>
                            </div>

                            <div class="field">
                                <label>Nome opcional</label>
                                <input class="lobby-input"
                                       @bind="_nomeBot"
                                       @bind:event="oninput"
                                       maxlength="120"
                                       placeholder="Ex: Bot Azul" />
                            </div>

                            <button type="button"
                                    class="lobby-button secondary full"
                                    @onclick="AdicionarBotAsync"
                                    disabled="@(_processando || !_lobby.PodeAdicionarJogadorOuBot || _perfisBot.Count == 0)">
                                <i class="bi bi-robot"></i>
                                Adicionar bot
                            </button>
                        </section>
                    }

                    <section class="lobby-card">
                        <div class="card-header">
                            <div>
                                <h2>Definicao da ordem</h2>
                                <p>Maior resultado no dado joga primeiro. Empates rolam novamente.</p>
                            </div>
                        </div>

                        @if (_lobby.IdStatusPartida == (int)StatusPartida.Lobby)
                        {
                            <p class="help-text">
                                O host deve iniciar a definicao da ordem quando todos os jogadores estiverem na sala.
                            </p>
                        }
                        else if (_lobby.IdStatusPartida == (int)StatusPartida.DefinindoOrdem)
                        {
                            <p class="help-text">
                                Jogadores humanos envolvidos devem clicar em <strong>Rolar dado</strong>. Bots rolam automaticamente.
                            </p>
                        }
                        else if (_lobby.IdStatusPartida == (int)StatusPartida.OrdemDefinida)
                        {
                            <p class="help-text success-text">
                                Ordem definida. O host ja pode iniciar a partida.
                            </p>
                        }

                        @if (_lobby.UsuarioAtualEhHost)
                        {
                            <div class="host-actions">
                                <button type="button"
                                        class="lobby-button secondary full"
                                        @onclick="IniciarDefinicaoOrdemAsync"
                                        disabled="@(_processando || !_lobby.PodeIniciarDefinicaoOrdem)">
                                    <i class="bi bi-dice-6"></i>
                                    Definir ordem
                                </button>

                                @* Local Multiplayer: o host conduz a fila de rolagem de todos os humanos locais. *@
                                @if (_lobby.TipoJogo == (int)TipoJogoConfiguracao.LocalMultiplayer
                                     && _lobby.IdStatusPartida == (int)StatusPartida.DefinindoOrdem
                                     && ExistemHumanosPendentes())
                                {
                                    <button type="button"
                                            class="lobby-button secondary full"
                                            @onclick="IniciarFilaRolagemAsync"
                                            disabled="@(_processando)">
                                        <i class="bi bi-dice-5"></i>
                                        Rolar ordem (@QtdHumanosPendentes jogador@(QtdHumanosPendentes == 1 ? "" : "es"))
                                    </button>
                                }

                                <button type="button"
                                        class="lobby-button primary full"
                                        @onclick="IniciarPartidaAsync"
                                        disabled="@(_processando || !_lobby.PodeIniciarPartida)">
                                    <i class="bi bi-play-fill"></i>
                                    Iniciar partida
                                </button>
                            </div>
                        }
                    </section>

                </aside>
            </div>
        </section>

        @* Modal de dado. Min/Max vem da configuracao real da partida. *@
        <DadoModal @ref="_dadoModal"
                   TituloModal="@_tituloDado"
                   MinValor="_lobby.ValMinDado"
                   MaxValor="_lobby.ValMaxDado"
                   NumerosRestritos="_numerosRestritos"
                   ObterResultadoServidor="RolarNoServidorAsync"
                   AoConfirmar="OnDadoConfirmado" />

        @* Modal de personalizacao de aparencia (cor + upload de foto) *@
        @if (_modalAparenciaAberto)
        {
            <div class="aparencia-overlay" @onclick="FecharModalAparencia">
                <div class="aparencia-modal" @onclick:stopPropagation="true">

                    <header class="aparencia-modal-header">
                        <h3>Personalizar aparencia</h3>
                        <button type="button" class="aparencia-fechar" @onclick="FecharModalAparencia">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </header>

                    <div class="aparencia-modal-body">

                        <div class="aparencia-preview grande">
                            <div class="aparencia-avatar" style="@EstiloAvatarModal()">
                                @if (!string.IsNullOrWhiteSpace(_avatarPreviewModal))
                                {
                                    <img src="@_avatarPreviewModal" alt="Avatar" />
                                }
                                else
                                {
                                    @ObterIniciais(_nomeJogador)
                                }
                            </div>
                        </div>

                        <div class="aparencia-section">
                            <label>Cor do jogador</label>
                            <div class="cor-grid">
                                @foreach (var cor in _coresDisponiveis)
                                {
                                    var corLocal = cor;
                                    <button type="button"
                                            class="@(_corModal == corLocal ? "cor-chip ativo" : "cor-chip")"
                                            style="background-color:@corLocal"
                                            @onclick="() => _corModal = corLocal">
                                        @if (_corModal == corLocal)
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="aparencia-section">
                            <label>Foto do jogador</label>

                            <div class="field">
                                <input class="lobby-input"
                                       @bind="_nomeImagem"
                                       @bind:event="oninput"
                                       maxlength="60"
                                       placeholder="Nome para a imagem (ex: meu-avatar)" />
                            </div>

                            <label class="upload-zone">
                                <InputFile OnChange="OnArquivoSelecionado" accept="image/*" />
                                <i class="bi bi-cloud-arrow-up"></i>
                                <span>
                                    @(_arquivoSelecionado is null
                                        ? "Clique para escolher uma imagem"
                                        : _arquivoSelecionado.Name)
                                </span>
                                <small>JPG, PNG, WEBP ou GIF - ate 5 MB</small>
                            </label>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_erroModal))
                        {
                            <div class="lobby-alert error compact">
                                <i class="bi bi-exclamation-triangle"></i>
                                <span>@_erroModal</span>
                            </div>
                        }

                    </div>

                    <footer class="aparencia-modal-footer">
                        <button type="button"
                                class="lobby-button secondary"
                                @onclick="FecharModalAparencia"
                                disabled="@(_salvandoAparencia)">
                            Cancelar
                        </button>
                        <button type="button"
                                class="lobby-button primary"
                                @onclick="SalvarAparenciaAsync"
                                disabled="@(_salvandoAparencia)">
                            @if (_salvandoAparencia)
                            {
                                <i class="bi bi-hourglass-split"></i>
                                <span>Salvando...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg"></i>
                                <span>Salvar</span>
                            }
                        </button>
                    </footer>

                </div>
            </div>
        }

        @* Modal de jogador local (adicionar/editar): nome + cor *@
        @if (_modalJogadorAberto)
        {
            <div class="aparencia-overlay" @onclick="FecharModalJogador">
                <div class="aparencia-modal" @onclick:stopPropagation="true">

                    <header class="aparencia-modal-header">
                        <h3>@(_modoEdicaoJogador ? "Editar jogador" : "Adicionar jogador")</h3>
                        <button type="button" class="aparencia-fechar" @onclick="FecharModalJogador">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </header>

                    <div class="aparencia-modal-body">

                        <div class="aparencia-preview grande">
                            <div class="aparencia-avatar" style="@EstiloAvatarJogadorModal()">
                                @ObterIniciais(_nomeJogadorModal)
                            </div>
                        </div>

                        <div class="aparencia-section">
                            <label>Nome do jogador</label>
                            <div class="field">
                                <input class="lobby-input"
                                       @bind="_nomeJogadorModal"
                                       @bind:event="oninput"
                                       maxlength="120"
                                       placeholder="Ex: Jogador 2" />
                            </div>
                        </div>

                        <div class="aparencia-section">
                            <label>Cor do jogador</label>
                            <div class="cor-grid">
                                @foreach (var cor in _coresDisponiveis)
                                {
                                    var corLocal = cor;
                                    <button type="button"
                                            class="@(_corJogadorModal == corLocal ? "cor-chip ativo" : "cor-chip")"
                                            style="background-color:@corLocal"
                                            @onclick="() => _corJogadorModal = corLocal">
                                        @if (_corJogadorModal == corLocal)
                                        {
                                            <i class="bi bi-check-lg"></i>
                                        }
                                    </button>
                                }
                            </div>
                        </div>

                        @if (!string.IsNullOrWhiteSpace(_erroJogadorModal))
                        {
                            <div class="lobby-alert error compact">
                                <i class="bi bi-exclamation-triangle"></i>
                                <span>@_erroJogadorModal</span>
                            </div>
                        }

                    </div>

                    <footer class="aparencia-modal-footer">
                        <button type="button"
                                class="lobby-button secondary"
                                @onclick="FecharModalJogador"
                                disabled="@(_salvandoJogador)">
                            Cancelar
                        </button>
                        <button type="button"
                                class="lobby-button primary"
                                @onclick="SalvarJogadorModalAsync"
                                disabled="@(_salvandoJogador)">
                            @if (_salvandoJogador)
                            {
                                <i class="bi bi-hourglass-split"></i>
                                <span>Salvando...</span>
                            }
                            else
                            {
                                <i class="bi bi-check-lg"></i>
                                <span>@(_modoEdicaoJogador ? "Salvar" : "Adicionar")</span>
                            }
                        </button>
                    </footer>

                </div>
            </div>
        }
    }
</div>

<style>
    .lobby-page {
        max-width: 1280px;
        margin: 0 auto;
        color: inherit;
    }

    .lobby-hero {
        display: flex;
        justify-content: space-between;
        gap: 1.5rem;
        align-items: stretch;
        margin-bottom: 1.4rem;
    }

    .lobby-eyebrow {
        display: inline-flex;
        margin-bottom: .45rem;
        color: #60a5fa;
        font-size: .78rem;
        font-weight: 800;
        letter-spacing: .09em;
        text-transform: uppercase;
    }

    .lobby-hero h1 {
        margin: 0;
        font-size: clamp(2rem, 3vw, 3rem);
        line-height: 1.05;
        letter-spacing: -.04em;
    }

    .lobby-hero p {
        margin: .75rem 0 0;
        color: #94a3b8;
        max-width: 680px;
    }

    .lobby-code-card {
        min-width: 270px;
        padding: 1.1rem 1.25rem;
        border: 1px solid rgba(96, 165, 250, .22);
        border-radius: 20px;
        background: linear-gradient(135deg, rgba(37, 99, 235, .22), rgba(15, 23, 42, .9));
        box-shadow: 0 20px 50px rgba(0,0,0,.22);
    }

        .lobby-code-card span {
            display: block;
            color: #93c5fd;
            font-size: .82rem;
            margin-bottom: .35rem;
        }

        .lobby-code-card strong {
            display: block;
            color: #e5e7eb;
            font-size: 1.5rem;
            margin-bottom: .75rem;
        }

        .lobby-code-card button {
            border: 1px solid rgba(96, 165, 250, .32);
            border-radius: 12px;
            background: rgba(37, 99, 235, .18);
            color: #bfdbfe;
            padding: .45rem .7rem;
            font-weight: 800;
            cursor: pointer;
        }

    .lobby-shell {
        border: 1px solid rgba(148, 163, 184, .16);
        border-radius: 26px;
        background: rgba(15, 23, 42, .62);
        box-shadow: 0 26px 70px rgba(0,0,0,.28);
        overflow: hidden;
    }

    .lobby-status-bar {
        display: grid;
        grid-template-columns: repeat(4, minmax(0, 1fr));
        gap: 1px;
        background: rgba(148, 163, 184, .12);
        border-bottom: 1px solid rgba(148, 163, 184, .14);
    }

    .status-item {
        padding: 1rem;
        background: rgba(2, 6, 23, .32);
    }

        .status-item span {
            display: block;
            color: #94a3b8;
            font-size: .78rem;
            margin-bottom: .25rem;
        }

        .status-item strong {
            color: #e5e7eb;
        }

    .lobby-grid {
        display: grid;
        grid-template-columns: minmax(0, 1fr) 340px;
        gap: 1rem;
        padding: 1rem;
    }

    .lobby-card {
        border: 1px solid rgba(148, 163, 184, .15);
        border-radius: 20px;
        background: rgba(2, 6, 23, .32);
        padding: 1rem;
    }

    .lobby-side {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .card-header {
        display: flex;
        justify-content: space-between;
        gap: 1rem;
        align-items: flex-start;
        margin-bottom: 1rem;
    }

        .card-header h2 {
            margin: 0;
            font-size: 1.05rem;
        }

        .card-header p,
        .help-text {
            margin: .25rem 0 0;
            color: #94a3b8;
            font-size: .88rem;
        }

    .success-text {
        color: #86efac;
