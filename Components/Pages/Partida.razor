    private async Task ConfirmarTrocaAsync()
    {
        if (_jogadorAtual is null || _trocaAlvo is null) return;

        var alvo = _trocaAlvo;
        _modalTrocaConfirmarAberto = false;
        _modalTrocaEscolhaAberto = false;
        _trocaAlvo = null;

        try
        {
            var novaPos = await AcaoCasaService.TrocarDeCasaAsync(
                IdPartida, _jogadorAtual.IdPartidaJogador, alvo.IdPartidaJogador);

            _msgSimulacao = $"Você trocou de casa com {alvo.NomeJogador} (agora na casa {novaPos}).";
            await TocarSomEfeitoAsync("neutro");
            await RecarregarAsync();

            // Se a casa de efeito manda resolver o destino, resolve a nova casa.
            if (_efeitoAplicaCasaApos)
            {
                var resCasa = await AcaoCasaService.AoCairNaCasaAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
                _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(
                    IdPartida, novaPos, _jogadorAtual.IdPartidaJogador, _debug);
                await RecarregarAsync();
                await AbrirModalPosCasaAsync();
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }

        StateHasChanged();
    }

    // ===== IMPOSTO =====
    private async Task ResolverImpostoAsync()
    {
        if (_jogadorAtual is null) return;

        try
        {
            var r = await AcaoCasaService.ResolverImpostoAsync(IdPartida, _jogadorAtual.IdPartidaJogador);

            // imune: não paga, mostra modal de imunidade
            if (r.Imune)
            {
                await RecarregarAsync();
                await AbrirModalImunidadeAsync("Imune a impostos!", r.Frase ?? "Você não pagou o imposto!", "bi-shield-check");
                return;
            }

            _impostoNome = r.Nome;
            _impostoFrase = r.Frase ?? "";
            _impostoImagem = r.Imagem;
            _fatorImposto = r.FatorMultiplicador;

            await TocarSomAsync("impostos");

            await RecarregarAsync();

            if (r.DependeDado)
            {
                // abre o dado para definir o valor (dado x fator)
                _rolandoDadoImposto = true;
                _tituloDado = "Role para definir o imposto!";
                // NÃO abre o modal de imposto agora — só o DadoModal, para não sobrepor.
                StateHasChanged();

                if (_dadoModal is not null)
                    await _dadoModal.AbrirAsync();
            }
            else
            {
                _impostoValor = r.Valor;
                _modalImpostoAberto = true;
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
            StateHasChanged();
        }
    }

    private async Task ConfirmarPagamentoImpostoAsync()
    {
        _modalImpostoAberto = false;

        if (_jogadorAtual is null) return;

        try
        {
            var r = await AcaoCasaService.PagarImpostoAsync(IdPartida, _jogadorAtual.IdPartidaJogador, _impostoValor);

            if (r.Eliminado)
            {
                _msgSimulacao = $"Sem saldo para o imposto de R$ {_impostoValor:N2}. Jogador eliminado.";
                await TocarSomAsync("eliminado");
            }
            else if (r.PrecisaVender)
            {
                _msgSimulacao = $"Saldo insuficiente. Deve R$ {r.AluguelDevido:N2}, pode levantar R$ {r.PotencialVenda:N2} vendendo.";
            }
            else
            {
                _msgSimulacao = $"Imposto pago: R$ {_impostoValor:N2}.";
                await TocarSomAsync("aluguel");
            }

            await RecarregarAsync();
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }

        StateHasChanged();
    }

