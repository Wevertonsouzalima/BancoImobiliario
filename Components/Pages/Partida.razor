@page "/jogo/partida/{IdPartida:int}"
@layout EmptyLayout

@using BancoImobiliario.Components.Componentes
@using BancoImobiliario.Models.DTOs.Jogo
@using BancoImobiliario.Models.Jogo
@using BancoImobiliario.Models.Enums
@using BancoImobiliario.Services
@using BancoImobiliario.Services.Jogo
@using BancoImobiliario.Services.Tabuleiro
@using BancoImobiliario.Components.Layout
@using Microsoft.AspNetCore.WebUtilities

@inject PartidaService PartidaService
@inject TabuleiroService TabuleiroService
@inject AcaoCasaService AcaoCasaService
@inject NavigationManager NavigationManager
@inject IJSRuntime JS

<PageTitle>Partida - Tabuleiro</PageTitle>

<div class="jogo-page">

    @if (_carregando)
    {
        <div class="jogo-loading">
            <i class="bi bi-hourglass-split"></i>
            <span>Carregando tabuleiro...</span>
        </div>
    }
    else if (!string.IsNullOrWhiteSpace(_erro))
    {
        <div class="jogo-alerta">
            <i class="bi bi-exclamation-triangle"></i>
            <span>@_erro</span>
        </div>
    }
    else
    {
        @* ===== TABULEIRO ===== *@
        <div class="tabuleiro-area">
            <div class="tabuleiro-grade"
                 style="
                --cols:@_colunas;
                --rows:@_linhas;
                --tamanho-casa:@($"{_tamanhoCasa}px");">

                @foreach (var celula in _celulas)
                {
                    var casa = celula.Casa;
                    var mostrar = casa.IsRevelada || _debug;
                    <div class="casa @(!casa.IsRevelada && _debug ? "casa-debug" : "") @(TemPeao(casa.Posicao) ? "tem-peao" : "")"
                         style="grid-column:@(celula.Coluna + 1); grid-row:@(celula.Linha + 1); @EstiloPeoes(casa.Posicao)"
                         title="@(mostrar ? $"{casa.Nome} ({casa.TipoCasaDescricao})" : "Casa não revelada")"
                         @onclick="() => InspecionarCasaAsync(casa.Posicao)">

                        @if (mostrar && !string.IsNullOrWhiteSpace(casa.Imagem))
                        {
                            <div class="casa-imagem"
                                 style="background-image:url('/imagens/@casa.Imagem');">
                            </div>
                        }
                        else if (mostrar)
                        {
                            <div class="casa-imagem casa-sem-imagem">
                                <i class="bi bi-geo-alt"></i>
                            </div>
                        }
                        else
                        {
                            <div class="casa-imagem casa-surpresa">
                                <i class="bi bi-question-lg"></i>
                            </div>
                        }

                        @if (mostrar)
                        {
                            <span class="casa-numero"
                                  style="background-color:@CorDaCasa(casa);">
                                @casa.Posicao
                            </span>
                        }

                        @* peões: bolinhas com a cor de cada jogador presente na casa *@
                        @{
                            var peoesAqui = _posicoesJogadores.Where(p => p.Posicao == casa.Posicao).ToList();
                        }
                        @if (peoesAqui.Count > 0)
                        {
                            <div class="casa-peoes">
                                @foreach (var peao in peoesAqui)
                                {
                                    <span class="peao" style="background-color:@(string.IsNullOrWhiteSpace(peao.CorHex) ? CorNeutra : peao.CorHex);"
                                          title="@peao.NomeJogador"></span>
                                }
                            </div>
                        }
                    </div>
                }
            </div>
        </div>

        @* ===== PAINEL INFERIOR: faixa 70/30 ===== *@
        <div class="painel-inferior">

            @* ----- PAINEL ESQUERDO (70%): sessão do jogador ----- *@
            <div class="painel-sessao">

                <div class="painel-cabecalho">
                    <div>
                        <span class="painel-eyebrow">Partida</span>
                        <h1>@(_lobby?.CodigoSala ?? "")</h1>
                    </div>
                    <div class="painel-cabecalho-dir">
                        @if (_vezDe is not null)
                        {
                            <span class="vez-badge" title="Jogador da vez">
                                <i class="bi bi-person-fill"></i> Vez de @_vezDe.NomeJogador
                            </span>
                        }
                        @if (_debug)
                        {
                            <span class="debug-badge" title="Modo debug ativo: casas reveladas para teste">
                                <i class="bi bi-bug-fill"></i> DEBUG
                            </span>
                        }
                        <span class="painel-status">@(_lobby?.StatusPartidaDescricao ?? "")</span>
                    </div>
                </div>

                @* SIMULAÇÃO (ferramenta de teste) *@
                <div class="simulacao-box">
                    <i class="bi bi-bug-fill"></i>
                    <span class="simulacao-label">Simular queda na casa</span>
                    <input type="number" min="1" class="simulacao-input"
                           placeholder="nº" @bind="_casaSimulada" />
                    <button type="button" class="simulacao-btn" @onclick="ExecutarSimulacaoAsync">
                        <i class="bi bi-play-fill"></i> Executar
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_msgSimulacao))
                    {
                        <span class="simulacao-msg">@_msgSimulacao</span>
                    }
                </div>

                @if (!string.IsNullOrWhiteSpace(_avisoBusiness))
                {
                    <div class="aviso-business">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@_avisoBusiness</span>
                        <button type="button" @onclick="@(() => _avisoBusiness = null)" title="Fechar">
                            <i class="bi bi-x-lg"></i>
                        </button>
                    </div>
                }

                <div class="painel-tabs">
                    <button type="button"
                            class="@(_abaAtiva == "dados" ? "tab ativa" : "tab")"
                            @onclick="@(() => _abaAtiva = "dados")">
                        Seus dados
                    </button>
                    <button type="button"
                            class="@(_abaAtiva == "propriedades" ? "tab ativa" : "tab")"
                            @onclick="@(() => _abaAtiva = "propriedades")">
                        Propriedades
                    </button>
                </div>

                <div class="painel-corpo">

                    @if (_abaAtiva == "dados")
                    {
                        <div class="aba-dados">

                            @* sub-painel: dados do jogador *@
                            <div class="subpainel bloco-dados">
                                @if (_jogadorAtual is not null)
                                {
                                    <div class="dados-cabecalho">
                                        <div class="dados-avatar" style="@EstiloAvatar(_jogadorAtual)">
                                            @if (!string.IsNullOrWhiteSpace(_jogadorAtual.UrlAvatar))
                                            {
                                                <img src="@_jogadorAtual.UrlAvatar" alt="@_jogadorAtual.NomeJogador" />
                                            }
                                            else
                                            {
                                                @ObterIniciais(_jogadorAtual.NomeJogador)
                                            }
                                        </div>
                                        <div>
                                            <strong>@_jogadorAtual.NomeJogador</strong>
                                            <small>Ordem #@_jogadorAtual.OrdemTurno</small>
                                        </div>
                                    </div>

                                    <dl class="dados-lista">
                                        <dt>Saldo</dt>
                                        <dd class="saldo">R$ @((_estadoJogador?.SaldoAtual ?? _jogadorAtual.SaldoAtual).ToString("N2"))</dd>
                                        <dt>Casa atual</dt>
                                        <dd>@(_estadoJogador?.PosicaoAtual ?? 0)</dd>
                                        <dt>Rodada</dt>
                                        <dd>0</dd>
                                        <dt>Volta</dt>
                                        <dd>@(_estadoJogador?.VoltasCompletadas ?? 0)</dd>
                                        <dt>Propriedades</dt>
                                        <dd>@_qtdPropriedades</dd>
                                    </dl>
                                }
                                else
                                {
                                    <p class="dados-vazio">Nenhum jogador identificado.</p>
                                }
                            </div>

                            @* sub-painel: efeitos + grupo (só aparece se houver algo a mostrar) *@
                            @{
                                var temEfeitos = _efeitosAtivos.Count > 0;
                                var temGrupos = _gruposCompletos.Count > 0;
                            }
                            @if (temEfeitos || temGrupos)
                            {
                                <div class="subpainel bloco-status">

                                    @if (temEfeitos)
                                    {
                                        <div class="status-secao">
                                            <h4>Efeitos</h4>
                                            <div class="badges">
                                                @foreach (var ef in _efeitosAtivos)
                                                {
                                                    <span class="badge badge-efeito" title="@ef.Frase">
                                                        <i class="bi @ef.Icone"></i>
                                                        @ef.Rotulo
                                                        @if (ef.RemoverAposVolta)
                                                        {
                                                            <span class="badge-tag">até a volta</span>
                                                        }
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    }

                                    @if (temGrupos)
                                    {
                                        <div class="status-secao">
                                            <h4>Grupos completos</h4>
                                            <div class="badges badges-grupo">
                                                @foreach (var grupoId in _gruposCompletos)
                                                {
                                                    var cor = CorDoGrupo(grupoId);
                                                    <span class="badge badge-grupo">
                                                        <span class="grupo-cor" style="background-color:@cor;"></span>
                                                        @grupoId
                                                    </span>
                                                }
                                            </div>
                                        </div>
                                    }
                                </div>
                            }
                            else
                            {
                                <div class="subpainel bloco-status vazio-status">
                                    <i class="bi bi-stars"></i>
                                    <span>Sem efeitos ativos ou grupos completos ainda.</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="aba-propriedades">
                            <div class="tabela-wrapper">
                                <table class="tabela-propriedades">
                                    <thead>
                                        <tr>
                                            <th>Cidade</th>
                                            <th>Casas</th>
                                            <th>Hoteis</th>
                                            <th>Aluguel</th>
                                            <th>Grupo</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @if (_minhasPropriedades.Count == 0)
                                        {
                                            <tr class="vazio">
                                                <td colspan="5">Voce ainda nao possui propriedades.</td>
                                            </tr>
                                        }
                                        else
                                        {
                                            @foreach (var prop in _minhasPropriedades)
                                            {
                                                <tr>
                                                    <td>@prop.Nome</td>
                                                    <td>@prop.QtdCasas</td>
                                                    <td>@prop.QtdHoteis</td>
                                                    <td>R$ @((prop.ValorAluguelAtual ?? 0m).ToString("N2"))</td>
                                                    <td>@(prop.GrupoId?.ToString() ?? "-")</td>
                                                </tr>
                                            }
                                        }
                                    </tbody>
                                </table>
                            </div>
                        </div>
                    }

                </div>

                @* AÇÕES (clean) - visibilidade conforme estado de turno e configuração *@
                <div class="painel-acoes">
                    <button type="button" class="acao dado" title="Jogar dado"
                            disabled="@(!PodeJogarDado)"
                            @onclick="JogarDadoAsync">
                        <i class="bi bi-dice-5-fill"></i>
                    </button>

                    @if (_config?.HabilitarNegociacoes == true)
                    {
                        <button type="button" class="acao">Negociação</button>
                    }

                    @if (_config?.HabilitarApostas == true)
                    {
                        <button type="button" class="acao">Apostas</button>
                    }

                    @if (PodePagar)
                    {
                        <button type="button" class="acao alerta" @onclick="PagarAsync">
                            <i class="bi bi-cash-coin"></i> Pagar
                        </button>
                    }

                    <button type="button" class="acao destaque"
                            disabled="@(!PodeFinalizar)"
                            @onclick="FinalizarJogadaAsync">
                        Finalizar jogada
                    </button>

                    <button type="button" class="acao perigo" @onclick="DesistirAsync">
                        Desistir
                    </button>
                </div>

            </div>

            @* ----- PAINEL DIREITO (30%): dados da casa (fora das abas) ----- *@
            <aside class="painel-casa">
                <PainelCasa Dados="_dadosCasa"
                            PodeComprar="PodeComprarAtual()"
                            PodeAddCasa="PodeAddCasaAtual()"
                            PodeAddHotel="PodeAddHotelAtual()"
                            OnComprar="ComprarAsync"
                            OnAddCasa="AddCasaAsync"
                            OnAddHotel="AddHotelAsync"
                            OnLimpar="LimparCasa" />
            </aside>

        </div>

        @* Modal de dado do turno (animação de rolagem) *@
        <DadoModal @ref="_dadoModal"
                   TituloModal="@_tituloDado"
                   MinValor="@(_config?.ValMinDado ?? 1)"
                   MaxValor="@(_config?.ValMaxDado ?? 6)"
                   NumerosRestritos="_numerosRestritosDado"
                   ObterResultadoServidor="RolarDadoTurnoNoServidorAsync"
                   AoConfirmar="OnDadoTurnoConfirmado" />

        @* Modal de IMUNIDADE (efeito guardado consumido: prisão/imposto/efeito/aluguel) *@
        @if (_modalImunidadeAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalImunidade">
                <div class="modal-bonus modal-imunidade" @onclick:stopPropagation="true">
                    <div class="bonus-icone imunidade-icone"><i class="bi @_imunidadeIcone"></i></div>
                    <h3>@_imunidadeTitulo</h3>
                    <p>@_imunidadeFrase</p>
                    <button type="button" class="modal-bonus-ok imunidade-btn" @onclick="FecharModalImunidade">
                        <i class="bi bi-check-lg"></i> Entendi
                    </button>
                </div>
            </div>
        }

        @* Modal "COMPRA BLOQUEADA" — efeito de bloqueio consumido ao tentar comprar *@
        @if (_modalCompraBloqueadaAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalCompraBloqueada">
                <div class="modal-bonus modal-bloqueio" @onclick:stopPropagation="true">
                    <div class="bonus-icone bloqueio-icone"><i class="bi bi-slash-circle"></i></div>
                    <h3>Compra bloqueada!</h3>
                    <p>Um efeito impediu esta compra. A propriedade não foi adquirida e o efeito será consumido ao finalizar a jogada.</p>
                    <button type="button" class="modal-bonus-ok bloqueio-btn" @onclick="FecharModalCompraBloqueada">
                        <i class="bi bi-check-lg"></i> Entendi
                    </button>
                </div>
            </div>
        }

        @* Modal TROCAR GRUPO de propriedade (efeito 17): cidade + grupo *@
        @if (_modalTrocaGrupoAberto)
        {
            <div class="modal-overlay">
                <div class="modal-bonus modal-trocagrupo" @onclick:stopPropagation="true">
                    <div class="bonus-icone trocagrupo-icone"><i class="bi bi-diagram-3"></i></div>
                    <h3>Trocar grupo</h3>
                    <p>Escolha a propriedade e o novo grupo:</p>

                    <div class="tg-colunas">
                        <div class="tg-coluna">
                            <h4>Propriedade</h4>
                            <div class="tg-lista">
                                @foreach (var c in _cidadesGrupo)
                                {
                                    <button type="button"
                                            class="tg-item @(_trocaGrupoCidade?.PartidaTabuleiroId == c.PartidaTabuleiroId ? "tg-sel" : "")"
                                            @onclick="() => SelecionarCidadeGrupo(c)">
                                        <span class="tg-cor" style="background-color:@(c.CorHexadecimal ?? "#475569");"></span>
                                        <span class="tg-nome">@c.Nome</span>
                                        @if (c.GrupoId is not null)
                                        {
                                            <span class="tg-grupoatual">G@(c.GrupoId)</span>
                                        }
                                    </button>
                                }
                            </div>
                        </div>

                        <div class="tg-coluna">
                            <h4>Novo grupo</h4>
                            <div class="tg-lista">
                                @foreach (var g in _gruposTabuleiro)
                                {
                                    <button type="button"
                                            class="tg-item @(_trocaGrupoNovo == g.GrupoId ? "tg-sel" : "")"
                                            @onclick="() => SelecionarNovoGrupo(g.GrupoId)">
                                        <span class="tg-cor" style="background-color:@(g.Cor ?? "#475569");"></span>
                                        <span class="tg-nome">
                                            <strong>Grupo @g.GrupoId</strong>
                                            @if (!string.IsNullOrWhiteSpace(g.Frase))
                                            {
                                                <small>@g.Frase</small>
                                            }
                                        </span>
                                    </button>
                                }
                            </div>
                        </div>
                    </div>

                    <div class="troca-botoes">
                        <button type="button" class="modal-bonus-ok troca-confirmar"
                                disabled="@(_trocaGrupoCidade is null || _trocaGrupoNovo is null)"
                                @onclick="ConfirmarTrocaGrupoAsync">
                            <i class="bi bi-check-lg"></i> Confirmar troca
                        </button>
                        <button type="button" class="modal-bonus-ok troca-cancelar" @onclick="CancelarTrocaGrupo">
                            Cancelar
                        </button>
                    </div>
                </div>
            </div>
        }

        @* Modal ESCOLHER jogador para trocar de casa (3+ jogadores) *@
        @if (_modalTrocaEscolhaAberto)
        {
            <div class="modal-overlay">
                <div class="modal-bonus modal-troca" @onclick:stopPropagation="true">
                    <div class="bonus-icone troca-icone"><i class="bi bi-arrow-left-right"></i></div>
                    <h3>Trocar de casa</h3>
                    <p>Escolha com quem você quer trocar de lugar:</p>
                    <div class="troca-lista">
                        @foreach (var j in _jogadoresTroca)
                        {
                            <button type="button" class="troca-item" @onclick="() => SelecionarAlvoTroca(j)">
                                <span class="troca-nome">
                                    <i class="bi @(j.EhBot ? "bi-robot" : "bi-person-fill")"></i>
                                    @j.NomeJogador
                                </span>
                                <span class="troca-pos">Casa @j.PosicaoAtual</span>
                            </button>
                        }
                    </div>
                    <button type="button" class="modal-bonus-ok troca-cancelar" @onclick="CancelarTroca">
                        Cancelar
                    </button>
                </div>
            </div>
        }

        @* Modal CONFIRMAR troca direta (2 jogadores) *@
        @if (_modalTrocaConfirmarAberto && _trocaAlvo is not null)
        {
            <div class="modal-overlay">
                <div class="modal-bonus modal-troca" @onclick:stopPropagation="true">
                    <div class="bonus-icone troca-icone"><i class="bi bi-arrow-left-right"></i></div>
                    <h3>Trocar de casa</h3>
                    <p>Trocar de lugar com <strong>@_trocaAlvo.NomeJogador</strong> (casa @_trocaAlvo.PosicaoAtual)?</p>
                    <div class="troca-botoes">
                        <button type="button" class="modal-bonus-ok troca-confirmar" @onclick="ConfirmarTrocaAsync">
                            <i class="bi bi-check-lg"></i> Trocar
                        </button>
                        <button type="button" class="modal-bonus-ok troca-cancelar" @onclick="CancelarTroca">
                            Cancelar
                        </button>
                    </div>
                </div>
            </div>
        }

        @* Modal de EFEITO (frase do efeito sorteado) *@
        @if (_modalEfeitoAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalEfeito">
                <div class="modal-bonus modal-efeito" @onclick:stopPropagation="true">
                    <div class="bonus-icone efeito-icone"><i class="bi bi-stars"></i></div>
                    <h3>Efeito!</h3>
                    <p>@_efeitoFrase</p>
                    <button type="button" class="modal-bonus-ok efeito-btn" @onclick="FecharModalEfeito">
                        <i class="bi bi-check-lg"></i> Entendi
                    </button>
                </div>
            </div>
        }

        @* Modal de IMPOSTO (frase + valor; ou rola dado para definir) *@
        @if (_modalImpostoAberto)
        {
            <div class="modal-overlay">
                <div class="modal-bonus" @onclick:stopPropagation="true" style="border-color:rgba(248,113,113,.45);">
                    <div class="bonus-icone" style="color:#f87171;"><i class="bi bi-cash-stack"></i></div>
                    <h3 style="color:#fca5a5;">@_impostoNome</h3>
                    <p>@_impostoFrase</p>
                    @if (_rolandoDadoImposto)
                    {
                        <div class="bonus-valor" style="color:#fca5a5;">Role o dado...</div>
                    }
                    else
                    {
                        <div class="bonus-valor" style="color:#fca5a5;">R$ @_impostoValor.ToString("N2")</div>
                        <button type="button" class="modal-bonus-ok" style="background:linear-gradient(135deg,#dc2626,#ef4444); color:white;"
                                @onclick="ConfirmarPagamentoImpostoAsync">
                            <i class="bi bi-cash-coin"></i> Pagar imposto
                        </button>
                    }
                </div>
            </div>
        }

        @* Modal de PRISÃO (frase + rodadas; ou rola dado para definir) *@
        @if (_modalPrisaoAberto)
        {
            <div class="modal-overlay">
                <div class="modal-bonus" @onclick:stopPropagation="true" style="border-color:rgba(148,163,184,.45);">
                    <div class="bonus-icone" style="color:#94a3b8;"><i class="bi bi-lock-fill"></i></div>
                    <h3 style="color:#cbd5e1;">@_prisaoNome</h3>
                    <p>@_prisaoFrase</p>
                    @if (_rolandoDadoPrisao)
                    {
                        <div class="bonus-valor" style="color:#cbd5e1;">Role o dado...</div>
                    }
                    else if (_prisaoModoContador)
                    {
                        @* contador: a frase já informa quantas faltam; só fecha *@
                        <button type="button" class="modal-bonus-ok" style="background:rgba(148,163,184,.25); color:#e5e7eb;"
                                @onclick="FecharModalPrisao">
                            <i class="bi bi-check-lg"></i> Entendi
                        </button>
                    }
                    else
                    {
                        <div class="bonus-valor" style="color:#cbd5e1;">@_prisaoRodadas rodada(s) preso</div>
                        <button type="button" class="modal-bonus-ok" style="background:rgba(148,163,184,.25); color:#e5e7eb;"
                                @onclick="FecharModalPrisao">
                            <i class="bi bi-check-lg"></i> Entendi
                        </button>
                    }
                </div>
            </div>
        }

        @* Modal "A LIBERDADE CANTOU!" — ao cumprir a pena *@
        @if (_modalLiberdadeAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalLiberdade">
                <div class="modal-bonus modal-liberdade" @onclick:stopPropagation="true">
                    <div class="bonus-icone liberdade-icone"><i class="bi bi-unlock-fill"></i></div>
                    <h3>A liberdade cantou! 🕊️</h3>
                    <p>Você cumpriu sua pena e está livre. Jogue o dado e boa sorte!</p>
                    <button type="button" class="modal-bonus-ok liberdade-btn" @onclick="FecharModalLiberdade">
                        <i class="bi bi-dice-5-fill"></i> Jogar
                    </button>
                </div>
            </div>
        }

        @* Modal de confirmação da XEROX (misteriosa, valor fixo, opcional) *@
        @if (_modalXeroxAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalXerox">
                <div class="modal-bonus" @onclick:stopPropagation="true" style="border-color:rgba(96,165,250,.4);">
                    <div class="bonus-icone" style="color:#60a5fa;"><i class="bi bi-question-lg"></i></div>
                    <h3 style="color:#93c5fd;">Companhia misteriosa</h3>
                    <p>Deseja comprar esta companhia? Você só vai descobrir o que ela faz depois de comprar!</p>
                    <div class="bonus-valor" style="color:#93c5fd;">R$ @_xeroxPreco.ToString("N2")</div>
                    <div style="display:flex; gap:.6rem;">
                        <button type="button" class="modal-bonus-ok" style="background:rgba(148,163,184,.2); color:#e5e7eb;"
                                @onclick="FecharModalXerox">
                            Não comprar
                        </button>
                        <button type="button" class="modal-bonus-ok" style="background:linear-gradient(135deg,#2563eb,#3b82f6); color:white;"
                                @onclick="ConfirmarCompraXeroxAsync">
                            <i class="bi bi-cash-coin"></i> Comprar
                        </button>
                    </div>
                </div>
            </div>
        }

        @* Modal GENÉRICO de seleção de propriedade (Xerox copiar, etc.) *@
        <ModalSelecaoPropriedade @ref="_modalSelecao"
                                 Titulo="@_selecaoTitulo"
                                 Subtitulo="@_selecaoSubtitulo"
                                 TextoBotao="@_selecaoTextoBotao"
                                 Itens="_itensSelecao"
                                 FiltroPermitido="@_selecaoFiltro"
                                 PermiteCancelar="false"
                                 AoSelecionar="OnPropriedadeSelecionadaXerox" />

        @* Modal de compra de companhia normal (valor livre + preview do aluguel) *@
        <ModalComprarCompanhia @ref="_modalCompanhia"
                               AoComprar="OnCompanhiaCompradaAsync" />

        @* Modal da BUSINESS (aquisição grátis, se tem todas as outras companhias) *@
        @if (_modalBusinessAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalBusiness">
                <div class="modal-bonus" @onclick:stopPropagation="true" style="border-color:rgba(96,165,250,.4);">
                    <div class="bonus-icone" style="color:#60a5fa;"><i class="bi bi-briefcase-fill"></i></div>
                    <h3 style="color:#93c5fd;">@_businessNome</h3>
                    <p>Você é dono de todas as outras companhias e pode adquirir esta de graça!</p>
                    <div class="bonus-valor" style="color:#93c5fd;">Aluguel: R$ @_businessAluguel.ToString("N2")</div>
                    <div style="display:flex; gap:.6rem;">
                        <button type="button" class="modal-bonus-ok" style="background:rgba(148,163,184,.2); color:#e5e7eb;"
                                @onclick="FecharModalBusiness">
                            Não adquirir
                        </button>
                        <button type="button" class="modal-bonus-ok" style="background:linear-gradient(135deg,#2563eb,#3b82f6); color:white;"
                                @onclick="AdquirirBusinessAsync">
                            <i class="bi bi-briefcase"></i> Adquirir
                        </button>
                    </div>
                </div>
            </div>
        }

        @* Modal de BÔNUS DE VOLTA (aparece primeiro, ao completar uma volta) *@
        @if (_modalBonusAberto)
        {
            <div class="modal-overlay" @onclick="FecharModalBonus">
                <div class="modal-bonus" @onclick:stopPropagation="true">
                    <div class="bonus-icone"><i class="bi bi-trophy-fill"></i></div>
                    <h3>Volta completa!</h3>
                    <p>Você deu uma volta no tabuleiro e ganhou um bônus.</p>
                    <div class="bonus-valor">+ R$ @_bonusVoltaValor.ToString("N2")</div>
                    <button type="button" class="modal-bonus-ok" @onclick="FecharModalBonus">
                        <i class="bi bi-check-lg"></i> Continuar
                    </button>
                </div>
            </div>
        }

        @* Modal CENTRAL DA CASA (atalho ao cair) - reaproveita o PainelCasa *@
        @if (_modalCasaAberto && _dadosCasa is not null)
        {
            <div class="modal-overlay" @onclick="FecharModalCasa">
                <div class="modal-casa" @onclick:stopPropagation="true">
                    <button type="button" class="modal-casa-x" @onclick="FecharModalCasa" title="Fechar">
                        <i class="bi bi-x-lg"></i>
                    </button>
                    @if (!string.IsNullOrWhiteSpace(_msgBot))
                    {
                        <div class="modal-bot-faixa">
                            <i class="bi bi-robot"></i> @_msgBot
                        </div>
                    }
                    <PainelCasa Dados="_dadosCasa"
                                PodeComprar="PodeComprarAtual()"
                                PodeAddCasa="PodeAddCasaAtual()"
                                PodeAddHotel="PodeAddHotelAtual()"
                                OnComprar="ComprarNoModalAsync"
                                OnAddCasa="AddCasaNoModalAsync"
                                OnAddHotel="AddHotelNoModalAsync"
                                OnLimpar="FecharModalCasa" />
                </div>
            </div>
        }
    }
</div>

<style>
    .jogo-page {
        min-height: 100vh;
        background: linear-gradient(160deg, #0b1120, #050810);
        color: #e5e7eb;
        padding: 0;
        margin: 0;
    }

    .jogo-loading,
    .jogo-alerta {
        display: flex;
        align-items: center;
        gap: .65rem;
        max-width: 480px;
        margin: 3rem auto;
        padding: 1rem 1.2rem;
        border-radius: 16px;
        border: 1px solid rgba(148, 163, 184, .18);
        background: rgba(15, 23, 42, .7);
    }

    .jogo-alerta {
        border-color: rgba(239, 68, 68, .3);
        background: rgba(239, 68, 68, .12);
        color: #fca5a5;
    }

    /* ===== TABULEIRO ===== */
    .tabuleiro-area {
        padding: 1rem;
        overflow-x: auto;
        overflow-y: hidden;
        display: flex;
        justify-content: center;
    }

    .tabuleiro-grade {
        display: grid;
        grid-template-columns: repeat(var(--cols), var(--tamanho-casa));
        grid-template-rows: repeat(var(--rows), var(--tamanho-casa));
        gap: 6px;
    }

    .casa {
        position: relative;
        border-radius: 10px;
        overflow: hidden;
        background: #0b1225;
        border: 1px solid rgba(148, 163, 184, .2);
        box-shadow: 0 4px 12px rgba(0,0,0,.35);
        transition: transform 140ms ease, box-shadow 140ms ease;
        min-width: 0;
        cursor: pointer;
        --peao-ring: transparent;
    }

        .casa:hover {
            transform: scale(1.06);
            box-shadow: 0 12px 26px rgba(0,0,0,.55);
            z-index: 5;
        }

        /* casa com jogador(es): anel externo com a cor (definida inline via --peao-ring) */
        .casa.tem-peao {
            box-shadow: 0 0 0 3px var(--peao-ring), 0 6px 16px rgba(0,0,0,.5);
        }

    /* bolinhas dos jogadores na casa */
    .casa-peoes {
        position: absolute;
        bottom: 4px;
        right: 4px;
        display: flex;
        gap: 3px;
        z-index: 4;
    }

    .peao {
        width: 12px;
        height: 12px;
        border-radius: 50%;
        border: 2px solid rgba(255,255,255,.85);
        box-shadow: 0 1px 4px rgba(0,0,0,.6);
        display: inline-block;
    }

    .casa-imagem {
        position: absolute;
        inset: 0;
        background-size: cover;
        background-position: center;
        background-repeat: no-repeat;
    }

    .casa-sem-imagem {
        display: flex;
        align-items: center;
        justify-content: center;
        background: linear-gradient(145deg, #1e293b, #0f172a);
        color: #475569;
        font-size: 1.5rem;
    }

    /* casa não revelada: caixa misteriosa animada */
    .casa-surpresa {
        position: absolute;
        inset: 0;
        display: flex;
        align-items: center;
        justify-content: center;
        overflow: hidden;
        background: radial-gradient(circle at 50% 40%, rgba(96,165,250,.28), transparent 62%), linear-gradient(150deg, #1b2540, #0d1426 70%);
        color: #93c5fd;
        animation: surpresaGlow 3.2s ease-in-out infinite;
    }

        /* o "?" flutua de leve, grande e iluminado */
        .casa-surpresa i {
            font-size: 2.6rem;
            font-weight: 900;
            z-index: 2;
            color: #bfdbfe;
            text-shadow: 0 0 12px rgba(96,165,250,.8), 0 0 26px rgba(96,165,250,.45);
            animation: surpresaFloat 2.6s ease-in-out infinite;
        }

        /* brilho diagonal que cruza a casa de tempos em tempos */
        .casa-surpresa::before {
            content: "";
            position: absolute;
            top: -60%;
            left: -120%;
            width: 60%;
            height: 220%;
            background: linear-gradient( 105deg, transparent, rgba(147, 197, 253, .28), transparent);
            transform: rotate(8deg);
            animation: surpresaShimmer 3.8s ease-in-out infinite;
        }

        /* pontos decorativos sutis no fundo */
        .casa-surpresa::after {
            content: "";
            position: absolute;
            inset: 0;
            background-image: radial-gradient(rgba(148,163,184,.18) 1px, transparent 1px);
            background-size: 12px 12px;
            opacity: .5;
            z-index: 1;
        }

    .casa:hover .casa-surpresa {
        animation-duration: 1.4s;
    }

        .casa:hover .casa-surpresa i {
            animation-duration: 1s;
            color: #ffffff;
            transform: scale(1.18);
            text-shadow: 0 0 16px rgba(147,197,253,.95), 0 0 34px rgba(96,165,250,.6);
        }

    @@keyframes surpresaGlow {
        0%, 100% {
            box-shadow: inset 0 0 18px rgba(59,130,246,.12);
        }

        50% {
            box-shadow: inset 0 0 30px rgba(59,130,246,.34);
        }
    }

    @@keyframes surpresaFloat {
        0%, 100% {
            transform: translateY(0) rotate(0deg);
        }

        50% {
            transform: translateY(-4px) rotate(-6deg);
        }
    }

    @@keyframes surpresaShimmer {
        0% {
            left: -120%;
        }

        55% {
            left: 160%;
        }

        100% {
            left: 160%;
        }
    }

    /* casa visível só por causa do modo debug: contorno tracejado de alerta */
    .casa-debug {
        outline: 2px dashed rgba(251, 191, 36, .7);
        outline-offset: -2px;
    }

    .painel-cabecalho-dir {
