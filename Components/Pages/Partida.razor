    }

    private bool PodeComprarAtual()
    {
        if (_dadosCasa is null || _jogadorAtual is null)
            return false;

        var saldo = _estadoJogador?.SaldoAtual ?? _jogadorAtual.SaldoAtual;
        var preco = _dadosCasa.ValorCompra ?? 0m;
        return saldo >= preco;
    }

    private bool PodeAddCasaAtual()
    {
        if (_dadosCasa is null || _config is null || !_dadosCasa.EhDonoJogadorDaVez)
            return false;

        return _dadosCasa.QtdCasas < _config.QtdMaxCasas;
    }

    private bool PodeAddHotelAtual()
    {
        if (_dadosCasa is null || _config is null || !_dadosCasa.EhDonoJogadorDaVez)
            return false;

        return _dadosCasa.QtdCasas >= _config.MinCasasParaHotel
            && _dadosCasa.QtdHoteis < _config.QtdMaxHoteis;
    }

    // ========================================
    // PEÕES
    // ========================================

    private bool TemPeao(int posicao)
        => _posicoesJogadores.Any(p => p.Posicao == posicao);

    // Borda (anel) da casa: cor do jogador. Vários jogadores = degradê cônico.
    private string EstiloPeoes(int posicao)
    {
        var cores = _posicoesJogadores
            .Where(p => p.Posicao == posicao)
            .Select(p => string.IsNullOrWhiteSpace(p.CorHex) ? CorNeutra : p.CorHex)
            .ToList();

        if (cores.Count == 0)
            return string.Empty;

        if (cores.Count == 1)
            return $"--peao-ring:{cores[0]};";

        var stops = string.Join(",", cores);
        return $"--peao-ring:transparent; box-shadow:0 6px 16px rgba(0,0,0,.5); "
             + $"outline:3px solid transparent; border-image:conic-gradient({stops}) 1;";
    }

    private static string CorDaCasa(TabuleiroCasaDTO casa)
    {
        return string.IsNullOrWhiteSpace(casa.CorHexadecimal)
            ? CorNeutra
            : casa.CorHexadecimal;
    }

    private string CorDoGrupo(int grupoId)
    {
        var casa = _casas.FirstOrDefault(c => c.GrupoId == grupoId);
        return string.IsNullOrWhiteSpace(casa?.CorHexadecimal) ? CorNeutra : casa!.CorHexadecimal;
    }

    private static string EstiloAvatar(LobbyJogadorDTO jogador)
    {
        return string.IsNullOrWhiteSpace(jogador.CorHex)
            ? string.Empty
            : $"border-color:{jogador.CorHex};";
    }

    private static string ObterIniciais(string? nome)
    {
        if (string.IsNullOrWhiteSpace(nome))
            return "?";

        var partes = nome.Split(' ',
            StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (partes.Length == 1)
            return partes[0][0].ToString().ToUpperInvariant();

        return $"{partes[0][0]}{partes[^1][0]}".ToUpperInvariant();
    }

    private async Task TocarSomAsync(string nome)
    {
        try
        {
            await JS.InvokeVoidAsync("jogoAudio.tocar", nome);
        }
        catch
        {
            /* som opcional */
        }
    }

    // ========================================
    // TURNO DO BOT (automático, animado)
    // ========================================

    // Verifica se o jogador da vez é um bot e, se for, conduz o turno dele.
    // Encadeia: ao terminar, passa a vez; se o próximo também for bot, repete.
    private async Task VerificarTurnoBotAsync()
    {
        if (_botJogando) return;

        // O jogador da vez é bot e está aguardando o dado?
        var vez = _posicoesJogadores
            .FirstOrDefault(p => p.EstadoTurno == (int)EstadoTurnoJogador.AguardandoDado && p.EhBot);

        if (vez is null) return;

        _botJogando = true;

        try
        {
            // pequeno respiro antes de o bot começar
            await Task.Delay(700);

            var bot = vez;
            while (bot is not null)
            {
                await AnimarTurnoBotAsync(bot.IdPartidaJogador);

                // passa a vez no servidor
                var proximoId = await PartidaService.PassarVezAsync(IdPartida, bot.IdPartidaJogador);
                await RecarregarAsync();
                StateHasChanged();

                // o próximo é bot? continua a cadeia; senão, devolve ao humano
                bot = _posicoesJogadores
                    .FirstOrDefault(p => p.IdPartidaJogador == proximoId && p.EhBot
                        && p.EstadoTurno == (int)EstadoTurnoJogador.AguardandoDado);

                if (bot is not null)
                    await Task.Delay(700);
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            // Ao devolver a vez ao humano, garante que nenhum modal do bot
            // fique aberto. O modal da casa só deve abrir quando o jogador
            // da vez CAIR numa casa, não na troca de turno.
            _modalCasaAberto = false;
            _modalBonusAberto = false;
            _msgBot = null;
            _dadosCasa = null;
            _botJogando = false;
            StateHasChanged();
        }

        // A vez voltou ao humano: se ele estiver preso, trata (decrementa e passa).
        await VerificarPrisaoVezAsync();
    }

    // Toca o roteiro de um turno do bot: dado auto -> bônus -> casa -> decisão.
    private async Task AnimarTurnoBotAsync(int idBot)
    {
        var roteiro = await AcaoCasaService.JogarTurnoBotAsync(IdPartida, idBot);

        _tituloDado = $"Vez de {roteiro.NomeJogador}";
        StateHasChanged();

        // 1. Dado automático (gira e para sozinho no valor)
        if (_dadoModal is not null)
            await _dadoModal.AbrirAutomaticoAsync(roteiro.ValorDado);

        // 2. Atualiza tabuleiro (peão move)
        await RecarregarAsync();
        StateHasChanged();

        // 3. Bônus de volta (auto-fecha)
        if (roteiro.CompletouVolta && roteiro.BonusVolta > 0)
        {
            _bonusVoltaValor = roteiro.BonusVolta;
            _modalBonusAberto = true;
            await TocarSomAsync("bonus");
            StateHasChanged();
            await Task.Delay(2800);
            _modalBonusAberto = false;
            StateHasChanged();
        }

        // 4. Modal da casa com "pensando" e a decisão
        if (roteiro.PosicaoFinal > 0)
        {
            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(
                IdPartida, roteiro.PosicaoFinal, idBot, _debug);
            _modalCasaAberto = true;
            _msgBot = "Pensando...";
            StateHasChanged();
            await Task.Delay(2500);

            // som conforme a ação
            switch (roteiro.Acao)
            {
                case AcaoCasaService.AcaoBot.Comprou:
                    await TocarSomAsync("compra");
                    break;
                case AcaoCasaService.AcaoBot.PagouAluguel:
                    // casa de imposto (tipo 3) tem som próprio
                    await TocarSomAsync(roteiro.TipoCasaId == 3 ? "impostos" : "aluguel");
                    break;
                case AcaoCasaService.AcaoBot.Eliminado:
                    await TocarSomAsync("eliminado");
                    break;
            }

            _msgBot = roteiro.Mensagem;
            _msgSimulacao = roteiro.Mensagem;
            StateHasChanged();

            await Task.Delay(3000);
            _modalCasaAberto = false;
            _msgBot = null;
            StateHasChanged();
        }
    }

