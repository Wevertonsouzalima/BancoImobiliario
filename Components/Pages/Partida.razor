    private async Task PagarAsync()
    {
        if (_estadoJogador is null) return;

        try
        {
            var r = await AcaoCasaService.PagarAluguelAsync(IdPartida, _estadoJogador.IdPartidaJogador);
            _ultimoPagamento = r;

            if (r.Imune)
            {
                _ultimaAcaoCasa = null;
                await RecarregarAsync();
                await AbrirModalImunidadeAsync("Imune ao aluguel!", "Você ficou imune ao pagamento deste aluguel!", "bi-house-slash");
                return;
            }

            if (r.Eliminado)
            {
                _msgSimulacao = $"Sem saldo nem propriedades suficientes. Jogador eliminado. Pagou R$ {r.ValorPago:N2}.";
                await TocarSomAsync("eliminado");
            }
            else if (r.PrecisaVender)
                _msgSimulacao = $"Saldo insuficiente. Venda propriedades: deve R$ {r.AluguelDevido:N2}, pode levantar R$ {r.PotencialVenda:N2}.";
            else
            {
                _msgSimulacao = $"Aluguel pago: R$ {r.ValorPago:N2}.";
                await TocarSomAsync("aluguel");
            }

            if (r.Pago || r.Eliminado)
                _ultimaAcaoCasa = null;
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }

        await RecarregarAsync();
    }

    private async Task FinalizarJogadaAsync()
    {
        if (_estadoJogador is null || !PodeFinalizar) return;

        try
        {
            // Se tentou comprar com bloqueio ativo nesta jogada, agora o efeito é
            // consumido (foi "usado" ao tentar). Se não tentou, permanece.
            if (_tentouComprarBloqueado)
            {
                await AcaoCasaService.ConsumirEfeitoSeAtivoAsync(
                    IdPartida, _estadoJogador.IdPartidaJogador, AcaoCasaService.EF_BLOQUEIO_COMPRA);
                _tentouComprarBloqueado = false;
            }

            // Se está cumprindo prisão nesta vez, consome uma rodada antes de passar.
            if (_estaPresoNestaVez)
            {
                await AcaoCasaService.ProcessarInicioVezPrisaoAsync(IdPartida, _estadoJogador.IdPartidaJogador);

                // Se esta era a última rodada (TurnosPreso era 1 -> agora 0),
                // marca para mostrar "A liberdade cantou!" na próxima vez dele.
                if (_estadoJogador.TurnosPreso <= 1)
                    _idJogadorLibertando = _estadoJogador.IdPartidaJogador;

                _estaPresoNestaVez = false;
                _prisaoModoContador = false;
                _modalPrisaoAberto = false;
            }

            await PartidaService.PassarVezAsync(IdPartida, _estadoJogador.IdPartidaJogador);
            _ultimaAcaoCasa = null;
            _dadosCasa = null;
            _msgSimulacao = "Jogada finalizada.";
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }

        await RecarregarAsync();
        StateHasChanged();

        // Se a vez passou para alguém preso, trata; senão, se for bot, joga.
        if (await VerificarPrisaoVezAsync())
            return;

        await VerificarTurnoBotAsync();
    }

    private async Task DesistirAsync()
    {
        if (_estadoJogador is null) return;

        try
        {
            await PartidaService.DesistirAsync(IdPartida, _estadoJogador.IdPartidaJogador);
            _ultimaAcaoCasa = null;
            _dadosCasa = null;
            _msgSimulacao = "Você desistiu da partida.";
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }

        await RecarregarAsync();
        StateHasChanged();
    }

    private async Task AddCasaAsync()
    {
        if (_estadoJogador is null || _dadosCasa is null) return;
        try
        {
            var r = await AcaoCasaService.AdicionarCasaAsync(IdPartida, _estadoJogador.IdPartidaJogador);
            await TocarSomAsync("construir");
            _msgSimulacao = $"Casa construída (-R$ {r.CustoPago:N2}). Aluguel agora R$ {r.NovoAluguel:N2}.";
            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, _dadosCasa.Posicao, _jogadorAtual!.IdPartidaJogador, _debug);
            await RecarregarAsync();
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private async Task AddHotelAsync()
    {
        if (_estadoJogador is null || _dadosCasa is null) return;
        try
        {
            var r = await AcaoCasaService.AdicionarHotelAsync(IdPartida, _estadoJogador.IdPartidaJogador);
            await TocarSomAsync("construir");
            _msgSimulacao = $"Hotel construído (-R$ {r.CustoPago:N2}). Aluguel agora R$ {r.NovoAluguel:N2}.";
            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, _dadosCasa.Posicao, _jogadorAtual!.IdPartidaJogador, _debug);
            await RecarregarAsync();
