    // Abre o modal de imunidade (verde) e toca o som de efeito bom.
    private async Task AbrirModalImunidadeAsync(string titulo, string frase, string icone)
    {
        _imunidadeTitulo = titulo;
        _imunidadeFrase = frase;
        _imunidadeIcone = icone;
        _modalImunidadeAberto = true;
        await TocarSomEfeitoAsync("bom");
        StateHasChanged();
    }

    private void FecharModalImunidade() => _modalImunidadeAberto = false;

    // Toca o som conforme o tom do efeito: bom / ruim / neutro.
    private async Task TocarSomEfeitoAsync(string tom)
    {
        switch (tom)
        {
            case "bom":
                await TocarSomAsync("efeito_bom");
                break;
            case "ruim":
                await TocarSomAsync("efeito_ruim");
                break;
            default:
                await TocarSomAsync("efeito_neutro");
                break;
        }
    }

    // Xerox: abre o modal de confirmação (misteriosa, valor fixo, opcional).
    // A compra só acontece se o jogador confirmar.
    private async Task ResolverXeroxAsync()
    {
        if (_jogadorAtual is null) return;

        // valor de compra: vem do resultado do turno (ProcessarPropriedade preenche
        // Valor com ValorCompraAtual). Em fallback, usa o dados da casa.
        _xeroxPreco = _resultadoTurno?.Casa.Valor ?? _dadosCasa?.ValorCompra ?? 0m;
        _modalXeroxAberto = true;
        StateHasChanged();
        await Task.CompletedTask;
    }

