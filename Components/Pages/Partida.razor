@code {
    [Parameter]
    public int IdPartida { get; set; }

    private bool _carregando = true;
    private string? _erro;

    private LobbyPartidaDTO? _lobby;
    private LobbyJogadorDTO? _jogadorAtual;
    private Tb_PartidaJogador? _estadoJogador;
    private List<TabuleiroCasaDTO> _casas = new();

    private List<CelulaTabuleiro> _celulas = new();

    private readonly Dictionary<int, (int Linha, int Coluna)> _posicaoLayout = new();

    private string _abaAtiva = "dados";

    private const string CorNeutra = "#94a3b8";

    private int _colunas = 10;
    private int _linhas = 10;
    private int _tamanhoCasa = 80;

    private int? _casaSimulada;
    private string? _msgSimulacao;
    private DadosCasaPopup? _dadosCasa;

    // Modo debug: ativado por ?debug=true (ou ?debug) na URL. Mostra pistas (número/cor)
    // de casas não reveladas para facilitar o desenvolvimento. Fora dele, jogo real.
    private bool _debug;

    // Configuração da partida (regras: negociações, apostas, limites de construção...)
    private BancoImobiliario.Models.Configuracao? _config;

    // GrupoIds que o jogador da vez possui por completo (todas as casas do grupo)
    private HashSet<int> _gruposCompletos = new();

    protected override async Task OnInitializedAsync()
    {
        DetectarDebug();

        try
        {
            _lobby = await PartidaService.ObterLobbyAsync(IdPartida);
            _casas = await PartidaService.ObterTabuleiroPartidaAsync(IdPartida);

            if (_casas.Count == 0)
            {
                _erro = "O tabuleiro desta partida ainda nao foi gerado.";
                return;
            }

            var configDaPartida = await PartidaService.ObterConfiguracaoAsync(IdPartida);

            if (configDaPartida == null)
            {
                _erro = "Configuração da partida não encontrada.";
                return;
            }

            _config = configDaPartida;

            var tabuleiroDb = await TabuleiroService.ObterTabuleiroPorIdAsync(configDaPartida.IdTabuleiro);
            if (tabuleiroDb == null)
            {
                _erro = "Dados estruturais do tabuleiro não encontrados.";
                return;
            }

            _colunas = tabuleiroDb.LarguraGrade;
            _linhas = tabuleiroDb.AlturaGrade;
            _tamanhoCasa = tabuleiroDb.TamanhoCasaPx;

            var layoutDoBanco = await TabuleiroService.ObterLayoutPorTabuleiroIdAsync(configDaPartida.IdTabuleiro);

            _posicaoLayout.Clear();
            foreach (var l in layoutDoBanco)
                _posicaoLayout[l.Posicao] = (l.Linha, l.Coluna);

            _jogadorAtual = _lobby?.Jogadores
                .Where(j => j.TipoJogador == (int)TipoJogadorPartida.Humano)
                .OrderBy(j => j.OrdemTurno ?? 99)
                .FirstOrDefault();

            if (_jogadorAtual is not null)
                _estadoJogador = await AcaoCasaService.ObterJogadorAsync(IdPartida, _jogadorAtual.IdPartidaJogador);

            RecalcularGruposCompletos();
            RemapearCelulas();
        }
        catch (Exception ex)
        {
            _erro = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _carregando = false;
        }
    }

    // Lê ?debug=... da URL. Aceita "?debug", "?debug=true", "?debug=1".
    private void DetectarDebug()
    {
        var uri = NavigationManager.ToAbsoluteUri(NavigationManager.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        if (!query.TryGetValue("debug", out var valor))
        {
            _debug = false;
            return;
        }

        var v = valor.ToString();
        // "?debug" sem valor, "?debug=true" ou "?debug=1" ligam o modo.
        _debug = string.IsNullOrEmpty(v)
                 || v.Equals("true", StringComparison.OrdinalIgnoreCase)
                 || v == "1";
    }

    private void RemapearCelulas()
    {
        _celulas = new List<CelulaTabuleiro>();

        foreach (var casa in _casas)
        {
            var pos = _posicaoLayout.TryGetValue(casa.Posicao, out var p) ? p : (Linha: 0, Coluna: 0);

            _celulas.Add(new CelulaTabuleiro
            {
                Casa = casa,
                Coluna = pos.Coluna,
                Linha = pos.Linha
            });
        }
    }

    private async Task RecarregarAsync()
    {
        _casas = await PartidaService.ObterTabuleiroPartidaAsync(IdPartida);
        _lobby = await PartidaService.ObterLobbyAsync(IdPartida);

        _jogadorAtual = _lobby?.Jogadores
            .Where(j => j.TipoJogador == (int)TipoJogadorPartida.Humano)
            .OrderBy(j => j.OrdemTurno ?? 99)
            .FirstOrDefault();

        if (_jogadorAtual is not null)
            _estadoJogador = await AcaoCasaService.ObterJogadorAsync(IdPartida, _jogadorAtual.IdPartidaJogador);

        RecalcularGruposCompletos();
        RemapearCelulas();
    }

    // Um grupo está "completo" quando o jogador da vez possui TODAS as casas daquele GrupoId.
    private void RecalcularGruposCompletos()
    {
        _gruposCompletos = new HashSet<int>();

        if (_jogadorAtual is null)
            return;

        var meuId = _jogadorAtual.IdPartidaJogador;

        var porGrupo = _casas
            .Where(c => c.GrupoId is not null)
            .GroupBy(c => c.GrupoId!.Value);

        foreach (var grupo in porGrupo)
        {
            var total = grupo.Count();
            var meus = grupo.Count(c => c.ProprietarioId == meuId);

            if (total > 0 && meus == total)
                _gruposCompletos.Add(grupo.Key);
        }
    }

    private async Task ExecutarSimulacaoAsync()
    {
        _msgSimulacao = null;

        if (_jogadorAtual is null)
        {
            _msgSimulacao = "Nenhum jogador identificado.";
            return;
        }

        if (_casaSimulada is null)
        {
            _msgSimulacao = "Informe o número da casa.";
            return;
        }

        var posicao = _casaSimulada.Value;

        if (_casas.All(c => c.Posicao != posicao))
        {
            _msgSimulacao = $"A casa {posicao} não existe neste tabuleiro.";
            return;
        }

        try
        {
            await AcaoCasaService.DefinirPosicaoAsync(IdPartida, _jogadorAtual.IdPartidaJogador, posicao);

            var resultado = await AcaoCasaService.AoCairNaCasaAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
            _msgSimulacao = resultado.Mensagem;
            _ultimaAcaoCasa = resultado.Acao;

            // Define o estado de turno conforme o resultado:
            // ação que exige resolução (pagar) -> ResolvendoCasa; caso contrário, já pode finalizar.
            var exigeResolucao = resultado.Acao is TipoAcaoCasa.PagouAluguel or TipoAcaoCasa.PagouImposto;
            await AcaoCasaService.DefinirEstadoTurnoAsync(
                IdPartida, _jogadorAtual.IdPartidaJogador,
                exigeResolucao
                    ? BancoImobiliario.Models.Enums.EstadoTurnoJogador.ResolvendoCasa
                    : BancoImobiliario.Models.Enums.EstadoTurnoJogador.TurnoConcluido);

            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, posicao, _jogadorAtual.IdPartidaJogador, _debug);

            await RecarregarAsync();
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private async Task InspecionarCasaAsync(int posicao)
    {
        if (_jogadorAtual is null)
            return;

        try
        {
            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, posicao, _jogadorAtual.IdPartidaJogador, _debug);
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private void LimparCasa()
    {
        _dadosCasa = null;
    }

    private async Task ComprarAsync()
    {
        if (_jogadorAtual is null || _dadosCasa is null)
            return;

        try
        {
            await AcaoCasaService.ComprarPropriedadeAsync(IdPartida, _jogadorAtual.IdPartidaJogador);

            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, _dadosCasa.Posicao, _jogadorAtual.IdPartidaJogador, _debug);
            await RecarregarAsync();
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    // ========================================
    // VISIBILIDADE / ESTADO DE TURNO
    // ========================================

    private BancoImobiliario.Models.Enums.EstadoTurnoJogador EstadoAtual
        => (BancoImobiliario.Models.Enums.EstadoTurnoJogador)(_estadoJogador?.EstadoTurno ?? 0);

    private bool PodeJogarDado
        => EstadoAtual == BancoImobiliario.Models.Enums.EstadoTurnoJogador.AguardandoDado;

    // Pagar: há uma ação pendente de pagamento na casa atual (aluguel de outro dono).
    // Impostos/efeitos entram aqui quando esses tipos forem implementados.
    private bool PodePagar
    {
        get
        {
            if (EstadoAtual != BancoImobiliario.Models.Enums.EstadoTurnoJogador.ResolvendoCasa)
                return false;

            return _ultimaAcaoCasa == TipoAcaoCasa.PagouAluguel
                || _ultimaAcaoCasa == TipoAcaoCasa.PagouImposto;
        }
    }

    // Finalizar: bool independente na entidade (será ligado aos efeitos depois).
    private bool PodeFinalizar => _estadoJogador?.PodeFinalizar ?? false;

    // Guarda o tipo da última ação resultante de cair na casa (para visibilidade do Pagar).
    private TipoAcaoCasa? _ultimaAcaoCasa;

    // ========================================
    // HANDLERS DE TURNO (lógica real virá com o motor de turno)
    // ========================================

    // TODO: rolar dado de verdade (faixa ValMinDado/ValMaxDado), mover o peão,
    // resolver volta/bônus e então cair na casa. Por ora apenas avança o estado.
    private async Task JogarDadoAsync()
    {
        if (_estadoJogador is null) return;

        await AcaoCasaService.DefinirEstadoTurnoAsync(
            IdPartida, _estadoJogador.IdPartidaJogador,
            BancoImobiliario.Models.Enums.EstadoTurnoJogador.ResolvendoCasa);

        _msgSimulacao = "Dado jogado (simulação). Resolva a ação da casa.";
        await RecarregarAsync();
    }

    private async Task PagarAsync()
    {
        if (_estadoJogador is null) return;

        // O débito do aluguel já ocorre em AoCairNaCasa; aqui apenas conclui a ação pendente.
        await AcaoCasaService.ConcluirAcaoCasaAsync(IdPartida, _estadoJogador.IdPartidaJogador);

        _ultimaAcaoCasa = null;
        _msgSimulacao = "Pagamento concluído.";
        await RecarregarAsync();
    }

    private async Task FinalizarJogadaAsync()
    {
        if (_estadoJogador is null || !PodeFinalizar) return;

        await AcaoCasaService.DefinirEstadoTurnoAsync(
            IdPartida, _estadoJogador.IdPartidaJogador,
            BancoImobiliario.Models.Enums.EstadoTurnoJogador.AguardandoVez);

        _ultimaAcaoCasa = null;
        _msgSimulacao = "Jogada finalizada.";
        await RecarregarAsync();
    }

    // TODO: implementar desistência (marca status, libera propriedades etc.).
    private Task DesistirAsync()
    {
        _msgSimulacao = "Desistir: a implementar.";
        return Task.CompletedTask;
    }

    // TODO: implementar construção de casa/hotel (debita custo, incrementa QtdCasas/QtdHoteis).
    private Task AddCasaAsync()
    {
        _msgSimulacao = "Construção de casa: a implementar.";
        return Task.CompletedTask;
    }

    private Task AddHotelAsync()
    {
        _msgSimulacao = "Construção de hotel: a implementar.";
        return Task.CompletedTask;
    }

    private bool PodeComprarAtual()
    {
        if (_dadosCasa is null || _jogadorAtual is null)
            return false;

        var saldo = _estadoJogador?.SaldoAtual ?? _jogadorAtual.SaldoAtual;
        var preco = _dadosCasa.ValorCompra ?? 0m;
        return saldo >= preco;
    }

    // Add. Casa: é dono e ainda não atingiu o máximo de casas por propriedade.
    private bool PodeAddCasaAtual()
    {
        if (_dadosCasa is null || _config is null || !_dadosCasa.EhDonoJogadorDaVez)
            return false;

        return _dadosCasa.QtdCasas < _config.QtdMaxCasas;
    }

    // Add. Hotel: é dono, tem casas suficientes (>= MinCasasParaHotel) e não atingiu o máximo de hotéis.
    private bool PodeAddHotelAtual()
    {
        if (_dadosCasa is null || _config is null || !_dadosCasa.EhDonoJogadorDaVez)
            return false;

        return _dadosCasa.QtdCasas >= _config.MinCasasParaHotel
            && _dadosCasa.QtdHoteis < _config.QtdMaxHoteis;
    }

    private static string CorDaCasa(TabuleiroCasaDTO casa)
    {
        return string.IsNullOrWhiteSpace(casa.CorHexadecimal)
            ? CorNeutra
            : casa.CorHexadecimal;
    }

    // Cor de um grupo: usa a cor de qualquer casa daquele GrupoId (todas compartilham a cor).
    private string CorDoGrupo(int grupoId)
    {
        var casa = _casas.FirstOrDefault(c => c.GrupoId == grupoId);
        return string.IsNullOrWhiteSpace(casa?.CorHexadecimal) ? CorNeutra : casa!.CorHexadecimal;
    }

    private static string EstiloAvatar(LobbyJogadorDTO jogador)
    {
        return string.IsNullOrWhiteSpace(jogador.CorHex)
            ? string.Empty
            : $"border-color:{jogador.CorHex};";
    }

    private static string ObterIniciais(string? nome)
    {
        if (string.IsNullOrWhiteSpace(nome))
            return "?";

        var partes = nome.Split(' ',
            StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (partes.Length == 1)
            return partes[0][0].ToString().ToUpperInvariant();

        return $"{partes[0][0]}{partes[^1][0]}".ToUpperInvariant();
    }

    private sealed class CelulaTabuleiro
    {
        public TabuleiroCasaDTO Casa { get; set; } = default!;
        public int Coluna { get; set; }
        public int Linha { get; set; }
    }
}
