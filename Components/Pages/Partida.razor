    {
        _modalXeroxAberto = false;
    }

    // Confirmou a compra da Xerox: compra, revela e abre o modal de seleção
    // para copiar o aluguel de outra propriedade.
    private async Task ConfirmarCompraXeroxAsync()
    {
        _modalXeroxAberto = false;

        if (_jogadorAtual is null) return;

        // efeito de bloqueio tem prioridade
        if (await VerificarBloqueioCompraAsync())
            return;

        try
        {
            var r = await AcaoCasaService.ComprarXeroxAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
            await TocarSomAsync("compra");
            _msgSimulacao = r.Mensagem;

            // posição da Xerox = posição atual do jogador (onde ele caiu)
            var posXerox = _estadoJogador?.PosicaoAtual ?? _dadosCasa?.Posicao ?? 0;

            await RecarregarAsync();

            // monta a lista de copiáveis e abre o modal de seleção
            _itensSelecao = await AcaoCasaService.ListarCopiaveisXeroxAsync(IdPartida, posXerox);
            _selecaoTitulo = "Xerox — copiar aluguel";
            _selecaoSubtitulo = "Escolha a propriedade cujo aluguel será copiado.";
            _selecaoTextoBotao = "Copiar aluguel";
            _selecaoFiltro = "jogadores"; // só propriedades compradas (sem banco); inclui as suas
            _modoSelecao = "xerox";

            _msgSimulacao = $"Xerox comprada (pos {posXerox}). {_itensSelecao.Count} propriedade(s) para copiar.";
            StateHasChanged();

            if (_modalSelecao is not null)
            {
                await _modalSelecao.AbrirAsync();
            }
            else
            {
                _msgSimulacao = "Xerox comprada, mas o modal de seleção não está disponível (ref nula).";
                StateHasChanged();
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
            StateHasChanged();
        }
    }

    private async Task OnPropriedadeSelecionadaXerox(BancoImobiliario.Models.DTOs.Jogo.PropriedadeSelecionavelDTO escolha)
    {
        if (_jogadorAtual is null) return;

        // Efeito "escolher casa": move o jogador para a casa escolhida (encerra a jogada).
        if (_modoSelecao == "efeito_casa")
        {
            _modoSelecao = "";
            try
            {
                await AcaoCasaService.MoverParaCasaAsync(IdPartida, _jogadorAtual.IdPartidaJogador, escolha.Posicao);
                _msgSimulacao = $"Você foi levado para a casa {escolha.Posicao}.";
                await RecarregarAsync();
            }
            catch (Exception ex)
            {
                _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
            }
            StateHasChanged();
            return;
        }

        // Efeito "pegar do banco": a cidade escolhida vira do jogador (de graça).
        if (_modoSelecao == "efeito_pegar_banco")
        {
            _modoSelecao = "";
            try
            {
                var nome = await AcaoCasaService.PegarPropriedadeBancoAsync(
                    IdPartida, _jogadorAtual.IdPartidaJogador, escolha.PartidaTabuleiroId);
                _msgSimulacao = $"Você pegou {nome} do banco!";
                await TocarSomEfeitoAsync("bom");
                await RecarregarAsync();
            }
            catch (Exception ex)
            {
                _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
            }
            StateHasChanged();
            return;
        }

        // Efeito "roubar": a propriedade escolhida muda para o jogador.
        if (_modoSelecao == "efeito_roubar")
        {
            _modoSelecao = "";
            try
            {
                var nome = await AcaoCasaService.RoubarPropriedadeAsync(
                    IdPartida, _jogadorAtual.IdPartidaJogador, escolha.PartidaTabuleiroId);
                _msgSimulacao = $"Você roubou {nome} de {escolha.NomeProprietario}!";
                await TocarSomEfeitoAsync("bom");
                await RecarregarAsync();
            }
            catch (Exception ex)
            {
                _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
            }
            StateHasChanged();
            return;
        }

        // Padrão: Xerox (copiar aluguel).
        _modoSelecao = "";
        try
        {
            var aluguel = await AcaoCasaService.AplicarCopiaXeroxAsync(
                IdPartida, _jogadorAtual.IdPartidaJogador, escolha.PartidaTabuleiroId);

            _msgSimulacao = $"Aluguel copiado de {escolha.Nome}: R$ {aluguel:N2}.";
            await RecarregarAsync();
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }

        StateHasChanged();
    }

