                await AcaoCasaService.ProcessarInicioVezPrisaoAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
                await Task.Delay(900);

                await PartidaService.PassarVezAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
                await RecarregarAsync();
                StateHasChanged();

                if (await VerificarPrisaoVezAsync())
                    return true;

                await VerificarTurnoBotAsync();
                return true;
            }
            catch (Exception ex)
            {
                _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
                StateHasChanged();
                return false;
            }
        }

        // ----- HUMANO preso: fica na vez, mostra o contador; finaliza quando quiser -----
        _prisaoNome = "Você está preso!";
        if (_estadoJogador.TurnosPreso >= 2)
            _prisaoFrase = $"Você ainda tem {_estadoJogador.TurnosPreso} rodadas preso. Não pode jogar o dado, mas pode administrar suas propriedades antes de finalizar.";
        else // == 1
            _prisaoFrase = "Você será solto na próxima! Esta é sua última rodada preso. Não pode jogar o dado, mas pode administrar suas propriedades antes de finalizar.";

        _prisaoRodadas = _estadoJogador.TurnosPreso;
        _rolandoDadoPrisao = false;
        _prisaoModoContador = true; // usa layout de contador (sem "N rodada(s) preso" redundante)
        _estaPresoNestaVez = true;
        _modalPrisaoAberto = true;
        StateHasChanged();

        return false; // não consome a vez automaticamente; o humano finaliza
    }

    // O jogador da vez é quem está com o turno ativo (não AguardandoVez).
    // Se ninguém estiver ativo, cai no primeiro da ordem.
    private void DefinirJogadorDaVez()
    {
        if (_lobby is null) return;

        var ativos = _lobby.Jogadores
            .Where(j => j.IdStatusJogador == (int)StatusJogadorPartida.Jogando)
            .OrderBy(j => j.OrdemTurno ?? 99)
            .ToList();

        if (ativos.Count == 0)
        {
            _jogadorAtual = _lobby.Jogadores
                .Where(j => j.TipoJogador == (int)TipoJogadorPartida.Humano)
                .OrderBy(j => j.OrdemTurno ?? 99)
                .FirstOrDefault();
            _vezDe = _jogadorAtual;
            return;
        }

        // Quem está com turno ativo? Precisamos do EstadoTurno real (entidade),
        // que não vem no LobbyJogadorDTO. Usamos o _estadoJogador já carregado
        // e, na ausência, o primeiro da ordem. A definição precisa do estado de
        // cada jogador, então buscamos via posições (que trazem EstadoTurno).
        var vezId = _posicoesJogadores
            .Where(p => p.EstadoTurno != (int)EstadoTurnoJogador.AguardandoVez)
            .OrderBy(p => p.OrdemTurno ?? 99)
            .Select(p => (int?)p.IdPartidaJogador)
            .FirstOrDefault();

        _vezDe = vezId.HasValue
            ? ativos.FirstOrDefault(j => j.IdPartidaJogador == vezId.Value) ?? ativos.First()
            : ativos.First();

        // Tela compartilhada (local): "seus dados" mostra o jogador da vez.
        _jogadorAtual = _vezDe;
    }

    private void RemapearCelulas()
    {
        _celulas = new List<CelulaTabuleiro>();

        foreach (var casa in _casas)
        {
            var pos = _posicaoLayout.TryGetValue(casa.Posicao, out var p) ? p : (Linha: 0, Coluna: 0);

            _celulas.Add(new CelulaTabuleiro
            {
                Casa = casa,
                Coluna = pos.Coluna,
                Linha = pos.Linha
            });
        }
    }

    private async Task RecarregarAsync()
    {
        // Validação de início de vez: revoga Business de quem não tem mais
        // todas as companhias (cobre roubo/perda futura de casas).
        try
        {
            var avisos = await AcaoCasaService.RevalidarBusinessAsync(IdPartida);
            if (avisos.Count > 0)
                _avisoBusiness = string.Join(" ", avisos);
        }
        catch
        {
            // não bloqueia o recarregamento se a validação falhar
        }

        _casas = await PartidaService.ObterTabuleiroPartidaAsync(IdPartida);
        _lobby = await PartidaService.ObterLobbyAsync(IdPartida);

        await CarregarPosicoesAsync();
        DefinirJogadorDaVez();

        if (_jogadorAtual is not null)
            _estadoJogador = await AcaoCasaService.ObterJogadorAsync(IdPartida, _jogadorAtual.IdPartidaJogador);

        RecalcularGruposCompletos();
        await CarregarEfeitosAtivosAsync();
        RecalcularPropriedades();
        RemapearCelulas();
    }

    // Carrega as posições de todos os jogadores ativos para desenhar os peões.
    private async Task CarregarPosicoesAsync()
    {
        _posicoesJogadores = await PartidaService.ObterPosicoesJogadoresAsync(IdPartida);
    }

    // Posições dos jogadores são carregadas via serviço em CarregarPosicoesAsync.

    private void RecalcularPropriedades()
    {
        if (_jogadorAtual is null)
        {
            _minhasPropriedades = new();
            _qtdPropriedades = 0;
            return;
        }

        var meuId = _jogadorAtual.IdPartidaJogador;
        _minhasPropriedades = _casas.Where(c => c.ProprietarioId == meuId).ToList();
        _qtdPropriedades = _minhasPropriedades.Count;
    }

    private async Task CarregarEfeitosAtivosAsync()
    {
        if (_jogadorAtual is null)
        {
            _efeitosAtivos = new();
            return;
        }

        try
        {
            _efeitosAtivos = await AcaoCasaService.ListarEfeitosAtivosAsync(
                IdPartida, _jogadorAtual.IdPartidaJogador);
        }
        catch
        {
            _efeitosAtivos = new();
        }
    }

    private void RecalcularGruposCompletos()
    {
        _gruposCompletos = new HashSet<int>();

        if (_jogadorAtual is null)
            return;

        var meuId = _jogadorAtual.IdPartidaJogador;

        var porGrupo = _casas
            .Where(c => c.GrupoId is not null)
            .GroupBy(c => c.GrupoId!.Value);

        foreach (var grupo in porGrupo)
        {
            var total = grupo.Count();
            var meus = grupo.Count(c => c.ProprietarioId == meuId);

            if (total > 0 && meus == total)
                _gruposCompletos.Add(grupo.Key);
        }
    }

    private async Task ExecutarSimulacaoAsync()
    {
        _msgSimulacao = null;

        if (_jogadorAtual is null)
        {
            _msgSimulacao = "Nenhum jogador identificado.";
            return;
        }

        if (_casaSimulada is null)
        {
            _msgSimulacao = "Informe o número da casa.";
            return;
        }

        var posicao = _casaSimulada.Value;

        if (_casas.All(c => c.Posicao != posicao))
        {
            _msgSimulacao = $"A casa {posicao} não existe neste tabuleiro.";
            return;
        }

        try
        {
            await AcaoCasaService.DefinirPosicaoAsync(IdPartida, _jogadorAtual.IdPartidaJogador, posicao);

            var resultado = await AcaoCasaService.AoCairNaCasaAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
            _msgSimulacao = resultado.Mensagem;
            _ultimaAcaoCasa = resultado.Acao;

            var exigeResolucao = resultado.Acao is TipoAcaoCasa.PagouAluguel or TipoAcaoCasa.PagouImposto;
            await AcaoCasaService.DefinirEstadoTurnoAsync(
                IdPartida, _jogadorAtual.IdPartidaJogador,
                exigeResolucao
                    ? BancoImobiliario.Models.Enums.EstadoTurnoJogador.ResolvendoCasa
                    : BancoImobiliario.Models.Enums.EstadoTurnoJogador.TurnoConcluido);

            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, posicao, _jogadorAtual.IdPartidaJogador, _debug);

            await RecarregarAsync();

            // Companhia normal sem dono -> modal de compra de companhia.
            // Internet -> compra obrigatória + dado do aluguel.
            // Caso contrário -> modal central da casa (atalho).
            if (resultado.Acao == TipoAcaoCasa.PodeComprarCompanhia)
            {
                try
                {
                    var dadosComp = await AcaoCasaService.ObterDadosCompraCompanhiaAsync(IdPartida, _jogadorAtual.IdPartidaJogador, _debug);
                    if (_modalCompanhia is not null)
                        await _modalCompanhia.AbrirAsync(dadosComp);
                }
                catch
                {
                    AbrirModalCasa();
                }
            }
            else if (resultado.Acao == TipoAcaoCasa.PodeComprarInternet)
            {
                await ResolverInternetAsync();
            }
            else if (resultado.Acao == TipoAcaoCasa.PodeComprarBusiness)
            {
                try
                {
                    var rb = await AcaoCasaService.AvaliarBusinessAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
                    if (rb.PodeComprar)
                    {
                        _businessNome = rb.Nome;
                        _businessAluguel = rb.AluguelSomado;
                        _modalBusinessAberto = true;
                    }
                    else
                    {
                        AbrirModalCasa();
                    }
                }
                catch
                {
                    AbrirModalCasa();
                }
            }
            else if (resultado.Acao == TipoAcaoCasa.PodeComprarXerox)
            {
                await ResolverXeroxAsync();
            }
            else if (resultado.Acao == TipoAcaoCasa.PagouImposto)
            {
                await ResolverImpostoAsync();
            }
            else if (resultado.Acao == TipoAcaoCasa.FoiPreso)
            {
                await ResolverPrisaoAsync();
            }
            else if (resultado.Acao == TipoAcaoCasa.Efeito)
            {
                await ResolverEfeitoNaTelaAsync();
            }
            else
            {
                _msgSimulacao = $"Caiu em {resultado.Mensagem} (ação: {resultado.Acao}, tipo casa: {resultado.TipoCasaId}).";
                AbrirModalCasa();
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private async Task InspecionarCasaAsync(int posicao)
    {
        if (_jogadorAtual is null)
            return;

        try
        {
            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, posicao, _jogadorAtual.IdPartidaJogador, _debug);
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    private void LimparCasa()
    {
        _dadosCasa = null;
    }

    // Verifica o bloqueio de compra (efeito guardado). Se ativo, NÃO consome:
    // apenas marca que o jogador tentou comprar (será removido ao finalizar a
    // jogada) e mostra o modal. Enquanto o jogador estiver na casa, toda tentativa
    // de compra é bloqueada. Se ele nunca clicar em comprar, o efeito permanece.
    private async Task<bool> VerificarBloqueioCompraAsync()
    {
        if (_jogadorAtual is null) return false;

        var temBloqueio = await AcaoCasaService.TemEfeitoAtivoAsync(
            IdPartida, _jogadorAtual.IdPartidaJogador, AcaoCasaService.EF_BLOQUEIO_COMPRA);

        if (!temBloqueio) return false;

        // marca que houve tentativa de compra com bloqueio ativo (consome ao finalizar)
        _tentouComprarBloqueado = true;

        // fecha qualquer modal de compra aberto
        _modalCasaAberto = false;
        _modalBusinessAberto = false;
        _modalXeroxAberto = false;
        if (_modalCompanhia is not null)
            _modalCompanhia.Fechar();

        // modal dedicado avisando o bloqueio
        _modalCompraBloqueadaAberto = true;
        StateHasChanged();
        return true;
    }

    private void FecharModalCompraBloqueada() => _modalCompraBloqueadaAberto = false;

    private async Task ComprarAsync()
    {
        if (_jogadorAtual is null || _dadosCasa is null)
            return;

        // efeito de bloqueio tem prioridade
        if (await VerificarBloqueioCompraAsync())
            return;

        try
        {
            await AcaoCasaService.ComprarPropriedadeAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
            await TocarSomAsync("compra");

            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(IdPartida, _dadosCasa.Posicao, _jogadorAtual.IdPartidaJogador, _debug);
            await RecarregarAsync();
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

    // ========================================
    // VISIBILIDADE / ESTADO DE TURNO
    // ========================================

    private BancoImobiliario.Models.Enums.EstadoTurnoJogador EstadoAtual
        => (BancoImobiliario.Models.Enums.EstadoTurnoJogador)(_estadoJogador?.EstadoTurno ?? 0);

    private bool PodeJogarDado
        => EstadoAtual == BancoImobiliario.Models.Enums.EstadoTurnoJogador.AguardandoDado
           && !_estaPresoNestaVez; // preso não rola o dado

    private bool PodePagar
    {
        get
        {
            if (EstadoAtual != BancoImobiliario.Models.Enums.EstadoTurnoJogador.ResolvendoCasa)
                return false;

            return _ultimaAcaoCasa == TipoAcaoCasa.PagouAluguel
                || _ultimaAcaoCasa == TipoAcaoCasa.PagouImposto;
        }
    }

    // Preso pode finalizar (cumprir a rodada); ou finaliza normal quando PodeFinalizar.
    private bool PodeFinalizar
        => _estaPresoNestaVez || (_estadoJogador?.PodeFinalizar ?? false);

    // ========================================
    // HANDLERS DE TURNO
    // ========================================

    private async Task JogarDadoAsync()
    {
        if (_estadoJogador is null || !PodeJogarDado) return;

        _tituloDado = $"Vez de {_jogadorAtual?.NomeJogador}";

        if (_dadoModal is not null)
            await _dadoModal.AbrirAsync();
    }

    // Chamado pelo DadoModal ao "Parar": rola no servidor.
    // Se estamos definindo o aluguel da Internet, sorteia o dado da config
    // (não move o peão). Caso contrário, é o dado de movimento do turno.
    private async Task<int> RolarDadoTurnoNoServidorAsync()
    {
        // Dados que NÃO movem o peão (definem valor/rodadas): sorteia da config.
        if (_rolandoDadoInternet || _rolandoDadoImposto || _rolandoDadoPrisao || _rolandoDadoEfeito)
        {
            return await AcaoCasaService.SortearDadoConfigAsync(IdPartida);
        }

        var r = await AcaoCasaService.RolarDadoTurnoAsync(IdPartida, _estadoJogador!.IdPartidaJogador);
        _resultadoTurno = r;
        return r.ValorDado;
    }

    // Chamado pelo DadoModal ao "Confirmar".
    private async Task OnDadoTurnoConfirmado(int valor)
    {
        // Se este lançamento define o aluguel da Internet, aplica e encerra o fluxo.
        if (_rolandoDadoInternet)
        {
            _rolandoDadoInternet = false;

            if (_jogadorAtual is not null)
            {
                try
                {
                    var aluguel = await AcaoCasaService.AplicarAluguelInternetAsync(
                        IdPartida, _jogadorAtual.IdPartidaJogador, valor);

                    _msgSimulacao = valor <= 0
                        ? $"Você tirou {valor}: o aluguel ficou em R$ 0,00 (sem reembolso da compra)."
                        : $"Você tirou {valor}: aluguel definido em R$ {aluguel:N2} ({valor} × {_fatorInternet}).";
                }
                catch (Exception ex)
                {
                    _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
                }
            }

            await RecarregarAsync();
            StateHasChanged();
            return;
        }

        // Imposto por dado: valor = dado x fator.
        if (_rolandoDadoImposto)
        {
            _rolandoDadoImposto = false;

            if (_jogadorAtual is not null)
            {
                _impostoValor = AcaoCasaService.CalcularImpostoDado(valor, _fatorImposto);
                _msgSimulacao = $"Você tirou {valor}: imposto de R$ {_impostoValor:N2} ({valor} × {_fatorImposto}).";
                _modalImpostoAberto = true; // mostra o valor e o botão de pagar
            }

            StateHasChanged();
            return;
        }

        // Prisão por dado: rodadas = valor do dado.
        if (_rolandoDadoPrisao)
        {
            _rolandoDadoPrisao = false;

            if (_jogadorAtual is not null)
            {
                try
                {
                    _prisaoRodadas = await AcaoCasaService.AplicarPrisaoDadoAsync(
                        IdPartida, _jogadorAtual.IdPartidaJogador, valor);
                    _msgSimulacao = $"Você tirou {valor}: preso por {_prisaoRodadas} rodada(s).";
                }
                catch (Exception ex)
                {
                    _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
                }
                _modalPrisaoAberto = true;
            }

            await RecarregarAsync();
            StateHasChanged();
            return;
        }

        // Efeito de movimento: avança/volta N casas (dado x fator).
        if (_rolandoDadoEfeito)
        {
            _rolandoDadoEfeito = false;

            if (_jogadorAtual is not null)
            {
                try
                {
                    var avancar = _efeitoAcaoId != 20; // 20 = Volte; senão Avance
                    var novaPos = await AcaoCasaService.AplicarMovimentoEfeitoAsync(
                        IdPartida, _jogadorAtual.IdPartidaJogador, valor, _efeitoFator, avancar);

                    _msgSimulacao = $"Você {(avancar ? "avançou" : "voltou")} {valor} casa(s) → casa {novaPos}.";

                    await RecarregarAsync();

                    // Se o efeito resolve a casa de destino, dispara a queda nela.
                    if (_efeitoAplicaCasaApos)
                    {
                        var resCasa = await AcaoCasaService.AoCairNaCasaAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
                        _resultadoTurno = new AcaoCasaService.ResultadoTurno(
                            valor, _estadoJogador?.PosicaoAtual ?? novaPos, novaPos, false, 0m, resCasa);

                        _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(
                            IdPartida, novaPos, _jogadorAtual.IdPartidaJogador, _debug);

                        await RecarregarAsync();
                        await AbrirModalPosCasaAsync(); // resolve a casa de destino (aluguel, compra, etc.)
                    }
                    else
                    {
                        _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(
                            IdPartida, novaPos, _jogadorAtual.IdPartidaJogador, _debug);
                    }
                }
                catch (Exception ex)
                {
                    _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
                }
            }

            StateHasChanged();
            return;
        }

        if (_resultadoTurno is not null)
        {
            _ultimaAcaoCasa = _resultadoTurno.Casa.Acao;
            _msgSimulacao = _resultadoTurno.Casa.Mensagem;
        }

        if (_jogadorAtual is not null)
            _dadosCasa = await AcaoCasaService.MontarDadosCasaAsync(
                IdPartida, _resultadoTurno?.PosicaoFinal ?? _estadoJogador!.PosicaoAtual,
                _jogadorAtual.IdPartidaJogador, _debug);

        await RecarregarAsync();

        // Encadeamento dos modais: bônus de volta primeiro (se houve), depois a casa.
        if (_resultadoTurno is { CompletouVolta: true, BonusVolta: > 0 })
        {
            _bonusVoltaValor = _resultadoTurno.BonusVolta;
            _modalBonusAutoFechar = false;
            _modalBonusAberto = true;   // ao fechar, abre o modal seguinte
            await TocarSomAsync("bonus");
        }
        else
        {
            await AbrirModalPosCasaAsync();
        }

        StateHasChanged();
    }

    // Decide qual modal abrir ao cair: companhia normal sem dono -> modal de
    // compra de companhia; Internet -> compra automática + dado do aluguel;
    // caso contrário -> modal central da casa (atalho).
    private async Task AbrirModalPosCasaAsync()
    {
        var acao = _resultadoTurno?.Casa.Acao;

        if (acao == TipoAcaoCasa.PodeComprarCompanhia && _jogadorAtual is not null)
        {
            try
            {
                var dados = await AcaoCasaService.ObterDadosCompraCompanhiaAsync(IdPartida, _jogadorAtual.IdPartidaJogador, _debug);
                if (_modalCompanhia is not null)
                    await _modalCompanhia.AbrirAsync(dados);
                return;
            }
            catch
            {
                // se falhar, cai no modal padrão
            }
        }

        if (acao == TipoAcaoCasa.PodeComprarInternet && _jogadorAtual is not null)
        {
            await ResolverInternetAsync();
            return;
        }

        if (acao == TipoAcaoCasa.PodeComprarBusiness && _jogadorAtual is not null)
        {
            try
            {
                var r = await AcaoCasaService.AvaliarBusinessAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
                if (r.PodeComprar)
                {
                    _businessNome = r.Nome;
                    _businessAluguel = r.AluguelSomado;
                    _modalBusinessAberto = true;
                    StateHasChanged();
                    return;
                }
            }
            catch
            {
                // se falhar, cai no modal padrão
            }
        }

        if (acao == TipoAcaoCasa.PodeComprarXerox && _jogadorAtual is not null)
        {
            await ResolverXeroxAsync();
            return;
        }

        if (acao == TipoAcaoCasa.PagouImposto && _jogadorAtual is not null)
        {
            await ResolverImpostoAsync();
            return;
        }

        if (acao == TipoAcaoCasa.FoiPreso && _jogadorAtual is not null)
        {
            await ResolverPrisaoAsync();
            return;
        }

        if (acao == TipoAcaoCasa.Efeito && _jogadorAtual is not null)
        {
            await ResolverEfeitoNaTelaAsync();
            return;
        }

        AbrirModalCasa();
    }

    // ===== EFEITO (Fatia 1) =====
    private async Task ResolverEfeitoNaTelaAsync()
    {
        if (_jogadorAtual is null) return;

        try
        {
            var r = await AcaoCasaService.ResolverEfeitoAsync(IdPartida, _jogadorAtual.IdPartidaJogador);

            // imune ao efeito: nem sorteia, mostra modal de imunidade
            if (r.Imune)
            {
                await RecarregarAsync();
                await AbrirModalImunidadeAsync("Imune a efeitos!", r.Frase ?? "Você não foi afetado pelo efeito!", "bi-shield-shaded");
                return;
            }

            _efeitoFrase = r.Frase ?? "Efeito!";
            _efeitoImagem = r.Imagem;
            _efeitoAcaoId = r.AcaoEfeitoId;
            _efeitoFator = (int)r.FatorMultiplicador;
            _efeitoAplicaCasaApos = r.AplicarCasaAposEfeito;
            _msgSimulacao = r.Mensagem;

            // som conforme o tom do efeito (bom/ruim/neutro)
            await TocarSomEfeitoAsync(r.Tom);

            await RecarregarAsync();

            switch (r.AcaoTela)
            {
                case AcaoCasaService.AcaoTelaEfeito.Nada:
                    // instantâneo (ganhe/perca/teleporte) — só mostra a frase
                    _modalEfeitoAberto = true;
                    StateHasChanged();
                    break;

                case AcaoCasaService.AcaoTelaEfeito.RolarDado:
                    // avançar/voltar N casas — rola o dado
                    _rolandoDadoEfeito = true;
                    _tituloDado = r.AcaoEfeitoId == 20 ? "Role para voltar casas!" : "Role para avançar casas!";
                    StateHasChanged();
                    if (_dadoModal is not null)
                        await _dadoModal.AbrirAsync();
                    break;

                case AcaoCasaService.AcaoTelaEfeito.EscolherCasa:
                    // escolhe a casa de destino
                    _itensSelecao = await AcaoCasaService.ListarCasasTabuleiroAsync(
                        IdPartida, _estadoJogador?.PosicaoAtual ?? 0);
                    _selecaoTitulo = "Escolha para onde ir";
                    _selecaoSubtitulo = "Você será levado até a casa escolhida (a jogada encerra).";
                    _selecaoTextoBotao = "Ir para esta casa";
                    _selecaoFiltro = "todos";
                    _modoSelecao = "efeito_casa";
                    StateHasChanged();
                    if (_modalSelecao is not null)
                        await _modalSelecao.AbrirAsync();
                    break;

                case AcaoCasaService.AcaoTelaEfeito.PegarBanco:
                    // escolhe uma cidade sem dono do banco
                    _itensSelecao = await AcaoCasaService.ListarCidadesBancoAsync(IdPartida);
                    if (_itensSelecao.Count == 0)
                    {
                        _efeitoFrase = "Não há cidades disponíveis no banco para pegar.";
                        _modalEfeitoAberto = true;
                        StateHasChanged();
                        break;
                    }
                    _selecaoTitulo = "Pegue uma propriedade do banco";
                    _selecaoSubtitulo = "Escolha uma cidade sem dono. Ela será sua, de graça!";
                    _selecaoTextoBotao = "Pegar esta propriedade";
                    _selecaoFiltro = "banco";
                    _modoSelecao = "efeito_pegar_banco";
                    StateHasChanged();
                    if (_modalSelecao is not null)
                        await _modalSelecao.AbrirAsync();
                    break;

                case AcaoCasaService.AcaoTelaEfeito.Roubar:
                    // escolhe uma propriedade de outro jogador
                    _itensSelecao = await AcaoCasaService.ListarPropriedadesJogadoresAsync(
                        IdPartida, _jogadorAtual.IdPartidaJogador);
                    if (_itensSelecao.Count == 0)
                    {
                        _efeitoFrase = "Não há propriedades de outros jogadores para roubar.";
                        _modalEfeitoAberto = true;
                        StateHasChanged();
                        break;
                    }
                    _selecaoTitulo = "Roube uma propriedade";
                    _selecaoSubtitulo = "Escolha uma propriedade de outro jogador para roubar (vai com casas e hotéis).";
                    _selecaoTextoBotao = "Roubar esta propriedade";
                    _selecaoFiltro = "jogadores";
                    _modoSelecao = "efeito_roubar";
                    StateHasChanged();
                    if (_modalSelecao is not null)
                        await _modalSelecao.AbrirAsync();
                    break;

                case AcaoCasaService.AcaoTelaEfeito.TrocarJogador:
                    {
                        var outros = await AcaoCasaService.ListarJogadoresParaTrocaAsync(
                            IdPartida, _jogadorAtual.IdPartidaJogador);

                        if (outros.Count == 0)
                        {
                            _efeitoFrase = "Não há outro jogador para trocar de casa.";
                            _modalEfeitoAberto = true;
                            StateHasChanged();
                            break;
                        }

                        _jogadoresTroca = outros;

                        if (outros.Count == 1)
                        {
                            // só um outro jogador: confirmação direta
                            _trocaAlvo = outros[0];
                            _modalTrocaConfirmarAberto = true;
                        }
                        else
                        {
                            // vários: escolher com quem trocar
                            _modalTrocaEscolhaAberto = true;
                        }
                        StateHasChanged();
                    }
                    break;

                case AcaoCasaService.AcaoTelaEfeito.TrocarGrupo:
                    {
                        _cidadesGrupo = await AcaoCasaService.ListarCidadesComGrupoAsync(IdPartida);
                        _gruposTabuleiro = await AcaoCasaService.ListarGruposTabuleiroAsync(IdPartida);

                        if (_cidadesGrupo.Count == 0 || _gruposTabuleiro.Count == 0)
                        {
                            _efeitoFrase = "Não há cidades com grupo ou grupos disponíveis para trocar.";
                            _modalEfeitoAberto = true;
                            StateHasChanged();
                            break;
                        }

                        _trocaGrupoCidade = null;
                        _trocaGrupoNovo = null;
                        _modalTrocaGrupoAberto = true;
                        StateHasChanged();
                    }
                    break;

                default:
                    // não implementado nesta fatia: mostra a frase e segue
                    _modalEfeitoAberto = true;
                    StateHasChanged();
                    break;
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
            StateHasChanged();
        }
    }

