    // Internet: compra obrigatória automática (se há saldo). Se comprou, abre o
    // dado para definir o aluguel. Se pulou (sem saldo), só informa e segue.
    private async Task ResolverInternetAsync()
    {
        if (_jogadorAtual is null) return;

        // efeito de bloqueio tem prioridade: nem a compra obrigatória ocorre
        if (await VerificarBloqueioCompraAsync())
            return;

        try
        {
            var r = await AcaoCasaService.ComprarInternetAsync(IdPartida, _jogadorAtual.IdPartidaJogador);
            _msgSimulacao = r.Mensagem;

            if (r.Comprou)
            {
                await TocarSomAsync("compra");
                _fatorInternet = r.FatorMultiplicador;
                await RecarregarAsync();

                // Abre o dado para DEFINIR o aluguel (segundo lançamento no turno).
                _rolandoDadoInternet = true;
                _tituloDado = "Role para definir o aluguel!";
                StateHasChanged();

                if (_dadoModal is not null)
                    await _dadoModal.AbrirAsync();
            }
            else
            {
                // Não tinha saldo: compra pulada, mostra o modal informativo da casa.
                await RecarregarAsync();
                AbrirModalCasa();
            }
        }
        catch (Exception ex)
        {
            _msgSimulacao = ex.InnerException?.Message ?? ex.Message;
        }
    }

