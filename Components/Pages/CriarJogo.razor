    private int _maxFronteirasTabuleiroAtual = 0; // Limite dinâmico

    private bool _permitirCompanhias = true;
    private bool _permitirEfeitos = true;
    private bool _permitirEspeciais = true;
    private bool _permitirImpostos = true;
    private bool _permitirPrisao = true;

    private int _qtdCompanhias;
    private int _qtdEfeitos;
    private int _qtdEspeciais;
    private int _qtdImpostos;
    private int _qtdPrisao;

    private int _maxCompanhias;
    private int _maxEfeitos;
    private int _maxEspeciais;
    private int _maxImpostos;
    private int _maxPrisao;
    private int _maxGrupos;

    private string CodigoSalaDisplay =>
        string.IsNullOrWhiteSpace(_configuracao.CodigoSala)
            ? "Gerado ao criar"
            : _configuracao.CodigoSala;

    private readonly List<OpcaoSelect> _tiposJogo = new()
    {
        new((int)TipoJogoConfiguracao.Solo, EnumDescricaoHelper.ObterDescricao(TipoJogoConfiguracao.Solo)),
        new((int)TipoJogoConfiguracao.LocalMultiplayer, EnumDescricaoHelper.ObterDescricao(TipoJogoConfiguracao.LocalMultiplayer)),
        new((int)TipoJogoConfiguracao.Rede, EnumDescricaoHelper.ObterDescricao(TipoJogoConfiguracao.Rede))
    };

    private readonly List<OpcaoSelect> _dificuldades = new()
    {
        new((int)DificuldadeJogo.Facil, EnumDescricaoHelper.ObterDescricao(DificuldadeJogo.Facil)),
        new((int)DificuldadeJogo.Normal, EnumDescricaoHelper.ObterDescricao(DificuldadeJogo.Normal)),
        new((int)DificuldadeJogo.Dificil, EnumDescricaoHelper.ObterDescricao(DificuldadeJogo.Dificil)),
        new((int)DificuldadeJogo.Personalizada, EnumDescricaoHelper.ObterDescricao(DificuldadeJogo.Personalizada))
    };

    private readonly List<OpcaoSelect> _regrasFronteira = new()
    {
        new((int)RegraFronteiraJogo.DonoDeApenasUma, EnumDescricaoHelper.ObterDescricao(RegraFronteiraJogo.DonoDeApenasUma)),
        new((int)RegraFronteiraJogo.DonoDasDuas, EnumDescricaoHelper.ObterDescricao(RegraFronteiraJogo.DonoDasDuas))
    };

    private readonly List<OpcaoSelect> _tiposFinalizacao = new()
    {
        new((int)TipoFinalizacaoJogo.TodasPropriedadesCompradas, EnumDescricaoHelper.ObterDescricao(TipoFinalizacaoJogo.TodasPropriedadesCompradas)),
        new((int)TipoFinalizacaoJogo.NumeroVoltas, EnumDescricaoHelper.ObterDescricao(TipoFinalizacaoJogo.NumeroVoltas)),
        new((int)TipoFinalizacaoJogo.NumeroPropriedadesCompradas, EnumDescricaoHelper.ObterDescricao(TipoFinalizacaoJogo.NumeroPropriedadesCompradas)),
        new((int)TipoFinalizacaoJogo.SaldoAcumulado, EnumDescricaoHelper.ObterDescricao(TipoFinalizacaoJogo.SaldoAcumulado)),
        new((int)TipoFinalizacaoJogo.TempoMinutos, EnumDescricaoHelper.ObterDescricao(TipoFinalizacaoJogo.TempoMinutos)),
        new((int)TipoFinalizacaoJogo.Ilimitado, EnumDescricaoHelper.ObterDescricao(TipoFinalizacaoJogo.Ilimitado))
    };

    private readonly List<OpcaoSelect> _criteriosVitoria = new()
    {
        new((int)VenceQuemJogo.MaisPropriedades, EnumDescricaoHelper.ObterDescricao(VenceQuemJogo.MaisPropriedades)),
        new((int)VenceQuemJogo.MaiorSaldoFinal, EnumDescricaoHelper.ObterDescricao(VenceQuemJogo.MaiorSaldoFinal)),
        new((int)VenceQuemJogo.MaiorSaldoTotal, EnumDescricaoHelper.ObterDescricao(VenceQuemJogo.MaiorSaldoTotal)),
        new((int)VenceQuemJogo.MaiorNumeroVoltas, EnumDescricaoHelper.ObterDescricao(VenceQuemJogo.MaiorNumeroVoltas)),
        new((int)VenceQuemJogo.PontuacaoIndividual, EnumDescricaoHelper.ObterDescricao(VenceQuemJogo.PontuacaoIndividual))
    };

    private bool ExibirSubcriterioFinalizacao =>
        (TipoFinalizacaoJogo)_configuracao.TipoFinalizacao is
            TipoFinalizacaoJogo.NumeroVoltas or
            TipoFinalizacaoJogo.NumeroPropriedadesCompradas or
            TipoFinalizacaoJogo.SaldoAcumulado or
            TipoFinalizacaoJogo.TempoMinutos;

    private string LabelSubcriterioFinalizacao =>
        (TipoFinalizacaoJogo)_configuracao.TipoFinalizacao switch
        {
            TipoFinalizacaoJogo.NumeroVoltas => "Quantidade de voltas",
            TipoFinalizacaoJogo.NumeroPropriedadesCompradas => "Quantidade de propriedades compradas",
            TipoFinalizacaoJogo.SaldoAcumulado => "Saldo acumulado alvo",
            TipoFinalizacaoJogo.TempoMinutos => "Tempo em minutos",
            _ => "Subcritério"
        };

    protected override async Task OnInitializedAsync()
    {
        await CarregarLimitesDoBancoAsync();
        await NovoAsync();
        _carregando = false;
    }

    private async Task CarregarLimitesDoBancoAsync()
    {
        try
        {
            _tabuleirosDisponiveis = await TabuleiroService.ObterTodosTabuleirosAsync();

            _maxCompanhias = await TabuleiroService.ObterQuantidadeTotalPorTipoAsync("companhias");
            _maxEfeitos = await TabuleiroService.ObterQuantidadeTotalPorTipoAsync("efeitos");
            _maxEspeciais = await TabuleiroService.ObterQuantidadeTotalPorTipoAsync("especiais");
            _maxImpostos = await TabuleiroService.ObterQuantidadeTotalPorTipoAsync("impostos");
            _maxPrisao = await TabuleiroService.ObterQuantidadeTotalPorTipoAsync("prisao");
            _maxGrupos = await TabuleiroService.ObterQuantidadeTotalPorTipoAsync("grupos_efeito");
        }
        catch (Exception ex)
        {
            _mensagemErro = "Erro ao buscar limites do tabuleiro: " + ex.Message;
        }
    }

    // Conta no banco quantas fronteiras reais aquele tabuleiro tem
    private async Task<int> ObterQtdFronteirasAsync(int idTabuleiro)
    {
        if (idTabuleiro <= 0) return 0;
        var fronteiras = await GerenciamentoService.ObterFronteirasAsync(idTabuleiro);
        return fronteiras?.Count ?? 0;
    }

    // Chamado sempre que o usuário muda o Tabuleiro no Dropdown
    private async Task OnTabuleiroChangedAsync(int novoId)
    {
        _configuracao.IdTabuleiro = novoId;
        _maxFronteirasTabuleiroAtual = await ObterQtdFronteirasAsync(novoId);

        if (_numeroFronteiras > _maxFronteirasTabuleiroAtual)
            _numeroFronteiras = _maxFronteirasTabuleiroAtual;
    }

    private async Task NovoAsync()
    {
        LimparMensagens();

        _configuracao = await ConfiguracaoService.CriarConfiguracaoPadraoAsync();

        _configuracao.CodigoSala = string.Empty;

        if (_configuracao.IdTabuleiro <= 0 && _tabuleirosDisponiveis.Any())
            _configuracao.IdTabuleiro = _tabuleirosDisponiveis.First().TabuleiroId;

        _maxFronteirasTabuleiroAtual = await ObterQtdFronteirasAsync(_configuracao.IdTabuleiro);

        if (_configuracao.TipoJogo <= 0)
            _configuracao.TipoJogo = (int)TipoJogoConfiguracao.Solo;

        if (_configuracao.Dificuldade <= 0)
            _configuracao.Dificuldade = (int)DificuldadeJogo.Normal;

        if (_configuracao.TipoFinalizacao <= 0)
            _configuracao.TipoFinalizacao = (int)TipoFinalizacaoJogo.NumeroVoltas;

        if (_configuracao.VenceQuem <= 0)
            _configuracao.VenceQuem = (int)VenceQuemJogo.MaiorSaldoTotal;

        if (_configuracao.RegraFronteira <= 0)
            _configuracao.RegraFronteira = (int)RegraFronteiraJogo.DonoDeApenasUma;

        _configuracao.StatusJogo = 1;

        _tabuleiroAleatorio = false;
        _numeroGrupos = 0;
        _numeroFronteiras = 0;

        _permitirCompanhias = true;
        _permitirEfeitos = true;
        _permitirEspeciais = true;
        _permitirImpostos = true;
        _permitirPrisao = true;

        _qtdCompanhias = 0;
        _qtdEfeitos = 0;
        _qtdEspeciais = 0;
        _qtdImpostos = 0;
        _qtdPrisao = 0;
    }

    private async Task SalvarAsync(EditContext editContext)
    {
        LimparMensagens();
        _salvando = true;

        try
        {
            PrepararCamposDependentes();

            if (!ValidarTela())
                return;

            var identificadorHost = await BrowserIdentificacaoService.ObterOuCriarIdentificadorAsync();
            var nomeHost = await BrowserIdentificacaoService.ObterNomeAsync();

            if (string.IsNullOrWhiteSpace(nomeHost))
            {
                nomeHost = "Jogador 1";
                await BrowserIdentificacaoService.SalvarNomeAsync(nomeHost);
            }

            // Cria a base da partida
            var resultado = await PartidaService.CriarPartidaAsync(
                _configuracao,
                nomeHost: nomeHost,
                identificadorHost: identificadorHost);

            try
            {
                // Cria as casas do tabuleiro
                await TabuleiroService.CriarTabuleiro(
                    resultado.IdPartida,
                    QtdCasasSelecionado,
                    _qtdEfeitos,
                    _qtdPrisao,
                    _qtdCompanhias,
                    _qtdEspeciais,
                    _qtdImpostos,
                    _configuracao.EfeitosAleatorios,
                    _numeroGrupos,
                    _configuracao.TabuleiroOculto,
                    _configuracao.ValorCompraAleatorio,
                    _configuracao.ValorAluguelAleatorio);

                // NOVO: Sorteia e salva as fronteiras da partida!
                await GerenciamentoService.SortearESalvarFronteirasPartidaAsync(
                    _configuracao.IdTabuleiro,
                    resultado.IdPartida,
                    _numeroFronteiras);
            }
            catch (Exception exTabuleiro)
            {
                _mensagemErro =
                    "A partida foi criada, mas houve uma falha ao montar o tabuleiro: "
                    + (exTabuleiro.InnerException?.Message ?? exTabuleiro.Message)
                    + " Revise as quantidades e tente novamente.";
                return;
            }

            NavigationManager.NavigateTo($"/jogo/lobby/{resultado.IdPartida}");
        }
        catch (Exception ex)
        {
            _mensagemErro = ex.InnerException?.Message ?? ex.Message;
        }
        finally
        {
            _salvando = false;
        }
    }

    private string EstiloProgresso(double valor, double min, double max)
    {
        if (max <= min) return "--progress: 0%;";

        var percent = (valor - min) / (max - min) * 100.0;
        percent = Math.Clamp(percent, 0, 100);

        return $"--progress: {percent.ToString(System.Globalization.CultureInfo.InvariantCulture)}%;";
    }

    // ========================================
    // ALEATORIZAÇÃO
    // ========================================

    private async Task GerarTudoAleatorioAsync()
    {
        LimparMensagens();
        var random = Random.Shared;

        if (_tabuleirosDisponiveis.Any())
        {
            var tabSorteado = _tabuleirosDisponiveis[random.Next(_tabuleirosDisponiveis.Count)];
            _configuracao.IdTabuleiro = tabSorteado.TabuleiroId;
            _maxFronteirasTabuleiroAtual = await ObterQtdFronteirasAsync(tabSorteado.TabuleiroId);
        }

        _configuracao.QtdJogadores = random.Next(2, 9);
        _configuracao.ValorInicial = random.Next(10, 51) * 100m;
        _configuracao.BonusVolta = random.Next(0, 6) * 100m;
        _configuracao.BonusAteVolta = _configuracao.BonusVolta > 0 ? random.Next(0, 21) : 0;

        var minDado = random.Next(_limiteGeralMinDado, _limiteGeralMaxDado);
        _configuracao.ValMinDado = minDado;
        _configuracao.ValMaxDado = random.Next(minDado + 1, _limiteGeralMaxDado + 1);

        _configuracao.QtdMaxCasas = random.Next(2, 7);
        _configuracao.MinCasasParaHotel = random.Next(1, _configuracao.QtdMaxCasas + 1);
        _configuracao.QtdMaxHoteis = random.Next(1, 3);
        _configuracao.RemoverCasasAposHotel = random.Next(0, 2) == 1;

        _configuracao.Dificuldade = random.Next(1, 4);

        _tabuleiroAleatorio = true;
        _configuracao.TabuleiroOculto = random.Next(0, 2) == 1;
        _numeroGrupos = _maxGrupos > 0 ? random.Next(0, _maxGrupos + 1) : 0;

        _numeroFronteiras = _maxFronteirasTabuleiroAtual > 0 ? random.Next(0, _maxFronteirasTabuleiroAtual + 1) : 0;

        _configuracao.RegraFronteira = random.Next(1, 3);

        _permitirCompanhias = true;
        _permitirEfeitos = true;
        _permitirEspeciais = true;
        _permitirImpostos = true;
        _permitirPrisao = true;

        _qtdCompanhias = _maxCompanhias > 0 ? random.Next(1, _maxCompanhias + 1) : 0;
        _qtdEfeitos = _maxEfeitos > 0 ? random.Next(1, _maxEfeitos + 1) : 0;
        _qtdEspeciais = _maxEspeciais > 0 ? random.Next(1, _maxEspeciais + 1) : 0;
        _qtdImpostos = _maxImpostos > 0 ? random.Next(1, _maxImpostos + 1) : 0;
        _qtdPrisao = _maxPrisao > 0 ? random.Next(1, _maxPrisao + 1) : 0;

        _configuracao.EfeitosAleatorios = true;
        _configuracao.NaoRepetirEfeitos = random.Next(0, 2) == 1;

        _configuracao.TipoFinalizacao = random.Next(1, 7);
        _configuracao.VenceQuem = random.Next(1, 6);

        if (ExibirSubcriterioFinalizacao)
            _configuracao.SubCriterioFinalizacao = random.Next(5, 31);

        if ((VenceQuemJogo)_configuracao.VenceQuem == VenceQuemJogo.PontuacaoIndividual)
        {
            _configuracao.PonderacaoPropriedades = random.Next(1, 11);
            _configuracao.PonderacaoVoltas = random.Next(1, 11);
            _configuracao.PonderacaoSaldoFinal = random.Next(1, 11);
            _configuracao.PonderacaoSaldoTotal = random.Next(1, 11);
        }

        _configuracao.HabilitarNegociacoes = random.Next(0, 2) == 1;
        _configuracao.HabilitarApostas = random.Next(0, 2) == 1;
        _configuracao.ValorAluguelAleatorio = random.Next(0, 2) == 1;
        _configuracao.ValorCompraAleatorio = random.Next(0, 2) == 1;
        _configuracao.PermitirSaldoNegativo = random.Next(0, 2) == 1;
        _configuracao.PresoBloqueiaAluguel = random.Next(0, 2) == 1;

        _configuracao.PercentualDevolucaoVenda = random.Next(0, 21) * 5;

        _mensagemSucesso = "Configuração aleatória completa gerada! Revise antes de criar.";
    }

    private async Task GerarTabuleiroAleatorioAsync()
    {
        LimparMensagens();
        var random = Random.Shared;

        if (_tabuleirosDisponiveis.Any())
        {
            var tabSorteado = _tabuleirosDisponiveis[random.Next(_tabuleirosDisponiveis.Count)];
            _configuracao.IdTabuleiro = tabSorteado.TabuleiroId;
            _maxFronteirasTabuleiroAtual = await ObterQtdFronteirasAsync(tabSorteado.TabuleiroId);
        }

        _tabuleiroAleatorio = true;
        _configuracao.TabuleiroOculto = random.Next(0, 2) == 1;

        _numeroGrupos = _maxGrupos > 0 ? random.Next(0, _maxGrupos + 1) : 0;

        _numeroFronteiras = _maxFronteirasTabuleiroAtual > 0 ? random.Next(0, _maxFronteirasTabuleiroAtual + 1) : 0;

        _configuracao.RegraFronteira = random.Next(1, 3);

        _permitirCompanhias = true;
        _permitirEfeitos = true;
        _permitirEspeciais = true;
        _permitirImpostos = true;
        _permitirPrisao = true;

        _qtdCompanhias = _maxCompanhias > 0 ? random.Next(1, _maxCompanhias + 1) : 0;
        _qtdEfeitos = _maxEfeitos > 0 ? random.Next(1, _maxEfeitos + 1) : 0;
        _qtdEspeciais = _maxEspeciais > 0 ? random.Next(1, _maxEspeciais + 1) : 0;
        _qtdImpostos = _maxImpostos > 0 ? random.Next(1, _maxImpostos + 1) : 0;
        _qtdPrisao = _maxPrisao > 0 ? random.Next(1, _maxPrisao + 1) : 0;

        _configuracao.EfeitosAleatorios = true;
        _configuracao.NaoRepetirEfeitos = random.Next(0, 2) == 1;

        _mensagemSucesso = "Tabuleiro aleatório gerado. Revise as regras antes de criar a partida.";
    }

    // ========================================
    // INPUT HANDLERS (sliders/steppers)
    // ========================================

    private void OnQtdJogadoresInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _configuracao.QtdJogadores = v;
    }

    private void AjustarJogadores(int delta)
    {
        var novo = _configuracao.QtdJogadores + delta;

        if (novo < 2) novo = 2;
        if (novo > 8) novo = 8;

        _configuracao.QtdJogadores = novo;
    }

    private void OnValorInicialInput(ChangeEventArgs e)
    {
        if (decimal.TryParse(e.Value?.ToString(), out var v))
            _configuracao.ValorInicial = v;
    }

    private void OnDadoMinInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;

        _configuracao.ValMinDado = v;
        if (_configuracao.ValMaxDado < v)
            _configuracao.ValMaxDado = v;
    }

    private void OnDadoMaxInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;

        if (v < _configuracao.ValMinDado)
            v = _configuracao.ValMinDado;

        _configuracao.ValMaxDado = v;
    }

    private void OnMaxCasasInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;

        _configuracao.QtdMaxCasas = v;
        if (_configuracao.MinCasasParaHotel > v)
            _configuracao.MinCasasParaHotel = v;
    }

    private void OnMinCasasHotelInput(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out var v)) return;

        if (v > _configuracao.QtdMaxCasas)
            v = _configuracao.QtdMaxCasas;

        _configuracao.MinCasasParaHotel = v;
    }

    private void OnMaxHoteisInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _configuracao.QtdMaxHoteis = v;
    }

    private void OnNumeroGruposInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _numeroGrupos = Math.Clamp(v, 0, _maxGrupos);
    }

    private void OnNumeroFronteirasInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _numeroFronteiras = Math.Clamp(v, 0, _maxFronteirasTabuleiroAtual);
    }

    private void OnPercentualDevolucaoInput(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out var v))
            _configuracao.PercentualDevolucaoVenda = v;
    }

    // ========================================
    // TIPOS DO TABULEIRO (toggle + stepper)
    // ========================================

    private void AlternarTipoTabuleiro(string key)
    {
        switch (key)
        {
            case "companhias": _permitirCompanhias = !_permitirCompanhias; break;
            case "efeitos": _permitirEfeitos = !_permitirEfeitos; break;
            case "especiais": _permitirEspeciais = !_permitirEspeciais; break;
            case "impostos": _permitirImpostos = !_permitirImpostos; break;
            case "prisao": _permitirPrisao = !_permitirPrisao; break;
        }
    }

    private void AjustarQtdTipo(string key, int delta)
    {
        switch (key)
        {
            case "companhias": _qtdCompanhias = Math.Clamp(_qtdCompanhias + delta, 0, _maxCompanhias); break;
            case "efeitos": _qtdEfeitos = Math.Clamp(_qtdEfeitos + delta, 0, _maxEfeitos); break;
            case "especiais": _qtdEspeciais = Math.Clamp(_qtdEspeciais + delta, 0, _maxEspeciais); break;
            case "impostos": _qtdImpostos = Math.Clamp(_qtdImpostos + delta, 0, _maxImpostos); break;
            case "prisao": _qtdPrisao = Math.Clamp(_qtdPrisao + delta, 0, _maxPrisao); break;
        }
    }

