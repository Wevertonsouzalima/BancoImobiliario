    private string? _mensagemSucesso;
    private string? _mensagemErro;

    private readonly List<string> _errosValidacao = new();
    private readonly HashSet<string> _camposInvalidos = new();

    private bool _tabuleiroAleatorio;
    private int _numeroGrupos;
