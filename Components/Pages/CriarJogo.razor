            </section>
        </EditForm>
    }
</div>


@code {
    private Configuracao _configuracao = new();

    private List<Tabuleiros> _tabuleirosDisponiveis = new();

    private int QtdCasasSelecionado =>
        _tabuleirosDisponiveis.FirstOrDefault(t => t.TabuleiroId == _configuracao.IdTabuleiro)?.QtdCasas ?? 0;

    private AbaCriarJogo _abaAtual = AbaCriarJogo.Basicas;
    private int _limiteGeralMinDado = -10;
    private int _limiteGeralMaxDado = 10;
