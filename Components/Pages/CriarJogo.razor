@page "/jogo/criar"

@using BancoImobiliario.Models
@using BancoImobiliario.Models.Enums
@using BancoImobiliario.Models.Helpers
@using BancoImobiliario.Services
@using BancoImobiliario.Services.Tabuleiro
@using Microsoft.AspNetCore.Components.Forms

@inject ConfiguracaoService ConfiguracaoService
@inject NavigationManager NavigationManager
@inject PartidaService PartidaService
@inject BrowserIdentificacaoService BrowserIdentificacaoService
@inject TabuleiroService TabuleiroService
@inject GerenciamentoTabuleiroService GerenciamentoService

<PageTitle>Criar Jogo</PageTitle>

<div class="criar-jogo-page">

    <section class="game-hero">
        <div class="game-hero-content">
            <span class="game-eyebrow">
                <i class="bi bi-dice-5-fill"></i>
                <span>Banco Imobiliário</span>
            </span>
            <h1>Criar Jogo</h1>
            <p>Configure a sala, o tabuleiro e as regras de vitória antes de iniciar a partida.</p>

            <button type="button" class="enter-game-link" @onclick="IrParaEntrarJogo">
                <i class="bi bi-box-arrow-in-right"></i>
                <span>Já tem um código? Entrar em um jogo</span>
            </button>
        </div>

        <div class="room-ticket">
            <div class="ticket-glow"></div>
            <span class="ticket-label">
                <i class="bi bi-key-fill"></i>
                Código da sala
            </span>
            <strong>@CodigoSalaDisplay</strong>
            <small>Gerado automaticamente</small>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_mensagemSucesso))
    {
        <div class="game-alert success">
            <i class="bi bi-check-circle-fill"></i>
            <span>@_mensagemSucesso</span>
        </div>
    }

    @if (!string.IsNullOrWhiteSpace(_mensagemErro))
    {
        <div class="game-alert error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>@_mensagemErro</span>
        </div>
    }

    @if (_errosValidacao.Count > 0)
    {
        <div class="game-alert validation">
            <i class="bi bi-shield-exclamation"></i>
            <div>
                <strong>Revise as regras da partida:</strong>
                <ul>
                    @foreach (var erro in _errosValidacao)
                    {
                        <li>@erro</li>
                    }
                </ul>
            </div>
        </div>
    }

    @if (_carregando)
    {
        <div class="loading-panel">
            <i class="bi bi-hourglass-split"></i>
            <span>Preparando configuração inicial...</span>
        </div>
    }
    else
    {
        <EditForm Model="_configuracao" OnSubmit="SalvarAsync" FormName="frmCriarJogo">

            <section class="game-shell">

                <div class="mode-card">
                    <div class="mode-header">
                        <div>
                            <h2>
                                <i class="bi bi-controller"></i>
                                Tipo de Jogo
                            </h2>
                            <p>Escolha como a partida será criada.</p>
                        </div>
                    </div>

                    <div class="mode-options">
                        @foreach (var tipo in _tiposJogo)
                        {
                            <button type="button"
                                    class="@ClasseTipoJogo(tipo.Valor)"
                                    @onclick="() => SelecionarTipoJogo(tipo.Valor)">
                                <div class="mode-option-icon">
                                    <i class="@ObterIconeTipoJogo(tipo.Valor)"></i>
                                </div>
                                <div class="mode-option-text">
                                    <strong>@tipo.Descricao</strong>
                                    <small>@ObterDescricaoTipoJogo(tipo.Valor)</small>
                                </div>
                                <div class="mode-option-check">
                                    <i class="bi bi-check-lg"></i>
                                </div>
                            </button>
                        }
                    </div>
                </div>

                <div class="setup-tabs">
                    <button type="button"
                            class="@ClasseAba(AbaCriarJogo.Basicas)"
                            @onclick="() => _abaAtual = AbaCriarJogo.Basicas">
                        <i class="bi bi-sliders"></i>
                        <span>Configurações Básicas</span>
                        @if (ContarErrosAba(AbaCriarJogo.Basicas) > 0)
                        {
                            <span class="tab-badge">@ContarErrosAba(AbaCriarJogo.Basicas)</span>
                        }
                    </button>

                    <button type="button"
                            class="@ClasseAba(AbaCriarJogo.Tabuleiro)"
                            @onclick="() => _abaAtual = AbaCriarJogo.Tabuleiro">
                        <i class="bi bi-grid-3x3-gap"></i>
                        <span>Configuração Tabuleiro</span>
                        @if (ContarErrosAba(AbaCriarJogo.Tabuleiro) > 0)
                        {
                            <span class="tab-badge">@ContarErrosAba(AbaCriarJogo.Tabuleiro)</span>
                        }
                    </button>

                    <button type="button"
                            class="@ClasseAba(AbaCriarJogo.Finalizacao)"
                            @onclick="() => _abaAtual = AbaCriarJogo.Finalizacao">
                        <i class="bi bi-trophy"></i>
                        <span>Finalização / Outras</span>
                        @if (ContarErrosAba(AbaCriarJogo.Finalizacao) > 0)
                        {
                            <span class="tab-badge">@ContarErrosAba(AbaCriarJogo.Finalizacao)</span>
                        }
                    </button>

                    <button type="button"
                            class="random-all-button"
                            @onclick="GerarTudoAleatorioAsync"
                            title="Gerar configuração aleatória completa">
                        <i class="bi bi-stars"></i>
                        <span>Aleatorizar tudo</span>
                    </button>
                </div>

                <div class="setup-content">

                    @if (_abaAtual == AbaCriarJogo.Basicas)
                    {
                        <section class="setup-panel active-panel">
                            <div class="panel-title">
                                <div class="panel-title-icon">
                                    <i class="bi bi-controller"></i>
                                </div>
                                <div>
                                    <h2>Configurações Básicas</h2>
                                    <p>Defina jogadores, dinheiro inicial, dificuldade, dados, casas e hotéis.</p>
                                </div>
                            </div>

                            <div class="setup-grid">

                                <div class="rule-box span-2">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-door-closed"></i>
                                                Identificação da sala
                                            </h3>
                                            <span>O código será gerado automaticamente ao criar a partida.</span>
                                        </div>
                                    </div>

                                    <div class="field-grid columns-2">
                                        <div class="field">
                                            <label>Código da Sala</label>
                                            <div class="input-shell disabled">
                                                <i class="bi bi-hash input-icon"></i>
                                                <input class="setup-input"
                                                       value="@CodigoSalaDisplay"
                                                       disabled />
                                            </div>
                                        </div>

                                        <div class="field">
                                            <label>Dificuldade</label>
                                            <div class="input-shell">
                                                <i class="bi bi-speedometer2 input-icon"></i>
                                                <InputSelect class="@ClasseCampo(nameof(Configuracao.Dificuldade))"
                                                             @bind-Value="_configuracao.Dificuldade">
                                                    @foreach (var item in _dificuldades)
                                                    {
                                                        <option value="@item.Valor">@item.Descricao</option>
                                                    }
                                                </InputSelect>
                                                <i class="bi bi-chevron-down input-suffix"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rule-box">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-people-fill"></i>
                                                Jogadores
                                            </h3>
                                            <span>Mínimo 2 jogadores.</span>
                                        </div>
                                    </div>

                                    <div class="hybrid-control">
                                        <div class="stepper">
                                            <button type="button" class="stepper-btn" @onclick="() => AjustarJogadores(-1)">
                                                <i class="bi bi-dash-lg"></i>
                                            </button>
                                            <div class="stepper-display">
                                                <strong>@_configuracao.QtdJogadores</strong>
                                                <small>participantes</small>
                                            </div>
                                            <button type="button" class="stepper-btn" @onclick="() => AjustarJogadores(1)">
                                                <i class="bi bi-plus-lg"></i>
                                            </button>
                                        </div>
                                        <input type="range"
                                               min="2"
                                               max="8"
                                               step="1"
                                               class="game-slider"
                                               value="@_configuracao.QtdJogadores"
                                               style="@EstiloProgresso(_configuracao.QtdJogadores, 2, 8)"
                                               @oninput="OnQtdJogadoresInput" />
                                        <div class="slider-ticks">
                                            <span>2</span><span>4</span><span>6</span><span>8</span>
                                        </div>
                                    </div>
                                </div>

                                <div class="rule-box">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-cash-coin"></i>
                                                Saldo inicial
                                            </h3>
                                            <span>Dinheiro recebido ao começar.</span>
                                        </div>
                                    </div>

                                    <div class="money-hero">
                                        <span class="money-currency">R$</span>
                                        <input type="number" step="any"
                                               class="@ClasseCampo(nameof(Configuracao.ValorInicial)) money-input"
                                               value="@_configuracao.ValorInicial.ToString(System.Globalization.CultureInfo.InvariantCulture)"
                                               @onchange="OnValorInicialInput" />
                                    </div>

                                    <div class="quick-chips">
                                        @foreach (var preset in new[] { 1500m, 2500m, 5000m, 10000m })
                                        {
                                            var local = preset;
                                            <button type="button"
                                                    class="@(_configuracao.ValorInicial == local ? "quick-chip active" : "quick-chip")"
                                                    @onclick="() => _configuracao.ValorInicial = local">
                                                R$ @local.ToString("N0")
                                            </button>
                                        }
                                    </div>
                                </div>

                                <div class="rule-box span-2">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-arrow-repeat"></i>
                                                Bônus de volta
                                            </h3>
                                            <span>Valor recebido ao completar uma volta no tabuleiro.</span>
                                        </div>
                                    </div>

                                    <div class="field-grid columns-2">
                                        <div class="field">
                                            <label>Valor do bônus</label>
                                            <div class="input-shell">
                                                <span class="input-prefix">R$</span>
                                                <InputNumber class="@ClasseCampo(nameof(Configuracao.BonusVolta))"
                                                             @bind-Value="_configuracao.BonusVolta" />
                                            </div>
                                        </div>

                                        <div class="field">
                                            <label>
                                                Aplicar até a volta
                                                @if (_configuracao.BonusVolta <= 0)
                                                {
                                                    <span class="label-hint">— defina um bônus primeiro</span>
                                                }
                                            </label>
                                            <div class="input-shell @(_configuracao.BonusVolta <= 0 ? "disabled" : "")">
                                                <i class="bi bi-flag-fill input-icon"></i>
                                                <InputNumber class="@ClasseCampo(nameof(Configuracao.BonusAteVolta))"
                                                             @bind-Value="_configuracao.BonusAteVolta"
                                                             disabled="@(_configuracao.BonusVolta <= 0)" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rule-box span-2">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-dice-5-fill"></i>
                                                Configurar dado
                                            </h3>
                                            <span>O valor máximo é travado pelo mínimo automaticamente.</span>
                                        </div>
                                        <div class="dice-preview">
                                            <span>@_configuracao.ValMinDado</span>
                                            <i class="bi bi-arrow-right"></i>
                                            <span>@_configuracao.ValMaxDado</span>
                                        </div>
                                    </div>

                                    <div class="dual-slider-group">
                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Valor mínimo</strong>
                                                <span class="dual-slider-value">@_configuracao.ValMinDado</span>
                                            </div>
                                            <input type="range"
                                                   min="@_limiteGeralMinDado"
                                                   max="@_limiteGeralMaxDado"
                                                   step="1"
                                                   class="game-slider"
                                                   value="@_configuracao.ValMinDado"
                                                   style="@EstiloProgresso(_configuracao.ValMinDado, _limiteGeralMinDado, _limiteGeralMaxDado)"
                                                   @oninput="OnDadoMinInput" />
                                        </div>

                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Valor máximo</strong>
                                                <span class="dual-slider-value">@_configuracao.ValMaxDado</span>
                                                <span class="dual-slider-lock">
                                                    <i class="bi bi-lock-fill"></i> mín @_configuracao.ValMinDado
                                                </span>
                                            </div>
                                            <input type="range"
                                                   min="@_configuracao.ValMinDado"
                                                   max="@_limiteGeralMaxDado"
                                                   step="1"
                                                   class="game-slider accent-amber"
                                                   value="@_configuracao.ValMaxDado"
                                                   style="@EstiloProgresso(_configuracao.ValMaxDado, _configuracao.ValMinDado, _limiteGeralMaxDado)"
                                                   @oninput="OnDadoMaxInput" />
                                        </div>

                                        <div class="field">
                                            <label>Restrição (opcional)</label>
                                            <div class="input-shell">
                                                <i class="bi bi-funnel input-icon"></i>
                                                <InputText class="@ClasseCampo(nameof(Configuracao.RestricaoDado))"
                                                           placeholder="Ex: não permitir valores pares"
                                                           @bind-Value="_configuracao.RestricaoDado" />
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rule-box span-2">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-house-fill"></i>
                                                Casas e Hotéis
                                            </h3>
                                            <span>O mínimo de casas para hotel respeita o máximo de casas.</span>
                                        </div>
                                        <div class="dice-preview">
                                            <i class="bi bi-house"></i> @_configuracao.QtdMaxCasas
                                            <i class="bi bi-dot"></i>
                                            <i class="bi bi-building"></i> @_configuracao.QtdMaxHoteis
                                        </div>
                                    </div>

                                    <div class="dual-slider-group">
                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Máx. de casas por propriedade</strong>
                                                <span class="dual-slider-value">@_configuracao.QtdMaxCasas</span>
                                            </div>
                                            <input type="range"
                                                   min="0"
                                                   max="10"
                                                   step="1"
                                                   class="game-slider"
                                                   value="@_configuracao.QtdMaxCasas"
                                                   style="@EstiloProgresso(_configuracao.QtdMaxCasas, 0, 10)"
                                                   @oninput="OnMaxCasasInput" />
                                        </div>

                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Mín. casas para construir hotel</strong>
                                                <span class="dual-slider-value">@_configuracao.MinCasasParaHotel</span>
                                                <span class="dual-slider-lock">
                                                    <i class="bi bi-lock-fill"></i> máx @_configuracao.QtdMaxCasas
                                                </span>
                                            </div>
                                            <input type="range"
                                                   min="0"
                                                   max="@(_configuracao.QtdMaxCasas <= 0 ? 1 : _configuracao.QtdMaxCasas)"
                                                   step="1"
                                                   class="game-slider accent-amber"
                                                   value="@_configuracao.MinCasasParaHotel"
                                                   @oninput="OnMinCasasHotelInput"
                                                   style="@EstiloProgresso(_configuracao.MinCasasParaHotel, 0, _configuracao.QtdMaxCasas)"
                                                   disabled="@(_configuracao.QtdMaxCasas <= 0)" />
                                        </div>

                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Máx. de hotéis por propriedade</strong>
                                                <span class="dual-slider-value">@_configuracao.QtdMaxHoteis</span>
                                            </div>
                                            <input type="range"
                                                   min="0"
                                                   max="10"
                                                   step="1"
                                                   class="game-slider accent-violet"
                                                   value="@_configuracao.QtdMaxHoteis"
                                                   style="@EstiloProgresso(_configuracao.QtdMaxHoteis, 0, 10)"
                                                   @oninput="OnMaxHoteisInput" />
                                        </div>
                                    </div>

                                    <label class="@ClasseChip(_configuracao.RemoverCasasAposHotel)" style="margin-top: 1rem;">
                                        <InputCheckbox @bind-Value="_configuracao.RemoverCasasAposHotel" />
                                        <span class="chip-content">
                                            <strong>Remover casas após hotel</strong>
                                            <small>Ao comprar hotel, as casas usadas deixam de contar separadamente.</small>
                                        </span>
                                        <i class="bi bi-check-circle-fill chip-check"></i>
                                    </label>
                                </div>

                            </div>
                        </section>
                    }

                    @if (_abaAtual == AbaCriarJogo.Tabuleiro)
                    {
                        <section class="setup-panel active-panel">
                            <div class="panel-title">
                                <div class="panel-title-icon">
                                    <i class="bi bi-grid-3x3-gap"></i>
                                </div>
                                <div>
                                    <h2>Configuração do Tabuleiro</h2>
                                    <p>Selecione o layout, fronteiras, tipos de casas e efeitos.</p>
                                </div>
                            </div>

                            <div class="setup-grid">

                                <div class="rule-box span-2">
                                    <div class="rule-box-header with-action">
                                        <div>
                                            <h3>
                                                <i class="bi bi-map"></i>
                                                Configuração geral
                                            </h3>
                                            <span>Escolha o formato do mapa e suas regras.</span>
                                        </div>

                                        <button type="button"
                                                class="mini-action-button"
                                                @onclick="GerarTabuleiroAleatorioAsync">
                                            <i class="bi bi-shuffle"></i>
                                            <span>Aleatorizar tabuleiro</span>
                                        </button>
                                    </div>

                                    <div class="field" style="margin-bottom: 1.5rem;">
                                        <label>Selecione o Tabuleiro</label>
                                        <div class="input-shell">
                                            <i class="bi bi-grid-3x3 input-icon"></i>
                                            <InputSelect class="@ClasseCampo(nameof(Configuracao.IdTabuleiro))"
                                                         Value="@_configuracao.IdTabuleiro"
                                                         ValueExpression="@(() => _configuracao.IdTabuleiro)"
                                                         ValueChanged="@((int id) => OnTabuleiroChangedAsync(id))">
                                                <option value="0" disabled>Selecione um tabuleiro...</option>
                                                @foreach (var tab in _tabuleirosDisponiveis)
                                                {
                                                    <option value="@tab.TabuleiroId">@tab.Nome (@tab.QtdCasas casas)</option>
                                                }
                                            </InputSelect>
                                            <i class="bi bi-chevron-down input-suffix"></i>
                                        </div>
                                    </div>

                                    <div class="chip-row" style="margin-bottom: 1rem;">
                                        <label class="@ClasseChip(_tabuleiroAleatorio)">
                                            <InputCheckbox @bind-Value="_tabuleiroAleatorio" />
                                            <span class="chip-content">
                                                <strong>Gerar posições aleatórias</strong>
                                                <small>Distribui as casas aleatoriamente pela grade.</small>
                                            </span>
                                            <i class="bi bi-check-circle-fill chip-check"></i>
                                        </label>

                                        <label class="@ClasseChip(_configuracao.TabuleiroOculto)">
                                            <InputCheckbox @bind-Value="_configuracao.TabuleiroOculto" />
                                            <span class="chip-content">
                                                <strong>Nomes ocultos</strong>
                                                <small>Oculta nomes das posições no início.</small>
                                            </span>
                                            <i class="bi bi-check-circle-fill chip-check"></i>
                                        </label>
                                    </div>

                                    <div class="dual-slider-group">
                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Número de grupos</strong>
                                                <span class="dual-slider-value">@_numeroGrupos</span>
                                            </div>
                                            <input type="range"
                                                   min="0"
                                                   max="@_maxGrupos"
                                                   step="1"
                                                   class="game-slider"
                                                   value="@_numeroGrupos"
                                                   style="@EstiloProgresso(_numeroGrupos, 0, _maxGrupos)"
                                                   @oninput="OnNumeroGruposInput" />
                                        </div>

                                        <div class="dual-slider-row">
                                            <div class="dual-slider-label">
                                                <strong>Fronteiras</strong>
                                                <span class="dual-slider-value">@_numeroFronteiras <small>de @_maxFronteirasTabuleiroAtual</small></span>
                                            </div>
                                            <input type="range"
                                                   min="0"
                                                   max="@_maxFronteirasTabuleiroAtual"
                                                   step="1"
                                                   class="game-slider accent-amber"
                                                   value="@_numeroFronteiras"
                                                   disabled="@(_maxFronteirasTabuleiroAtual == 0)"
                                                   style="@EstiloProgresso(_numeroFronteiras, 0, _maxFronteirasTabuleiroAtual)"
                                                   @oninput="OnNumeroFronteirasInput" />
                                        </div>

                                        <div class="field">
                                            <label>Regra de fronteira</label>
                                            <div class="input-shell">
                                                <i class="bi bi-signpost-split input-icon"></i>
                                                <InputSelect class="@ClasseCampo(nameof(Configuracao.RegraFronteira))"
                                                             @bind-Value="_configuracao.RegraFronteira">
                                                    @foreach (var item in _regrasFronteira)
                                                    {
                                                        <option value="@item.Valor">@item.Descricao</option>
                                                    }
                                                </InputSelect>
                                                <i class="bi bi-chevron-down input-suffix"></i>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <div class="rule-box span-2">
                                    <div class="rule-box-header">
                                        <div>
                                            <h3>
                                                <i class="bi bi-collection"></i>
                                                Tipos permitidos no tabuleiro
                                            </h3>
                                            <span>Ative os tipos e ajuste a quantidade de cada um.</span>
                                        </div>
                                    </div>
                                    <div class="type-grid">
                                        @{
                                            var tipos = new[]
                                            {
                                                ("Companhias", "bi bi-building", _permitirCompanhias, _qtdCompanhias, _maxCompanhias, "companhias"),
                                                ("Efeitos", "bi bi-magic", _permitirEfeitos, _qtdEfeitos, _maxEfeitos, "efeitos"),
                                                ("Especiais", "bi bi-stars", _permitirEspeciais, _qtdEspeciais, _maxEspeciais, "especiais"),
                                                ("Impostos", "bi bi-cash-stack", _permitirImpostos, _qtdImpostos, _maxImpostos, "impostos"),
                                                ("Prisão", "bi bi-shield-lock", _permitirPrisao, _qtdPrisao, _maxPrisao, "prisao")
                                            };
                                        }

                                        @foreach (var (nome, icone, ativo, qtd, max, key) in tipos)
                                        {
                                            <div class="@(ativo ? "type-card active" : "type-card")">
                                                <button type="button"
                                                        class="type-card-toggle"
                                                        @onclick="() => AlternarTipoTabuleiro(key)">
                                                    <div class="type-card-icon">
                                                        <i class="@icone"></i>
                                                    </div>
                                                    <div class="type-card-text">
                                                        <strong>@nome</strong>
                                                        <small>@(ativo ? "Ativado" : "Desativado")</small>
                                                    </div>
                                                    <i class="bi bi-check-circle-fill chip-check"></i>
                                                </button>

