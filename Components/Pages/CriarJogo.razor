    // ========================================
    // VALIDAÇÃO
    // ========================================

    private void PrepararCamposDependentes()
    {
        if (_configuracao.BonusVolta <= 0)
            _configuracao.BonusAteVolta = 0;

        if (!ExibirSubcriterioFinalizacao)
            _configuracao.SubCriterioFinalizacao = null;

        if ((VenceQuemJogo)_configuracao.VenceQuem != VenceQuemJogo.PontuacaoIndividual)
        {
            _configuracao.PonderacaoPropriedades = null;
            _configuracao.PonderacaoVoltas = null;
            _configuracao.PonderacaoSaldoFinal = null;
            _configuracao.PonderacaoSaldoTotal = null;
        }

        if (!_configuracao.EfeitosAleatorios)
            _configuracao.NaoRepetirEfeitos = false;

        if (!_permitirCompanhias) _qtdCompanhias = 0;
        if (!_permitirEfeitos) _qtdEfeitos = 0;
        if (!_permitirEspeciais) _qtdEspeciais = 0;
        if (!_permitirImpostos) _qtdImpostos = 0;
        if (!_permitirPrisao) _qtdPrisao = 0;
    }

    private bool ValidarTela()
    {
        _errosValidacao.Clear();
        _camposInvalidos.Clear();

        if (_configuracao.QtdJogadores < 2)
            Erro(nameof(Configuracao.QtdJogadores), "A partida precisa ter pelo menos 2 jogadores.");

        if (_configuracao.ValorInicial < 0)
            Erro(nameof(Configuracao.ValorInicial), "O valor inicial não pode ser negativo.");

        if (_configuracao.BonusVolta < 0)
            Erro(nameof(Configuracao.BonusVolta), "O bônus por volta não pode ser negativo.");

        if (_configuracao.BonusAteVolta < 0)
            Erro(nameof(Configuracao.BonusAteVolta), "O limite de bônus por volta não pode ser negativo.");

        if (_configuracao.ValMinDado < _limiteGeralMinDado)
            Erro(nameof(Configuracao.ValMinDado), $"O valor mínimo do dado não pode ser menor que {_limiteGeralMinDado}.");

        if (_configuracao.ValMaxDado > _limiteGeralMaxDado)
            Erro(nameof(Configuracao.ValMaxDado), $"O valor máximo do dado não pode ser maior que {_limiteGeralMaxDado}.");

        if (_configuracao.ValMaxDado < _configuracao.ValMinDado)
        {
            Erro(nameof(Configuracao.ValMinDado), "O valor mínimo do dado não pode ser maior que o valor máximo.");
            Erro(nameof(Configuracao.ValMaxDado), "O valor máximo do dado deve ser maior ou igual ao valor mínimo.");
        }

        if (_configuracao.QtdMaxCasas < 0)
            Erro(nameof(Configuracao.QtdMaxCasas), "A quantidade máxima de casas não pode ser negativa.");

        if (_configuracao.MinCasasParaHotel < 0)
            Erro(nameof(Configuracao.MinCasasParaHotel), "A quantidade mínima de casas para hotel não pode ser negativa.");

        if (_configuracao.QtdMaxCasas < _configuracao.MinCasasParaHotel)
        {
            Erro(nameof(Configuracao.QtdMaxCasas), "A quantidade máxima de casas não pode ser menor que o mínimo exigido para hotel.");
            Erro(nameof(Configuracao.MinCasasParaHotel), "O mínimo de casas para hotel não pode ser maior que o máximo de casas.");
        }

        if (_configuracao.QtdMaxHoteis < 0)
            Erro(nameof(Configuracao.QtdMaxHoteis), "A quantidade máxima de hotéis não pode ser negativa.");

        if (_configuracao.RemoverCasasAposHotel && (_configuracao.QtdMaxHoteis <= 0 || _configuracao.MinCasasParaHotel <= 0))
            Erro(nameof(Configuracao.RemoverCasasAposHotel), "Remover casas após hotel só faz sentido quando hotéis e mínimo de casas estão habilitados.");

        if (ExibirSubcriterioFinalizacao && (!_configuracao.SubCriterioFinalizacao.HasValue || _configuracao.SubCriterioFinalizacao.Value <= 0))
            Erro(nameof(Configuracao.SubCriterioFinalizacao), $"Informe um valor válido para: {LabelSubcriterioFinalizacao}.");

        if (_configuracao.PercentualDevolucaoVenda < 0 || _configuracao.PercentualDevolucaoVenda > 100)
            Erro(nameof(Configuracao.PercentualDevolucaoVenda), "O percentual de devolução em venda deve estar entre 0 e 100.");

        if (_numeroGrupos < 0)
            Erro("NumeroGrupos", "O número de grupos não pode ser negativo.");

        if (_numeroFronteiras < 0 || _numeroFronteiras > _maxFronteirasTabuleiroAtual)
            Erro("NumeroFronteiras", "O número de fronteiras é inválido ou excede o limite do tabuleiro selecionado.");

        if (_configuracao.IdTabuleiro <= 0)
            Erro(nameof(Configuracao.IdTabuleiro), "É obrigatório selecionar um tabuleiro.");

        var totalOutrasCasas = _qtdCompanhias + _qtdEfeitos + _qtdEspeciais + _qtdImpostos + _qtdPrisao;
        var qtdCidadesCalculada = QtdCasasSelecionado - totalOutrasCasas;

        if (totalOutrasCasas >= QtdCasasSelecionado && QtdCasasSelecionado > 0)
        {
            Erro(nameof(Configuracao.IdTabuleiro), $"O tabuleiro escolhido tem {QtdCasasSelecionado} espaços, mas você selecionou {totalOutrasCasas} casas especiais. Reduza os tipos ativados.");
        }
        else if (QtdCasasSelecionado > 0)
        {
            var minCidadesExigidas = (int)Math.Ceiling(QtdCasasSelecionado * (_minPercentualCidades / 100.0));

            if (qtdCidadesCalculada < minCidadesExigidas)
            {
                Erro(nameof(Configuracao.IdTabuleiro), $"O tabuleiro deve ter pelo menos {_minPercentualCidades}% de cidades ({minCidadesExigidas} espaços). Atualmente tem apenas {qtdCidadesCalculada}. Diminua as casas especiais.");
            }
        }

        ValidarQuantidadeTipo(_permitirCompanhias, _qtdCompanhias, "QtdCompanhias", "Companhias");
        ValidarQuantidadeTipo(_permitirEfeitos, _qtdEfeitos, "QtdEfeitos", "Efeitos");
        ValidarQuantidadeTipo(_permitirEspeciais, _qtdEspeciais, "QtdEspeciais", "Especiais");
        ValidarQuantidadeTipo(_permitirImpostos, _qtdImpostos, "QtdImpostos", "Impostos");
        ValidarQuantidadeTipo(_permitirPrisao, _qtdPrisao, "QtdPrisao", "Prisão");

        if ((VenceQuemJogo)_configuracao.VenceQuem == VenceQuemJogo.PontuacaoIndividual)
        {
            ValidarPonderacao(_configuracao.PonderacaoPropriedades, nameof(Configuracao.PonderacaoPropriedades), "ponderação de propriedades");
            ValidarPonderacao(_configuracao.PonderacaoVoltas, nameof(Configuracao.PonderacaoVoltas), "ponderação de voltas");
            ValidarPonderacao(_configuracao.PonderacaoSaldoFinal, nameof(Configuracao.PonderacaoSaldoFinal), "ponderação de saldo final");
            ValidarPonderacao(_configuracao.PonderacaoSaldoTotal, nameof(Configuracao.PonderacaoSaldoTotal), "ponderação de saldo total");
        }

        return _errosValidacao.Count == 0;
    }

    private void ValidarQuantidadeTipo(bool permitido, int quantidade, string campo, string descricao)
    {
        if (permitido && quantidade < 0)
            Erro(campo, $"A quantidade de {descricao} não pode ser negativa.");
    }

    private void ValidarPonderacao(int? valor, string campo, string descricao)
    {
        if (valor.HasValue && valor.Value < 0)
            Erro(campo, $"A {descricao} não pode ser negativa.");
    }

    private void Erro(string campo, string mensagem)
    {
        _camposInvalidos.Add(campo);

        if (!_errosValidacao.Contains(mensagem))
            _errosValidacao.Add(mensagem);
    }

    private void LimparMensagens()
    {
        _mensagemSucesso = null;
        _mensagemErro = null;
        _errosValidacao.Clear();
        _camposInvalidos.Clear();
    }

