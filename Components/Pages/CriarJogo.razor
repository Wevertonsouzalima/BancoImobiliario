    private string ClasseCampo(string campo)
    {
        return _camposInvalidos.Contains(campo)
            ? "setup-input invalid"
            : "setup-input";
    }

    private string ClasseAba(AbaCriarJogo aba)
    {
        return _abaAtual == aba
            ? "tab-button active"
            : "tab-button";
    }

    private string ClasseTipoJogo(int tipoJogo)
    {
        return _configuracao.TipoJogo == tipoJogo
            ? "mode-option active"
            : "mode-option";
    }

    private string ClasseChip(bool ativo, bool desabilitado = false)
    {
        var classes = "chip-toggle";

        if (ativo) classes += " active";
        if (desabilitado) classes += " disabled";

        return classes;
    }

    private static string ObterIconeTipoJogo(int tipoJogo)
    {
        return (TipoJogoConfiguracao)tipoJogo switch
        {
            TipoJogoConfiguracao.Solo => "bi bi-person-fill",
            TipoJogoConfiguracao.LocalMultiplayer => "bi bi-people-fill",
            TipoJogoConfiguracao.Rede => "bi bi-wifi",
            _ => "bi bi-controller"
        };
    }

    private int ContarErrosAba(AbaCriarJogo aba)
    {
        var camposBasicas = new[]
        {
            nameof(Configuracao.QtdJogadores), nameof(Configuracao.ValorInicial),
            nameof(Configuracao.BonusVolta), nameof(Configuracao.BonusAteVolta),
            nameof(Configuracao.ValMinDado), nameof(Configuracao.ValMaxDado),
            nameof(Configuracao.QtdMaxCasas), nameof(Configuracao.MinCasasParaHotel),
            nameof(Configuracao.QtdMaxHoteis), nameof(Configuracao.RemoverCasasAposHotel),
            nameof(Configuracao.Dificuldade), nameof(Configuracao.RestricaoDado)
        };

        var camposTabuleiro = new[]
        {
            "NumeroGrupos", "NumeroFronteiras",
            "QtdCompanhias", "QtdEfeitos", "QtdEspeciais", "QtdImpostos", "QtdPrisao",
            nameof(Configuracao.RegraFronteira), nameof(Configuracao.IdTabuleiro)
        };

        var camposFinalizacao = new[]
        {
            nameof(Configuracao.TipoFinalizacao), nameof(Configuracao.SubCriterioFinalizacao),
            nameof(Configuracao.VenceQuem), nameof(Configuracao.PercentualDevolucaoVenda),
            nameof(Configuracao.PonderacaoPropriedades), nameof(Configuracao.PonderacaoVoltas),
            nameof(Configuracao.PonderacaoSaldoFinal), nameof(Configuracao.PonderacaoSaldoTotal)
        };

        return aba switch
        {
            AbaCriarJogo.Basicas => camposBasicas.Count(c => _camposInvalidos.Contains(c)),
            AbaCriarJogo.Tabuleiro => camposTabuleiro.Count(c => _camposInvalidos.Contains(c)),
            AbaCriarJogo.Finalizacao => camposFinalizacao.Count(c => _camposInvalidos.Contains(c)),
            _ => 0
        };
    }

    private sealed record OpcaoSelect(int Valor, string Descricao);

    private enum AbaCriarJogo
    {
        Basicas = 1,
        Tabuleiro = 2,
        Finalizacao = 3
    }
