@page "/tabuleiro/gerenciar"

@using BancoImobiliario.Models
@using BancoImobiliario.Services.Tabuleiro
@using Microsoft.AspNetCore.Components.Forms

@inject GerenciamentoTabuleiroService GerenciamentoService
@inject NavigationManager NavigationManager

<PageTitle>Gerenciar Tabuleiros - Banco Imobiliário</PageTitle>

<div class="gerenciar-tabuleiro-page">

    <section class="page-hero">
        <div class="hero-content">
            <span class="page-eyebrow">
                <i class="bi bi-gear-fill"></i>
                <span>Modo Desenvolvedor</span>
            </span>
            <div class="hero-header-row">
                <div>
                    <h1>Modelagem de Tabuleiros</h1>
                    <p>Gerencie as especificações de tamanho e grade antes de desenhar o caminho das casas.</p>
                </div>
                <button type="button" class="btn primary btn-novo" @onclick="AbrirModalNovo">
                    <i class="bi bi-plus-lg"></i> Novo Tabuleiro
                </button>
            </div>
        </div>
    </section>

    @if (!string.IsNullOrWhiteSpace(_mensagemSucessoTopo))
    {
        <div class="alert success topo">
            <i class="bi bi-check-circle-fill"></i>
            <span>@_mensagemSucessoTopo</span>
            <button type="button" class="close-btn" @onclick="() => _mensagemSucessoTopo = null"><i class="bi bi-x-lg"></i></button>
        </div>
    }

    <div class="list-card">
        <div class="card-header">
            <h2>
                <i class="bi bi-list-ul"></i>
                Tabuleiros Cadastrados
            </h2>

            <div class="search-box">
                <i class="bi bi-search search-icon"></i>
                <input type="text" class="search-input" placeholder="Pesquisar em tudo (Ex: 70)..."
                       @bind="TermoBusca" @bind:event="oninput" />
            </div>
        </div>

        <div class="table-wrapper">
            <table class="tabuleiro-table">
                <thead>
                    <tr>
                        <th class="sortable" @onclick="@(() => MudarOrdenacao("Nome"))">
                            Nome @RenderIconeOrdenacao("Nome")
                        </th>
                        <th class="sortable" @onclick="@(() => MudarOrdenacao("Casas"))">
                            Casas @RenderIconeOrdenacao("Casas")
                        </th>
                        <th class="sortable" @onclick="@(() => MudarOrdenacao("Grade"))">
                            Grade @RenderIconeOrdenacao("Grade")
                        </th>
                        <th class="sortable" @onclick="@(() => MudarOrdenacao("Data"))">
                            Data Criação @RenderIconeOrdenacao("Data")
                        </th>
                        <th class="text-center">Ações</th>
                    </tr>
                </thead>
                <tbody>
                    @if (_tabuleirosFiltrados.Count == 0)
                    {
                        <tr>
                            <td colspan="5" class="text-center vazio">Nenhum tabuleiro encontrado.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var tab in _tabuleirosFiltrados)
                        {
                            <tr>
                                <td><strong class="tab-name">@tab.Nome</strong></td>
                                <td><span class="badge-info">@tab.QtdCasas</span></td>
                                <td><span class="badge-neutral">@($"{tab.LarguraGrade}x{tab.AlturaGrade}")</span></td>
                                <td class="tab-date">@tab.DataCriacao.ToString("dd/MM/yyyy HH:mm")</td>
                                <td class="acoes-cell">
                                    <button class="btn-table edit" title="Editar Metadados" @onclick="() => AbrirModalEdicao(tab.TabuleiroId)">
                                        <i class="bi bi-pencil-fill"></i>
                                    </button>
                                    <button class="btn-table layout" title="Desenhar Layout" @onclick="() => NavegarParaLayout(tab.TabuleiroId)">
                                        <i class="bi bi-grid-3x3-gap"></i>
                                    </button>
                                    <button class="btn-table fronteira" title="Gerenciar Fronteiras (Atalhos)" @onclick="() => NavegarParaFronteiras(tab.TabuleiroId)">
                                        <i class="bi bi-signpost-split-fill"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@* ===== MODAL DE CADASTRO / EDIÇÃO ===== *@
@if (_exibirModal)
{
    <div class="modal-overlay" @onclick="FecharModal">
        <div class="modal-content" @onclick:stopPropagation="true">
            <div class="modal-header">
                <h2>
                    <i class="bi @(IsEdicao ? "bi-pencil-square" : "bi-plus-circle-fill")"></i>
                    @(IsEdicao ? "Editar Tabuleiro" : "Novo Tabuleiro")
                </h2>
                <button type="button" class="close-btn" @onclick="FecharModal">
                    <i class="bi bi-x-lg"></i>
                </button>
            </div>

            <div class="modal-body">
                @if (!string.IsNullOrWhiteSpace(_mensagemErroModal))
                {
                    <div class="alert error">
                        <i class="bi bi-exclamation-triangle-fill"></i>
                        <span>@_mensagemErroModal</span>
                    </div>
                }

                @if (_possuiLayoutSalvo)
                {
                    <div class="info-lock-panel">
                        <i class="bi bi-lock-fill"></i>
                        <p>Este tabuleiro já possui um layout montado. As dimensões e a quantidade de casas estão bloqueadas para manter a integridade.</p>
                    </div>
                }

                <EditForm Model="_tabuleiroAtual" OnValidSubmit="SalvarTabuleiroAsync" FormName="frmModalTabuleiro">
                    <DataAnnotationsValidator />

                    <div class="form-grid">
                        <div class="field span-2">
                            <label>Nome do Tabuleiro</label>
                            <div class="input-shell">
                                <i class="bi bi-textarea-t input-icon"></i>
                                <InputText class="setup-input" @bind-Value="_tabuleiroAtual.Nome" placeholder="Ex: Padrão Diagonal 70" />
                            </div>
                            <ValidationMessage For="() => _tabuleiroAtual.Nome" class="validation-error" />
                        </div>

                        <div class="field">
                            <label>Quantidade de Casas</label>
                            <div class="input-shell @(_possuiLayoutSalvo ? "disabled" : "")">
                                <i class="bi bi-collection input-icon"></i>
                                <InputNumber class="setup-input" @bind-Value="_tabuleiroAtual.QtdCasas" disabled="@_possuiLayoutSalvo" />
                            </div>
                            <ValidationMessage For="() => _tabuleiroAtual.QtdCasas" class="validation-error" />
                        </div>

                        <div class="field">
                            <label>Tamanho da Casa (px)</label>
                            <div class="input-shell">
                                <i class="bi bi-aspect-ratio input-icon"></i>
                                <InputNumber class="setup-input" @bind-Value="_tabuleiroAtual.TamanhoCasaPx" />
                            </div>
                            <ValidationMessage For="() => _tabuleiroAtual.TamanhoCasaPx" class="validation-error" />
                        </div>

                        <div class="field">
                            <label>Grade (Colunas)</label>
                            <div class="input-shell @(_possuiLayoutSalvo ? "disabled" : "")">
                                <i class="bi bi-arrows-expand-vertical rotated input-icon"></i>
                                <InputNumber class="setup-input" @bind-Value="_tabuleiroAtual.LarguraGrade" disabled="@_possuiLayoutSalvo" />
                            </div>
                            <ValidationMessage For="() => _tabuleiroAtual.LarguraGrade" class="validation-error" />
                        </div>

                        <div class="field">
                            <label>Grade (Linhas)</label>
                            <div class="input-shell @(_possuiLayoutSalvo ? "disabled" : "")">
                                <i class="bi bi-arrows-expand-vertical input-icon"></i>
                                <InputNumber class="setup-input" @bind-Value="_tabuleiroAtual.AlturaGrade" disabled="@_possuiLayoutSalvo" />
                            </div>
                            <ValidationMessage For="() => _tabuleiroAtual.AlturaGrade" class="validation-error" />
                        </div>
                    </div>

                    <div class="form-actions modal-actions">
                        <button type="button" class="btn secondary" @onclick="FecharModal" disabled="@_processando">Cancelar</button>
                        <button type="submit" class="btn primary" disabled="@_processando">
                            @if (_processando)
                            {
                                <i class="bi bi-hourglass-split spin"></i> <span>Salvando...</span>
                            }
                            else
                            {
                                <i class="bi bi-check2-circle"></i> <span>@_textoBotaoSalvar</span>
                            }
                        </button>
                    </div>
                </EditForm>
            </div>
        </div>
    </div>
}

