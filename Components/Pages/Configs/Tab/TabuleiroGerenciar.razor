@code {
    private List<Models.Tabuleiros> _tabuleiros = new();
    private List<Models.Tabuleiros> _tabuleirosFiltrados = new();

    private Models.Tabuleiros _tabuleiroAtual = new();

    private bool _exibirModal = false;
    private bool _possuiLayoutSalvo = false;
    private bool _processando = false;

    private string? _mensagemSucessoTopo;
    private string? _mensagemErroModal;

    // Filtro e Ordenação
    private string _termoBusca = string.Empty;
    private string _colunaOrdenacao = "Data";
    private bool _ordenacaoAscendente = false;

    private bool IsEdicao => _tabuleiroAtual.TabuleiroId > 0;
    private string _textoBotaoSalvar => IsEdicao ? "Salvar Alterações" : "Criar Tabuleiro";

    public string TermoBusca
    {
        get => _termoBusca;
        set
        {
            _termoBusca = value;
            AplicarFiltrosEOrdenacao();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        await CarregarTabuleirosAsync();
    }

    private async Task CarregarTabuleirosAsync()
    {
        _tabuleiros = await GerenciamentoService.ObterTodosAsync();
        AplicarFiltrosEOrdenacao();
    }

    // ================== LÓGICA DO GRID (FILTRO E ORDENAÇÃO) ==================

    private void AplicarFiltrosEOrdenacao()
    {
        // 1. Filtragem Global
        var query = _tabuleiros.AsEnumerable();

        if (!string.IsNullOrWhiteSpace(_termoBusca))
        {
            var termo = _termoBusca.ToLowerInvariant();
            query = query.Where(t =>
                t.Nome.ToLowerInvariant().Contains(termo) ||
                t.QtdCasas.ToString().Contains(termo) ||
                t.LarguraGrade.ToString().Contains(termo) ||
                t.AlturaGrade.ToString().Contains(termo) ||
                t.TamanhoCasaPx.ToString().Contains(termo)
            );
        }

        // 2. Ordenação
        query = _colunaOrdenacao switch
        {
            "Nome" => _ordenacaoAscendente ? query.OrderBy(t => t.Nome) : query.OrderByDescending(t => t.Nome),
            "Casas" => _ordenacaoAscendente ? query.OrderBy(t => t.QtdCasas) : query.OrderByDescending(t => t.QtdCasas),
            "Grade" => _ordenacaoAscendente ? query.OrderBy(t => t.LarguraGrade).ThenBy(t => t.AlturaGrade) : query.OrderByDescending(t => t.LarguraGrade).ThenByDescending(t => t.AlturaGrade),
            "Data" => _ordenacaoAscendente ? query.OrderBy(t => t.DataCriacao) : query.OrderByDescending(t => t.DataCriacao),
            _ => query.OrderByDescending(t => t.DataCriacao)
        };

        _tabuleirosFiltrados = query.ToList();
    }

    private void MudarOrdenacao(string coluna)
    {
        if (_colunaOrdenacao == coluna)
        {
            _ordenacaoAscendente = !_ordenacaoAscendente;
        }
        else
        {
            _colunaOrdenacao = coluna;
            _ordenacaoAscendente = true;
        }
        AplicarFiltrosEOrdenacao();
    }

    private MarkupString RenderIconeOrdenacao(string coluna)
    {
        if (_colunaOrdenacao != coluna) return new MarkupString("");
        return _ordenacaoAscendente
            ? new MarkupString("<i class='bi bi-sort-up'></i>")
            : new MarkupString("<i class='bi bi-sort-down'></i>");
    }

    // ================== LÓGICA DO MODAL ==================

    private void AbrirModalNovo()
    {
        _tabuleiroAtual = new Models.Tabuleiros { TamanhoCasaPx = 100, QtdCasas = 70, LarguraGrade = 15, AlturaGrade = 10 };
        _possuiLayoutSalvo = false;
        _mensagemErroModal = null;
        _mensagemSucessoTopo = null;
        _exibirModal = true;
    }

    private async Task AbrirModalEdicao(int id)
    {
        _mensagemErroModal = null;
        _mensagemSucessoTopo = null;

        var tab = await GerenciamentoService.ObterPorIdAsync(id);
        if (tab != null)
        {
            _tabuleiroAtual = new Models.Tabuleiros
            {
                TabuleiroId = tab.TabuleiroId,
                Nome = tab.Nome,
                QtdCasas = tab.QtdCasas,
                LarguraGrade = tab.LarguraGrade,
                AlturaGrade = tab.AlturaGrade,
                TamanhoCasaPx = tab.TamanhoCasaPx,
                DataCriacao = tab.DataCriacao
            };

            _possuiLayoutSalvo = await GerenciamentoService.VerificarPossuiLayoutAsync(id);
            _exibirModal = true;
        }
    }

    private void FecharModal()
    {
        _exibirModal = false;
    }

    private async Task SalvarTabuleiroAsync()
    {
        _mensagemErroModal = null;
        _processando = true;

        try
        {
            await GerenciamentoService.SalvarAsync(_tabuleiroAtual);

            _mensagemSucessoTopo = IsEdicao
                            ? "Tabuleiro atualizado com sucesso!"
                            : "Tabuleiro criado! Agora você já pode configurar o layout.";

            await CarregarTabuleirosAsync();
            FecharModal();
        }
        catch (InvalidOperationException ex)
        {
            _mensagemErroModal = ex.Message;
        }
        catch (Exception ex)
        {
            _mensagemErroModal = "Falha ao gravar informações: " + (ex.InnerException?.Message ?? ex.Message);
        }
        finally
        {
            _processando = false;
        }
    }

    private void NavegarParaLayout(int id)
    {
        NavigationManager.NavigateTo($"/tabuleiro/layout/{id}");
    }
    private void NavegarParaFronteiras(int id)
    {
        NavigationManager.NavigateTo($"/tabuleiro/fronteiras/{id}");
    }
}