@page "/tabuleiro/layout/{IdTabuleiro:int}"

@using BancoImobiliario.Models
@using BancoImobiliario.Services.Tabuleiro

@using Microsoft.AspNetCore.Components.Web

@inject GerenciamentoTabuleiroService GerenciamentoService
@inject NavigationManager NavigationManager
@inject TabuleiroService TabuleiroService

<PageTitle>Editor de Layout - Banco Imobiliário</PageTitle>

<div class="layout-editor-page">

    @if (_carregando)
    {
        <div class="loading-panel">
            <i class="bi bi-hourglass-split spin"></i>
            <span>Carregando área de trabalho...</span>
        </div>
    }
    else if (_tabuleiro == null)
    {
        <div class="alert error">
            <i class="bi bi-exclamation-triangle-fill"></i>
            <span>Tabuleiro não encontrado.</span>
        </div>
    }
    else
    {
        <div class="editor-header">
            <div>
                <button type="button" class="btn-voltar" @onclick="Voltar">
                    <i class="bi bi-arrow-left"></i> Voltar
                </button>
                <h1>Modelando: @_tabuleiro.Nome</h1>
                <p>Grid: @_tabuleiro.LarguraGrade x @_tabuleiro.AlturaGrade | Total de Casas: @_tabuleiro.QtdCasas</p>
            </div>

            <div class="zoom-controls">
                <button type="button" class="btn-tool" @onclick="() => AjustarZoom(-0.1)" title="Menos Zoom"><i class="bi bi-zoom-out"></i></button>
                <span class="zoom-value">@((_zoom * 100).ToString("F0"))%</span>
                <button type="button" class="btn-tool" @onclick="() => AjustarZoom(0.1)" title="Mais Zoom"><i class="bi bi-zoom-in"></i></button>
                <button type="button" class="btn-tool" @onclick="() => _zoom = 1.0" title="Resetar Zoom"><i class="bi bi-aspect-ratio"></i></button>
            </div>

            <div class="header-actions">
                <button type="button" class="btn warning" @onclick="LimparTudo" disabled="@(_casasPosicionadas.Count == 0)">
                    <i class="bi bi-trash"></i> Limpar Grid
                </button>
                <button type="button" class="btn primary" @onclick="SalvarLayoutAsync" disabled="@(_casasPosicionadas.Count != _tabuleiro.QtdCasas || _salvando)">
                    @if (_salvando)
                    {
                        <i class="bi bi-hourglass-split spin"></i> <span>Salvando...</span>
                    }
                    else
                    {
                        <i class="bi bi-floppy"></i> <span>Salvar Layout Final</span>
                    }
                </button>
            </div>
        </div>

        @if (!string.IsNullOrWhiteSpace(_mensagemAlerta))
        {
            <div class="alert warning temp-alert">
                <i class="bi bi-exclamation-circle"></i>
                <span>@_mensagemAlerta</span>
            </div>
        }

        <div class="editor-workspace">

            @* PALETA DE FERRAMENTAS / ESTOQUE *@
            <div class="paleta-lateral">
                <h3>Estoque de Casas</h3>

                <div class="status-progresso">
                    <span>Progresso: @_casasPosicionadas.Count / @_tabuleiro.QtdCasas</span>
                    <div class="barra-progresso">
                        <div class="preenchimento" style="width: @((_casasPosicionadas.Count * 100) / _tabuleiro.QtdCasas)%"></div>
                    </div>
                </div>

                @if (ProximaCasa <= _tabuleiro.QtdCasas)
                {
                    <p class="instrucao">Arraste a peça ou <strong>clique no grid</strong> para posicioná-la:</p>
                    <div class="casa-draggable" draggable="true" @ondragstart="HandleDragStart">
                        <span>@ProximaCasa</span>
                    </div>
                }
                else
                {
                    <div class="alerta-concluido">
                        <i class="bi bi-check-circle-fill"></i>
                        Todas as casas foram posicionadas!
                    </div>
                }

                @if (_casasPosicionadas.Count > 0)
                {
                    <button type="button" class="btn secondary btn-desfazer" @onclick="DesfazerUltima">
                        <i class="bi bi-arrow-counterclockwise"></i> Desfazer Casa @(_casasPosicionadas.Count)
                    </button>
                }

                <div class="regras-box">
                    <h4><i class="bi bi-info-circle"></i> Regras</h4>
                    <ul>
                        <li>A Casa 1 pode ser colocada em qualquer lugar.</li>
                        <li>A partir da Casa 2, solte/clique apenas em posições adjacentes à última casa colocada.</li>
                        <li><strong>Circuito Fechado:</strong> A última casa deve ser vizinha da Casa 1.</li>
                    </ul>
                </div>
            </div>

            @* O GRID VISUAL (CANVAS) *@
            <div class="canvas-area">
                <div class="grid-wrapper" style="--zoom: @_zoom.ToString(System.Globalization.CultureInfo.InvariantCulture);">
                    <div class="grid-tabuleiro" style="--cols: @_tabuleiro.LarguraGrade; --rows: @_tabuleiro.AlturaGrade;">

                        @for (int l = 0; l < _tabuleiro.AlturaGrade; l++)
                        {
                            for (int c = 0; c < _tabuleiro.LarguraGrade; c++)
                            {
                                var linhaAtual = l;
                                var colunaAtual = c;
                                var casaNaPosicao = ObterCasaNaPosicao(colunaAtual, linhaAtual);
                                var ehDestinoValido = ValidarAdjacencia(colunaAtual, linhaAtual);

                                <div class="celula-grid @(casaNaPosicao != null ? "ocupada" : "") @(ehDestinoValido && casaNaPosicao == null ? "drop-valido" : "")"
                                     @onclick="() => ProcessarAcaoGrid(colunaAtual, linhaAtual)"
                                     @ondragover="HandleDragOver"
                                     @ondragover:preventDefault="true"
                                     @ondrop="() => ProcessarAcaoGrid(colunaAtual, linhaAtual)">

                                    @if (casaNaPosicao != null)
                                    {
                                        <div class="casa-colocada @(casaNaPosicao.Posicao == 1 ? "casa-inicio" : "") @(casaNaPosicao.Posicao == _casasPosicionadas.Count ? "ultima-colocada" : "")">
                                            @casaNaPosicao.Posicao
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="coord-hint">@colunaAtual,@linhaAtual</span>
                                    }
                                </div>
                            }
                        }

                    </div>
                </div>
            </div>
        </div>
    }
</div>

<style>
    .layout-editor-page {
        height: 100vh;
        background: #050810;
        color: #e5e7eb;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        overflow: hidden;
    }

    .editor-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-bottom: 1.5rem;
        background: rgba(15, 23, 42, 0.8);
        padding: 1rem 1.5rem;
        border-radius: 12px;
        border: 1px solid rgba(148,163,184,0.1);
        flex-shrink: 0;
    }

        .editor-header h1 {
            font-size: 1.4rem;
            margin: 0.5rem 0 0.2rem;
        }

        .editor-header p {
            color: #94a3b8;
            font-size: 0.9rem;
            margin: 0;
        }

    /* Estilos do Zoom */
    .zoom-controls {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: rgba(0,0,0,0.3);
        padding: 0.4rem;
        border-radius: 8px;
        border: 1px solid rgba(148,163,184,0.2);
    }

    .btn-tool {
        background: transparent;
        border: none;
        color: #94a3b8;
        cursor: pointer;
        padding: 0.4rem;
        border-radius: 4px;
        transition: 0.2s;
    }

        .btn-tool:hover {
            background: rgba(148,163,184,0.2);
            color: #f8fafc;
        }

    .zoom-value {
        font-weight: 700;
        width: 45px;
        text-align: center;
        font-size: 0.9rem;
    }

    .header-actions {
        display: flex;
        gap: 0.8rem;
    }

    .btn {
        padding: 0.6rem 1.2rem;
        border-radius: 8px;
        font-weight: 700;
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        gap: 0.4rem;
        border: none;
        transition: 0.2s;
    }

        .btn:disabled {
            opacity: 0.5;
            cursor: not-allowed;
        }

        .btn.primary {
            background: #2563eb;
            color: white;
        }

            .btn.primary:not(:disabled):hover {
                background: #1d4ed8;
            }

        .btn.warning {
            background: rgba(239,68,68,0.15);
            color: #fca5a5;
            border: 1px solid rgba(239,68,68,0.3);
        }

            .btn.warning:not(:disabled):hover {
                background: rgba(239,68,68,0.25);
            }

        .btn.secondary {
            background: rgba(148,163,184,0.1);
            color: #cbd5e1;
        }

    .btn-voltar {
        background: transparent;
        border: none;
        color: #60a5fa;
        cursor: pointer;
        font-size: 0.85rem;
        font-weight: 700;
        padding: 0;
        display: flex;
        align-items: center;
        gap: 0.3rem;
    }

        .btn-voltar:hover {
            color: #3b82f6;
            text-decoration: underline;
        }

    .temp-alert {
        position: fixed;
        top: 20px;
        left: 50%;
        transform: translateX(-50%);
        z-index: 1000;
        animation: fadeOut 3s forwards;
    }
    @@keyframes fadeOut {
        0% {
            opacity: 1;
        }

        70% {
            opacity: 1;
        }

        100% {
            opacity: 0;
            display: none;
        }
    }

    .alert {
        padding: 1rem;
        border-radius: 8px;
        display: flex;
        align-items: center;
        gap: 0.6rem;
        font-weight: 600;
    }

        .alert.error {
            background: rgba(239,68,68,0.1);
            color: #fca5a5;
            border: 1px solid rgba(239,68,68,0.2);
        }

        .alert.warning {
            background: rgba(234,179,8,0.1);
            color: #fde047;
            border: 1px solid rgba(234,179,8,0.2);
            box-shadow: 0 10px 25px rgba(0,0,0,0.5);
        }

    .editor-workspace {
        display: flex;
        gap: 1.5rem;
        flex: 1;
        overflow: hidden;
    }

    .paleta-lateral {
        width: 300px;
        background: rgba(15,23,42,0.6);
        border: 1px solid rgba(148,163,184,0.1);
        border-radius: 12px;
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1rem;
        flex-shrink: 0;
        overflow-y: auto;
    }

        .paleta-lateral h3 {
            margin: 0;
            font-size: 1.1rem;
            border-bottom: 1px solid rgba(148,163,184,0.1);
            padding-bottom: 0.5rem;
        }

    .status-progresso {
        font-size: 0.85rem;
        font-weight: 700;
        color: #94a3b8;
    }

    .barra-progresso {
        height: 8px;
        background: #0f172a;
        border-radius: 4px;
        margin-top: 0.4rem;
        overflow: hidden;
    }

    .preenchimento {
        height: 100%;
        background: #10b981;
        transition: width 0.3s ease;
    }

    .instrucao {
        font-size: 0.85rem;
        color: #cbd5e1;
        margin: 0;
    }

    .casa-draggable {
        width: 80px;
        height: 80px;
        background: linear-gradient(135deg, #3b82f6, #2563eb);
        border-radius: 10px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 2rem;
        font-weight: 900;
        color: white;
        cursor: grab;
        box-shadow: 0 8px 20px rgba(37,99,235,0.4);
        margin: 0 auto;
        border: 2px solid #60a5fa;
    }

        .casa-draggable:active {
            cursor: grabbing;
            opacity: 0.8;
            transform: scale(0.95);
        }

    .alerta-concluido {
        background: rgba(16,185,129,0.15);
        color: #6ee7b7;
        padding: 1rem;
        border-radius: 8px;
        text-align: center;
        font-weight: 700;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .btn-desfazer {
        width: 100%;
        margin-top: auto;
    }

    .regras-box {
        margin-top: 1rem;
        background: rgba(0,0,0,0.2);
        padding: 1rem;
        border-radius: 8px;
        font-size: 0.8rem;
        color: #94a3b8;
    }

        .regras-box h4 {
            margin: 0 0 0.5rem;
            color: #cbd5e1;
            font-size: 0.85rem;
        }

        .regras-box ul {
            margin: 0;
            padding-left: 1.2rem;
        }

        .regras-box li {
            margin-bottom: 0.3rem;
        }

    /* CANVAS COM ZOOM */
    .canvas-area {
        flex: 1;
        overflow: auto;
        background: #0b1120;
        border: 1px solid rgba(148,163,184,0.15);
        border-radius: 12px;
    }

    .grid-wrapper {
        min-width: 100%;
        min-height: 100%;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 3rem;
        transform: scale(var(--zoom));
        transform-origin: center center;
        transition: transform 0.15s ease-out;
    }

    .grid-tabuleiro {
        display: grid;
        grid-template-columns: repeat(var(--cols), 65px);
        grid-template-rows: repeat(var(--rows), 65px);
        gap: 4px;
        margin: auto;
    }

    .celula-grid {
        background: rgba(30,41,59,0.3);
        border: 1px dashed rgba(148,163,184,0.15);
        border-radius: 6px;
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: 0.2s;
    }

    .coord-hint {
        font-size: 0.6rem;
        color: rgba(148,163,184,0.3);
        font-weight: 600;
        pointer-events: none;
    }

    .celula-grid.drop-valido {
        background: rgba(16,185,129,0.1);
        border-color: #10b981;
        cursor: pointer;
    }

        .celula-grid.drop-valido:hover {
            background: rgba(16,185,129,0.25);
        }

    .casa-colocada {
        width: 100%;
        height: 100%;
        background: #1e293b;
        border-radius: 6px;
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 800;
        font-size: 1.2rem;
        color: #f8fafc;
        border: 2px solid #475569;
        box-shadow: inset 0 0 10px rgba(0,0,0,0.5);
        animation: popIn 0.2s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .casa-inicio {
        border-color: #fbbf24;
        color: #fde047;
    }
    /* Destaque na Casa 1 */
    .ultima-colocada {
        background: #2563eb;
        border-color: #60a5fa;
        color: white;
        box-shadow: 0 0 15px rgba(59,130,246,0.5);
    }

    @@keyframes popIn {
        0% {
            transform: scale(0.5);
            opacity: 0;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }
</style>

@code {
    [Parameter]
    public int IdTabuleiro { get; set; }

    private Models.Tabuleiros? _tabuleiro;
    private bool _carregando = true;
    private bool _salvando = false;
    private string? _mensagemAlerta;

    private double _zoom = 1.0;

    private List<LayoutCasaMemoria> _casasPosicionadas = new();

    private int ProximaCasa => _casasPosicionadas.Count + 1;

    protected override async Task OnInitializedAsync()
    {
        _tabuleiro = await GerenciamentoService.ObterPorIdAsync(IdTabuleiro);

        if (_tabuleiro != null)
        {
            var layoutSalvo = await TabuleiroService.ObterLayoutPorTabuleiroIdAsync(IdTabuleiro);
            if (layoutSalvo != null && layoutSalvo.Any())
            {
                // OrderBy garante que a função de DesfazerUltima() funcione perfeitamente lendo do banco
                _casasPosicionadas = layoutSalvo.OrderBy(l => l.Posicao).Select(l => new LayoutCasaMemoria
                {
                    Posicao = l.Posicao,
                    Coluna = l.Coluna,
                    Linha = l.Linha
                }).ToList();
            }
        }

        _carregando = false;
    }

    private void AjustarZoom(double delta)
    {
        _zoom += delta;
        if (_zoom < 0.3) _zoom = 0.3;
        if (_zoom > 2.5) _zoom = 2.5;
    }

    private void HandleDragStart()
    {
        _mensagemAlerta = null;
    }

    private void HandleDragOver()
    {
        // Requerido pelo HTML5
    }

    // Método centralizado para lidar com Clique e Soltar
    private void ProcessarAcaoGrid(int coluna, int linha)
    {
        if (_tabuleiro == null || ProximaCasa > _tabuleiro.QtdCasas) return;

        if (ObterCasaNaPosicao(coluna, linha) != null)
        {
            DispararAlerta("Esta posição já está ocupada!");
            return;
        }

        if (!ValidarAdjacencia(coluna, linha))
        {
            DispararAlerta(ProximaCasa == _tabuleiro.QtdCasas
                ? "A última casa deve fechar o circuito (adjacente à Casa 1 e à penúltima)."
                : "A próxima casa deve ser adjacente à última casa colocada!");
            return;
        }

        _casasPosicionadas.Add(new LayoutCasaMemoria
        {
            Posicao = ProximaCasa,
            Coluna = coluna,
            Linha = linha
        });
    }

    private bool ValidarAdjacencia(int colunaDestino, int linhaDestino)
    {
        if (_casasPosicionadas.Count == 0) return true;

        var ultimaCasa = _casasPosicionadas.Last();

        var difColuna = Math.Abs(ultimaCasa.Coluna - colunaDestino);
        var difLinha = Math.Abs(ultimaCasa.Linha - linhaDestino);
        var ehVizinhoDaUltima = difColuna <= 1 && difLinha <= 1;

        if (ProximaCasa < _tabuleiro!.QtdCasas)
        {
            return ehVizinhoDaUltima;
        }
        else
        {
            // Regra da Última Casa: Circuito Fechado
            var casa1 = _casasPosicionadas.FirstOrDefault(c => c.Posicao == 1);
            if (casa1 == null) return ehVizinhoDaUltima; // Fallback caso ocorra anomalia de dados

            var difColCasa1 = Math.Abs(casa1.Coluna - colunaDestino);
            var difLinCasa1 = Math.Abs(casa1.Linha - linhaDestino);
            var ehVizinhoDaCasa1 = difColCasa1 <= 1 && difLinCasa1 <= 1;

            return ehVizinhoDaUltima && ehVizinhoDaCasa1;
        }
    }

    private LayoutCasaMemoria? ObterCasaNaPosicao(int coluna, int linha)
    {
        return _casasPosicionadas.FirstOrDefault(c => c.Coluna == coluna && c.Linha == linha);
    }

    private void DesfazerUltima()
    {
        if (_casasPosicionadas.Count > 0)
        {
            // Exatamente como funcionava antes
            _casasPosicionadas.RemoveAt(_casasPosicionadas.Count - 1);
        }
    }

    private void LimparTudo()
    {
        _casasPosicionadas.Clear();
    }

    private async Task SalvarLayoutAsync()
    {
        if (_casasPosicionadas.Count != _tabuleiro!.QtdCasas)
        {
            DispararAlerta("Você precisa posicionar todas as casas antes de salvar.");
            return;
        }

        _salvando = true;
        try
        {
            var layoutFormatado = _casasPosicionadas.Select(c => new LayoutTabuleiro
            {
                TabuleiroId = IdTabuleiro,
                Posicao = c.Posicao,
                Coluna = c.Coluna,
                Linha = c.Linha
            }).ToList();

            await GerenciamentoService.SalvarLayoutAsync(IdTabuleiro, layoutFormatado);
            NavigationManager.NavigateTo("/tabuleiro/gerenciar");
        }
        catch (Exception ex)
        {
            DispararAlerta("Erro ao salvar: " + (ex.InnerException?.Message ?? ex.Message));
        }
        finally
        {
            _salvando = false;
        }
    }

    private void Voltar()
    {
        NavigationManager.NavigateTo("/tabuleiro/gerenciar");
    }

    private async void DispararAlerta(string mensagem)
    {
        _mensagemAlerta = mensagem;
        StateHasChanged();
        await Task.Delay(3000);
        _mensagemAlerta = null;
        StateHasChanged();
    }

    private class LayoutCasaMemoria
    {
        public int Posicao { get; set; }
        public int Coluna { get; set; }
        public int Linha { get; set; }
    }
}